#!/bin/bash
# cc-notify — ping ANY live Claude Code session (any account) by friendly name or
# pane UUID. The general primitive of the two-way session-comms feature.
#
#   cc-notify <target> "<message>"   target = friendly-name | pane-UUID | --self
#   cc-notify --self                 print THIS session's pane UUID and exit
#   cc-notify --list [--json]        list sessions (delegates to cc-sessions)
#
# Options:
#   --from <name>     attribution written to the mailbox line (default: own
#                     registered name, else the account)
#   --mailbox-only    record to the mailbox but skip composer injection
#   -h, --help        this help
#
# Delivery (two-way transport):
#   1. it2 `session send -s <uuid> "<message>"`  — types the text, and
#   2. it2 `session send -s <uuid> $'\r'`         — submits it (CARRIAGE RETURN,
#      NOT newline: Claude Code's Ink composer binds Enter to \r only).
#   The text lands in the target's composer as a real user message — waking an
#   idle session or queuing into a busy one.
#   3. VERIFIED (2026-07-13 hardening): the pane is captured and the submit is
#      confirmed — a message still sitting at the composer '❯' gets up to 2 CR
#      retries; a strand is reported LOUDLY (exit 4), never as "delivered"
#      (an Ink redraw swallows the submit ~1-in-6; a strand sat 20 min once).
#   ALWAYS also appends ~/.claude/mailbox/<uuid>.md ("<ISO> [<from>] <message>")
#   as the durable fallback: a closed/recycled pane makes it2 exit non-zero, and
#   cc-notify then reports "mailbox only" and still exits 0 — never a hard fail.
#
# Resolution order: friendly name (exact, via the cc-registry) -> raw pane UUID
#   passthrough -> --self. Names never look like a UUID, so there is no ambiguity.
#
# Env overrides (tests): CC_REGISTRY_DIR, CC_MAILBOX_DIR, IT2_BIN.
# bash 3.2-safe. Exit 0 = delivered(+verified/unverifiable) or mailboxed; 2 = usage;
# 3 = unresolvable target; 4 = typed but STRANDED unsubmitted after retries (mailboxed).
set -uo pipefail

MAILBOX_DIR="${CC_MAILBOX_DIR:-$HOME/.claude/mailbox}"
IT2="${IT2_BIN:-$HOME/.claude/bin/it2}"

usage() { sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'; }

# cc-sessions lives beside cc-notify (same bin/). Prefer the sibling (deterministic
# for tests + symlinked deploys), then PATH, then the canonical ~/.claude/bin.
_sd="$(cd "$(dirname "$0")" 2>/dev/null && pwd || true)"
CCS=""
if   [ -n "$_sd" ] && [ -x "$_sd/cc-sessions" ]; then CCS="$_sd/cc-sessions"
elif command -v cc-sessions >/dev/null 2>&1;     then CCS="$(command -v cc-sessions)"
elif [ -x "$HOME/.claude/bin/cc-sessions" ];      then CCS="$HOME/.claude/bin/cc-sessions"
fi

command -v jq >/dev/null 2>&1 || { echo "cc-notify: jq required" >&2; exit 1; }

# --- parse args ---
FROM=""; MAILBOX_ONLY=0; TARGET=""; MSG=""; HAVE_TARGET=0; HAVE_MSG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --list)         shift; if [ -n "$CCS" ]; then exec "$CCS" "$@"; else echo "cc-notify: cc-sessions not found" >&2; exit 1; fi ;;
    --self)         TARGET="__self__"; HAVE_TARGET=1; shift ;;
    --mailbox-only) MAILBOX_ONLY=1; shift ;;
    --from)         FROM="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --from=*)       FROM="${1#--from=}"; shift ;;
    -h|--help)      usage; exit 0 ;;
    --*)            echo "cc-notify: unknown option '$1'" >&2; usage >&2; exit 2 ;;
    *)
      if   [ "$HAVE_TARGET" = 0 ]; then TARGET="$1"; HAVE_TARGET=1; shift
      elif [ "$HAVE_MSG" = 0 ];    then MSG="$1"; HAVE_MSG=1; shift
      else echo "cc-notify: too many arguments" >&2; usage >&2; exit 2; fi
      ;;
  esac
done

[ "$HAVE_TARGET" = 1 ] || { echo "cc-notify: no target given" >&2; usage >&2; exit 2; }

# --- resolve target -> pane UUID ---
own_uuid="${ITERM_SESSION_ID:-}"; own_uuid="${own_uuid##*:}"
resolve() {
  local t="$1" u=""
  if [ "$t" = "__self__" ]; then
    [ -n "$own_uuid" ] || return 1
    echo "$own_uuid"; return 0
  fi
  # exact friendly-name match (registry, via cc-sessions --json)
  if [ -n "$CCS" ]; then
    u="$("$CCS" --json 2>/dev/null | jq -r --arg n "$t" 'map(select(.name==$n)) | .[0].paneUUID // empty' 2>/dev/null)"
    [ -n "$u" ] && { echo "$u"; return 0; }
  fi
  # raw UUID passthrough
  if [[ "$t" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]]; then
    echo "$t"; return 0
  fi
  return 1
}

if ! uuid="$(resolve "$TARGET")"; then
  if [ "$TARGET" = "__self__" ]; then
    echo "cc-notify: --self needs \$ITERM_SESSION_ID (not in an iTerm2 pane)" >&2
  else
    echo "cc-notify: cannot resolve target '$TARGET' — not a live session name or a pane UUID" >&2
    echo "  try: cc-notify --list" >&2
  fi
  exit 3
fi

# `cc-notify --self` with no message = just print own UUID (utility).
if [ "$HAVE_MSG" = 0 ]; then
  if [ "$TARGET" = "__self__" ]; then echo "$uuid"; exit 0; fi
  echo "cc-notify: no message given" >&2; usage >&2; exit 2
fi

# --- attribution (default: own registered name, else account) ---
if [ -z "$FROM" ]; then
  rdir="${CC_REGISTRY_DIR:-$HOME/.claude/cc-registry}"
  if [ -n "$own_uuid" ] && [ -f "$rdir/$own_uuid.json" ]; then
    FROM="$(jq -r '.name // empty' "$rdir/$own_uuid.json" 2>/dev/null)"
  fi
  [ -z "$FROM" ] && FROM="$(basename "${CLAUDE_CONFIG_DIR:-$HOME/.claude}" | sed 's/^\.//')"
fi

# --- ALWAYS record the mailbox (durable fallback) ---
mailbox_write() {
  mkdir -p "$MAILBOX_DIR" 2>/dev/null || return 1
  printf '%s [%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$FROM" "$MSG" >> "$MAILBOX_DIR/$uuid.md"
}
mailbox_write || echo "cc-notify: warning — could not write mailbox $MAILBOX_DIR/$uuid.md" >&2

# --- inject into the composer (unless --mailbox-only) ---
if [ "$MAILBOX_ONLY" = 1 ]; then
  echo "cc-notify: [$uuid] recorded to mailbox (injection skipped: --mailbox-only)" >&2
  exit 0
fi

# text, then CR submit (\r — Ink composer submits on CR, never \n)
if ! { "$IT2" session send -s "$uuid" "$MSG" 2>/dev/null \
       && "$IT2" session send -s "$uuid" "$(printf '\r')" 2>/dev/null; }; then
  echo "cc-notify: pane $uuid unreachable (closed/recycled) — delivered to mailbox only" >&2
  exit 0
fi

# --- verify the SUBMIT, never trust the keystroke (hardened 2026-07-13) ----------------------
# An Ink redraw swallows the submitting newline ~1-in-6 (the handoff-fire as_write finding);
# a stranded message then sits at the composer '❯' indefinitely — observed 20 minutes on a
# live countermand the same day this was added. Same confirm-the-effect pattern as the
# handoff-fire relaunch fix: capture the pane, and while the message head still sits AT/AFTER
# the last composer prompt, re-send CR (2 retries), then fail LOUD — the mailbox already holds
# the message, but a strand must never be reported as "delivered".
# Exit codes: 0 = delivered (verified, or pane text unreadable — degrade gracefully);
#             4 = typed but STRANDED in the composer after retries (mailbox recorded).
_cap="$(mktemp "${TMPDIR:-/tmp}/cc-notify-cap.XXXXXX")"
trap 'rm -f "$_cap"' EXIT
_head="$(printf '%s' "$MSG" | head -1 | cut -c1-40)"
composer_stranded() { # 0 = stranded, 1 = clear/submitted, 2 = unreadable
  "$IT2" session capture -s "$uuid" -o "$_cap" >/dev/null 2>&1 || return 2
  [ -s "$_cap" ] || return 2
  # last composer-prompt line; the message head appearing ON or AFTER it = stranded.
  last_prompt="$(grep -n '❯' "$_cap" 2>/dev/null | tail -1 | cut -d: -f1)"
  [ -n "$last_prompt" ] || return 2
  hit="$(grep -nF "$_head" "$_cap" 2>/dev/null | tail -1 | cut -d: -f1)"
  [ -n "$hit" ] && [ "$hit" -ge "$last_prompt" ] && return 0
  return 1
}
_attempt=0
while :; do
  composer_stranded; _st=$?
  if [ "$_st" = 1 ]; then
    echo "cc-notify: delivered to $uuid (composer + mailbox; submit VERIFIED)" >&2
    exit 0
  fi
  if [ "$_st" = 2 ]; then
    echo "cc-notify: delivered to $uuid (composer + mailbox; submit UNVERIFIED — pane capture unavailable)" >&2
    exit 0
  fi
  _attempt=$((_attempt + 1))
  if [ "$_attempt" -gt 2 ]; then
    echo "cc-notify: STRANDED — message typed into $uuid but the composer never submitted after $_attempt CR retries; mailbox holds it. Submit manually (press Enter in that pane) or re-run." >&2
    exit 4
  fi
  sleep 1
  "$IT2" session send -s "$uuid" "$(printf '\r')" 2>/dev/null || true
done
