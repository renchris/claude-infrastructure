#!/bin/bash
# cc-notify — deliver a message to ANY Claude Code session (any account) by friendly name or pane UUID,
# as a MESSAGE it reads at a safe boundary — NEVER as keystrokes on its live input line.
#
#   cc-notify <target> "<message>"   target = friendly-name | pane-UUID | --self
#   cc-notify --self                 print THIS session's pane UUID and exit
#   cc-notify --list [--json]        list sessions (delegates to cc-sessions)
#
# Options:
#   --from <name>     attribution written to the inbox line (default: own registered name / account)
#   --mailbox-only    force inbox-only (skip the liveness classification / never a "not-live" note)
#   -h, --help        this help
#
# ── TRANSPORT (v2, 2026-07-20): the INBOX, drained at a safe boundary — NO keystroke injection ──
#   cc-notify APPENDS the message to the target's inbox ~/.claude/mailbox/<uuid>.md (one line:
#   "<ISO> [<from>] <message>"). The target's `hooks/mailbox-drain.sh` drains it and surfaces it as
#   CONTEXT — additionalContext on SessionStart/UserPromptSubmit, or a Stop decision:block reason —
#   so it ALWAYS lands as a message the session reads and NEVER races the user's typing (at a Claude
#   prompt OR a bash prompt). An idle session is woken by its own armed `cc-await-ping` watcher (which
#   polls this same inbox) → the harness task-completion notification re-invokes it. Non-keystroke,
#   robust to pane state. The v1 it2 `session send` transport is GONE — it raced live input (the exact
#   bug this replaces): at a bash prompt the surface text ran as a command; at a Claude prompt it
#   corrupted the half-typed message + cursor.
#
# The <uuid>.seen line-count cursor (shared with handoff-disposition.sh --ack and mailbox-drain.sh)
# makes delivery exactly-once. A single-line-per-message invariant is preserved (newlines in the
# message are collapsed to spaces) so the cursor counts messages, not physical lines.
#
# ── DELIVERABILITY (honest exit codes — an enqueue to a DEAD inbox must not read as delivered) ──
#   The target's liveness decides the verdict cc-announce trusts. A LIVE session (registered live in
#   cc-sessions, or a live iTerm2 pane) WILL drain the inbox → "delivered to inbox". A NOT-live target
#   (closed/recycled pane, dead pid) is enqueued but no drain will ever run → "mailbox only" (the
#   cc-announce alarm path; disk-truth that nothing reads is NOT a delivery — the W5 lesson holds).
#
# Resolution order: friendly name (exact, cc-registry) -> raw pane UUID passthrough -> --self.
# Env overrides (tests): CC_REGISTRY_DIR, CC_MAILBOX_DIR, IT2_BIN.
# bash 3.2-safe. Exit: 0 = enqueued (delivered to a live inbox, OR mailbox-only to a not-live/unknown-
#   liveness target — stderr says which); 2 = usage; 3 = unresolvable target; 5 = inbox UNWRITABLE
#   (LOUD — a message that cannot even persist must alarm, never a silent drop).
set -uo pipefail

MAILBOX_DIR="${CC_MAILBOX_DIR:-$HOME/.claude/mailbox}"
IT2="${IT2_BIN:-$HOME/.claude/bin/it2}"     # read-only here (session list, for pane liveness) — NEVER `session send`

usage() { sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'; }

# cc-sessions lives beside cc-notify (same bin/). Prefer the sibling (deterministic for tests +
# symlinked deploys), then PATH, then the canonical ~/.claude/bin. It is BOTH the name resolver and
# the liveness oracle (its --json lists LIVE sessions only: pid alive + pane present).
_sd="$(cd "$(dirname "$0")" 2>/dev/null && pwd || true)"
CCS=""
if   [ -n "$_sd" ] && [ -x "$_sd/cc-sessions" ]; then CCS="$_sd/cc-sessions"
elif command -v cc-sessions >/dev/null 2>&1;     then CCS="$(command -v cc-sessions)"
elif [ -x "$HOME/.claude/bin/cc-sessions" ];      then CCS="$HOME/.claude/bin/cc-sessions"
fi

command -v jq >/dev/null 2>&1 || { echo "cc-notify: jq required" >&2; exit 1; }

# --- parse args ---
FROM=""; MAILBOX_ONLY=0; TARGET=""; MSG=""; HAVE_TARGET=0; HAVE_MSG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --list)         shift; if [ -n "$CCS" ]; then exec "$CCS" "$@"; else echo "cc-notify: cc-sessions not found" >&2; exit 1; fi ;;
    --self)         TARGET="__self__"; HAVE_TARGET=1; shift ;;
    --mailbox-only) MAILBOX_ONLY=1; shift ;;
    --from)         FROM="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
    --from=*)       FROM="${1#--from=}"; shift ;;
    -h|--help)      usage; exit 0 ;;
    --*)            echo "cc-notify: unknown option '$1'" >&2; usage >&2; exit 2 ;;
    *)
      if   [ "$HAVE_TARGET" = 0 ]; then TARGET="$1"; HAVE_TARGET=1; shift
      elif [ "$HAVE_MSG" = 0 ];    then MSG="$1"; HAVE_MSG=1; shift
      else echo "cc-notify: too many arguments" >&2; usage >&2; exit 2; fi
      ;;
  esac
done

[ "$HAVE_TARGET" = 1 ] || { echo "cc-notify: no target given" >&2; usage >&2; exit 2; }

# --- resolve target -> pane UUID ---
own_uuid="${ITERM_SESSION_ID:-}"; own_uuid="${own_uuid##*:}"
resolve() {
  local t="$1" u=""
  if [ "$t" = "__self__" ]; then
    [ -n "$own_uuid" ] || return 1
    echo "$own_uuid"; return 0
  fi
  # exact friendly-name match (registry, via cc-sessions --json)
  if [ -n "$CCS" ]; then
    u="$("$CCS" --json 2>/dev/null | jq -r --arg n "$t" 'map(select(.name==$n)) | .[0].paneUUID // empty' 2>/dev/null)"
    [ -n "$u" ] && { echo "$u"; return 0; }
  fi
  # raw UUID passthrough
  if [[ "$t" =~ ^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$ ]]; then
    echo "$t"; return 0
  fi
  return 1
}

if ! uuid="$(resolve "$TARGET")"; then
  if [ "$TARGET" = "__self__" ]; then
    echo "cc-notify: --self needs \$ITERM_SESSION_ID (not in an iTerm2 pane)" >&2
  else
    echo "cc-notify: cannot resolve target '$TARGET' — not a live session name or a pane UUID" >&2
    echo "  try: cc-notify --list" >&2
  fi
  exit 3
fi

# `cc-notify --self` with no message = just print own UUID (utility).
if [ "$HAVE_MSG" = 0 ]; then
  if [ "$TARGET" = "__self__" ]; then echo "$uuid"; exit 0; fi
  echo "cc-notify: no message given" >&2; usage >&2; exit 2
fi

# --- attribution (default: own registered name, else account) ---
if [ -z "$FROM" ]; then
  rdir="${CC_REGISTRY_DIR:-$HOME/.claude/cc-registry}"
  if [ -n "$own_uuid" ] && [ -f "$rdir/$own_uuid.json" ]; then
    FROM="$(jq -r '.name // empty' "$rdir/$own_uuid.json" 2>/dev/null)"
  fi
  [ -z "$FROM" ] && FROM="$(basename "${CLAUDE_CONFIG_DIR:-$HOME/.claude}" | sed 's/^\.//')"
fi

# --- ENQUEUE to the inbox (the durable, keystroke-free transport) ---
# One message = one line: collapse any embedded newlines/CR to spaces so the <uuid>.seen line-count
# cursor counts MESSAGES, not physical lines (a multi-line message would otherwise desync the cursor).
MSG_1LINE="$(printf '%s' "$MSG" | tr '\r\n' '  ')"
mailbox_write() {
  mkdir -p "$MAILBOX_DIR" 2>/dev/null || return 1
  printf '%s [%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$FROM" "$MSG_1LINE" >> "$MAILBOX_DIR/$uuid.md"
}
if ! mailbox_write; then
  # A message that cannot even be persisted must NOT read as delivered — LOUD, never a silent drop.
  # F4: exit 5 alone is INERT (every fire-and-forget caller swallows it with `|| true`). So the backstop
  # for "cannot persist" must NOT depend on persistence — escalate DIRECTLY here: a durable alarm record
  # in a DIFFERENT dir (the target mailbox is what failed) + a best-effort push to the operator's phone.
  adir="${CC_COMMS_ALARM_DIR:-$HOME/.claude/autonomy/comms-alarms}"
  if mkdir -p "$adir" 2>/dev/null; then
    jq -nc --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)" --arg tgt "$uuid" --arg from "$FROM" --arg msg "$MSG_1LINE" \
      '{kind:"enqueue-failed", target:$tgt, from:$from, msg:$msg, ts:$ts}' \
      > "$adir/enqueue-fail-$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null)-$$.json" 2>/dev/null || true
  fi
  for _p in "$_sd/../scripts/push-send.sh" "$HOME/.claude/scripts/push-send.sh" "$(command -v push-send.sh 2>/dev/null || true)"; do
    [ -n "$_p" ] && [ -x "$_p" ] && { "$_p" send --title "cc-notify enqueue FAILED" --message "inbox unwritable for $uuid; NOT delivered: $MSG_1LINE" >/dev/null 2>&1 || true; break; }
  done
  echo "cc-notify: FAILED to write inbox $MAILBOX_DIR/$uuid.md — message NOT delivered; alarm recorded + phone paged (check permissions/disk)" >&2
  exit 5
fi

# --mailbox-only: caller explicitly wants a pure record, no liveness verdict.
if [ "$MAILBOX_ONLY" = 1 ]; then
  echo "cc-notify: [$uuid] recorded to inbox ($MAILBOX_DIR/$uuid.md; --mailbox-only)" >&2
  exit 0
fi

# --- liveness classification: does a LIVE session exist to drain this inbox? ---
# LIVE  → the drain hook (or the target's armed cc-await-ping watcher) WILL surface it → delivered.
# not-live (closed/recycled pane, dead pid) → enqueued but no drain will run → "mailbox only" (the
#   cc-announce alarm path; a dead inbox is not a delivery).
# unknown (no liveness oracle available) → degrade to "mailbox only", never a false "delivered".
target_live() {
  local u="$1"
  # self is always live (it is us)
  [ "$u" = "$own_uuid" ] && [ -n "$own_uuid" ] && return 0
  # registered live (cc-sessions --json lists LIVE rows only: pid alive + pane present)
  if [ -n "$CCS" ]; then
    local hit; hit="$("$CCS" --json 2>/dev/null | jq -r --arg u "$u" 'map(select(.paneUUID==$u)) | length' 2>/dev/null)"
    [ -n "$hit" ] && [ "$hit" != 0 ] && return 0
  fi
  # else a live (possibly unregistered) iTerm2 pane — read-only `session list`, never `session send`.
  # A VALID JSON array (even []) means the list is READABLE → membership is authoritative (a `[]` means
  # zero live panes → not-live, NOT "unknown"). Only a non-array / errored output is "unknown".
  local raw; raw="$("$IT2" session list --json 2>/dev/null || true)"
  if [ -n "$raw" ] && printf '%s' "$raw" | jq -e 'type=="array"' >/dev/null 2>&1; then
    printf '%s' "$raw" | jq -r '.[].id // empty' 2>/dev/null | grep -qxF "$u" && return 0
    return 1       # list readable AND uuid absent → authoritatively not-live
  fi
  return 2         # it2 unavailable / errored → no liveness oracle → unknown
}

# F5: a WAKE PATH — not mere registered-liveness — is what makes a delivery a wake. A fresh cc-await-ping
# heartbeat (<uuid>.watching) means the target's watcher wakes it within a poll; its ABSENCE means the
# target only drains on its NEXT turn (fine for a routine ping, but NOT a guaranteed wake for a terminal
# announce — cc-announce treats no-watcher as a degrade, never "wake confirmed"). Never equate live+idle
# with a wake (that WAS the W5 incident).
WATCH_FRESH_S="${CC_WATCH_FRESH_S:-90}"
wake_path_armed() {
  local u="$1" wf mt now
  wf="$MAILBOX_DIR/$u.watching"; [ -f "$wf" ] || return 1
  mt="$(stat -f %m "$wf" 2>/dev/null || stat -c %Y "$wf" 2>/dev/null || echo 0)"
  now="$(date +%s 2>/dev/null || echo 0)"; case "$mt" in ''|*[!0-9]*) mt=0 ;; esac
  [ "$(( now - mt ))" -le "$WATCH_FRESH_S" ]
}

target_live "$uuid"; _lv=$?
case "$_lv" in
  0)
    if [ "$uuid" = "$own_uuid" ] || wake_path_armed "$uuid"; then
      echo "cc-notify: delivered to inbox [$uuid] (live session, wake-path armed — its cc-await-ping watcher wakes it within a poll)" >&2
    else
      echo "cc-notify: delivered to inbox [$uuid] (live session, NO watcher armed — drains on its NEXT turn; delivered but not a guaranteed instant wake)" >&2
    fi
    exit 0 ;;
  1) echo "cc-notify: [$uuid] mailbox only — target is NOT a live session (closed/recycled pane); no drain will run. The message is recorded but unread until/unless that pane returns." >&2; exit 0 ;;
  *) echo "cc-notify: delivered to inbox [$uuid] (liveness UNVERIFIABLE — no session registry/pane list; recorded, will drain if the pane is live)" >&2; exit 0 ;;
esac
