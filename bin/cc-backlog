#!/bin/bash
# cc-backlog — durable, append-only work-ledger for the desk mission (Program D).
#
# The ledger is EVIDENCE (one-artifact-one-role): every status change is an
# APPEND-ONLY record; the current status of an item is the FOLD of its record
# trail (last transition wins). Nothing is ever rewritten in place EXCEPT the
# `compact` verb, which may drop ONLY terminal (done) items that have aged past a
# threshold — open work is never touched. Malformed lines are reported, never
# silently dropped.
#
# Store: JSONL at ${CC_BACKLOG_FILE:-~/.claude/autonomy/backlog.jsonl}
# IDs are event-keyed (hash of project+title+source) → re-`add` is idempotent.
#
# Verbs:
#   add     --title T [--project P] [--dod-ref R] [--source S]   → echoes the id
#   list    [--open | --all | --blocked | --project P] [--json]  (default: --open, table)
#   claim   <id> --by <sid>
#   done    <id> --evidence <ref>
#   reopen  <id>
#   block   <id> --needs "<operator-only step>"                  → status "blocked"
#   unblock <id>                                                 → back to "open"
#   reap    [--dry-run]                                          → stale-claim maintenance sweep
#   compact [--older-than-days N]                                (default N=30)
#
# BLOCKED-ON-OPERATOR: an item whose DoD needs an operator-only step (a key, a
# `launchctl bootout`, any human action) is `block`ed with the pending step in
# `--needs`. `blocked` folds distinctly from `open`, so cc-dispatch EXCLUDES it
# from the wave (no re-dispatch loop), while `list --open`/`--blocked` and the desk
# digest still SURFACE it + its `needs`. The operator `unblock`s once the step is
# done → back to `open` → dispatchable again.
#
# REAP (stale-claim maintenance — the dead-worker/thrash sweep): `block` above covers only
# OPERATOR-gated items and cc-reconcile heals only the SESSION registry — neither touches a
# CLAIM whose worker DIED. A `claim`ed item whose worker is gone (limit-killed, crashed, or
# self-closed without transitioning) stays `claimed` forever — cc-dispatch fires only
# status=="open", so the work STRANDS; a spawn-fail / land-conflict item THRASHES the wave
# (claim→reopen→claim…). `reap` folds the trail and, append-only + idempotent: (B, priority)
# BLOCKS an item with >= MAX_THRASH fast claim→reopen cycles (the spawn-fail / rebase-exit-5
# signature) so it leaves the wave for a human; (A) REOPENS a dead-worker claim idle past
# STALE_CLAIM_S whose claimer is not live — BOUNDED, so after MAX_ATTEMPTS dispatch claims a
# still-stale item is BLOCKED instead (never a slow-reopen loop). cc-reaper calls it each
# --reap sweep. All thresholds env-tunable (see the reap body).
set -uo pipefail

BACKLOG="${CC_BACKLOG_FILE:-$HOME/.claude/autonomy/backlog.jsonl}"

usage() {
  sed -n '2,/^set -uo/p' "$0" | sed 's/^# \{0,1\}//; /^set -uo/d'
}

now_iso()  { date -u +%Y-%m-%dT%H:%M:%SZ; }

# cutoff_iso <days-ago> → an ISO-8601 UTC timestamp N days in the past (BSD + GNU).
cutoff_iso() {
  local d="$1"
  date -u -v-"${d}"d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || date -u -d "-${d} days" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null
}

# mk_id <project> <title> <source> → 12-hex event key (US-separated, collision-safe).
mk_id() { printf '%s\037%s\037%s' "$1" "$2" "$3" | shasum -a 256 | cut -c1-12; }

ensure_file() {
  mkdir -p "$(dirname "$BACKLOG")" 2>/dev/null || true
  [ -f "$BACKLOG" ] || : > "$BACKLOG"
}

# Emit only well-formed records (must have id+event) to stdout; REPORT malformed
# lines to stderr (fail-loud). Never removes them from the file.
valid_records() {
  [ -f "$BACKLOG" ] || return 0
  local n=0 bad=0 line
  while IFS= read -r line || [ -n "$line" ]; do
    n=$((n + 1))
    [ -z "$line" ] && continue
    if printf '%s' "$line" | jq -e 'has("id") and has("event")' >/dev/null 2>&1; then
      printf '%s\n' "$line"
    else
      printf 'cc-backlog: malformed line %d skipped (still in file)\n' "$n" >&2
      bad=$((bad + 1))
    fi
  done < "$BACKLOG"
  [ "$bad" -eq 0 ] || printf 'cc-backlog: %d malformed line(s) reported above\n' "$bad" >&2
  return 0
}

# Fold the trail → a JSON ARRAY of one object per id (latest status + carried meta).
fold() {
  valid_records | jq -s '
    reduce .[] as $r ({};
      .[$r.id] = ((.[$r.id] // {}) as $p | {
        id:       $r.id,
        project:  ($r.project  // $p.project  // ""),
        title:    ($r.title    // $p.title    // ""),
        dodRef:   ($r.dodRef   // $p.dodRef   // ""),
        source:   ($r.source   // $p.source   // ""),
        by:       ($r.by       // $p.by       // ""),
        evidence: ($r.evidence // $p.evidence // ""),
        needs:    ($r.needs    // $p.needs    // ""),
        status: (
          if   $r.event == "done"    then "done"
          elif $r.event == "block"   then "blocked"
          elif $r.event == "unblock" then "open"
          elif $r.event == "claim"   then "claimed"
          elif $r.event == "reopen"  then "open"
          else ($p.status // "open") end),
        lastTs:   ($r.ts // $p.lastTs // "")
      })
    ) | [ .[] ]'
}

has_id() {
  [ -f "$BACKLOG" ] || return 1
  valid_records 2>/dev/null | jq -e -s --arg id "$1" 'any(.[]; .id == $id)' >/dev/null 2>&1
}

cmd_add() {
  local project="" title="" dod="" source=""
  while [ $# -gt 0 ]; do
    local key="$1"; shift
    case "$key" in
      --project) project="${1:-}"; [ $# -gt 0 ] && shift ;;
      --title)   title="${1:-}";   [ $# -gt 0 ] && shift ;;
      --dod-ref) dod="${1:-}";     [ $# -gt 0 ] && shift ;;
      --source)  source="${1:-}";  [ $# -gt 0 ] && shift ;;
      *) printf 'cc-backlog add: unknown arg %s\n' "$key" >&2; return 2 ;;
    esac
  done
  [ -n "$title" ] || { echo "cc-backlog add: --title is required" >&2; return 2; }
  [ -n "$project" ] || project="$(pwd)"
  ensure_file
  local id; id=$(mk_id "$project" "$title" "$source")
  if has_id "$id"; then echo "$id"; return 0; fi   # idempotent: no duplicate add
  jq -nc --arg id "$id" --arg ts "$(now_iso)" --arg project "$project" \
     --arg title "$title" --arg dod "$dod" --arg source "$source" \
     '{id:$id, ts:$ts, event:"add", project:$project, title:$title, dodRef:$dod, source:$source}' \
     >> "$BACKLOG"
  echo "$id"
}

cmd_transition() {
  local event="$1"; shift
  local id="${1:-}"; [ $# -gt 0 ] && shift
  local by="" evidence="" needs=""
  while [ $# -gt 0 ]; do
    local key="$1"; shift
    case "$key" in
      --by)       by="${1:-}";       [ $# -gt 0 ] && shift ;;
      --evidence) evidence="${1:-}"; [ $# -gt 0 ] && shift ;;
      --needs)    needs="${1:-}";    [ $# -gt 0 ] && shift ;;
      *) printf 'cc-backlog %s: unknown arg %s\n' "$event" "$key" >&2; return 2 ;;
    esac
  done
  [ -n "$id" ] || { printf 'cc-backlog %s: <id> is required\n' "$event" >&2; return 2; }
  # `block` MUST carry the pending operator step — that IS the desk-surfaced payload.
  if [ "$event" = block ] && [ -z "$needs" ]; then
    printf 'cc-backlog block: --needs "<operator-only step>" is required\n' >&2; return 2
  fi
  ensure_file
  has_id "$id" || { printf 'cc-backlog %s: unknown id %s\n' "$event" "$id" >&2; return 3; }
  jq -nc --arg id "$id" --arg ts "$(now_iso)" --arg event "$event" \
     --arg by "$by" --arg evidence "$evidence" --arg needs "$needs" \
     '{id:$id, ts:$ts, event:$event}
      + (if $by != ""       then {by:$by}             else {} end)
      + (if $evidence != "" then {evidence:$evidence} else {} end)
      + (if $needs != ""    then {needs:$needs}       else {} end)' \
     >> "$BACKLOG"
  echo "$id"
}

cmd_list() {
  local mode="open" projfilter="" fmt="table"
  while [ $# -gt 0 ]; do
    local key="$1"; shift
    case "$key" in
      --open)    mode="open" ;;
      --all)     mode="all" ;;
      --blocked) mode="blocked" ;;
      --project) projfilter="${1:-}"; [ $# -gt 0 ] && shift ;;
      --json) fmt="json" ;;
      *) printf 'cc-backlog list: unknown arg %s\n' "$key" >&2; return 2 ;;
    esac
  done
  # mode → status predicate (`keep`, shared by json + table): all=every item ·
  # blocked=only blocked · open(default)=every non-done item (so `blocked` items STILL
  # surface in the desk's --open view, but cc-dispatch's exact status=="open" filter
  # excludes them). `needs` (the pending operator step) is carried in both branches.
  # --json: the SAME filtered fold as the table, as a compact JSON array (one object per
  # item, full carried meta incl. `needs`) for machine consumers (cc-dispatch, the desk
  # digest). The default (table) branch is byte-unchanged for non-blocked rows.
  if [ "$fmt" = json ]; then
    fold | jq -c --arg mode "$mode" --arg proj "$projfilter" '
      def keep: if $mode=="all" then true elif $mode=="blocked" then .status=="blocked" else .status!="done" end;
      sort_by(.project, .title)
      | map( select(keep)
           | select($proj == "" or .project == $proj) )'
    return 0
  fi
  fold | jq -r --arg mode "$mode" --arg proj "$projfilter" '
    def keep: if $mode=="all" then true elif $mode=="blocked" then .status=="blocked" else .status!="done" end;
    sort_by(.project, .title) | .[]
    | select(keep)
    | select($proj == "" or .project == $proj)
    | [.status, .id, .project, .title, (.needs // "")] | @tsv
  ' | while IFS=$'\t' read -r st id proj title needs; do
      if [ "$st" = blocked ] && [ -n "$needs" ]; then
        printf '%-8s | %s | %-28s | %s  ⟵ needs: %s\n' "$st" "$id" "$proj" "$title" "$needs"
      else
        printf '%-8s | %s | %-28s | %s\n' "$st" "$id" "$proj" "$title"
      fi
    done
}

cmd_compact() {
  local days="30"
  while [ $# -gt 0 ]; do
    local key="$1"; shift
    case "$key" in
      --older-than-days) days="${1:-30}"; [ $# -gt 0 ] && shift ;;
      *) printf 'cc-backlog compact: unknown arg %s\n' "$key" >&2; return 2 ;;
    esac
  done
  ensure_file
  local cutoff; cutoff=$(cutoff_iso "$days")
  [ -n "$cutoff" ] || { echo "cc-backlog compact: could not compute cutoff" >&2; return 2; }
  # Drop set: terminal (done) items whose last event is older than the cutoff.
  local drop; drop=$(fold | jq -r --arg c "$cutoff" \
    '.[] | select(.status == "done" and .lastTs != "" and .lastTs < $c) | .id')
  if [ -z "$drop" ]; then
    printf 'cc-backlog compact: nothing aged out (cutoff %s)\n' "$cutoff" >&2
    return 0
  fi
  local tmp n=0 kept=0 dropped=0 malformed=0 line lid
  tmp=$(mktemp)
  while IFS= read -r line || [ -n "$line" ]; do
    n=$((n + 1)); [ -z "$line" ] && continue
    lid=$(printf '%s' "$line" | jq -r 'if (has("id") and has("event")) then .id else "__BAD__" end' 2>/dev/null || echo "__BAD__")
    if [ "$lid" = "__BAD__" ]; then
      printf '%s\n' "$line" >> "$tmp"; malformed=$((malformed + 1))   # preserve, never drop
      printf 'cc-backlog compact: preserved malformed line %d\n' "$n" >&2
      continue
    fi
    if printf '%s\n' "$drop" | grep -qxF -- "$lid"; then
      dropped=$((dropped + 1)); continue
    fi
    printf '%s\n' "$line" >> "$tmp"; kept=$((kept + 1))
  done < "$BACKLOG"
  mv "$tmp" "$BACKLOG"
  printf 'cc-backlog compact: kept %d, dropped %d aged-terminal, preserved %d malformed\n' \
    "$kept" "$dropped" "$malformed" >&2
}

# _resolve_sessions_bin → path to cc-sessions (the live-registry liveness oracle), or "" (rc 0).
# Env override wins (tests), then sibling, then ~/.claude/bin, then PATH (launchd bare-PATH safe).
_resolve_sessions_bin() {
  if [ -n "${CC_BACKLOG_SESSIONS_BIN:-}" ]; then printf '%s' "$CC_BACKLOG_SESSIONS_BIN"; return 0; fi
  local c
  for c in "$(dirname "$0")/cc-sessions" "$HOME/.claude/bin/cc-sessions" "$(command -v cc-sessions 2>/dev/null || true)"; do
    [ -n "$c" ] && [ -x "$c" ] && { printf '%s' "$c"; return 0; }
  done
  printf ''
}

# claimer_live <by> — is the claim's owner still live? A `<host>-<pid>` claimer (cc-dispatch and
# most manual claims) is authoritatively checked with `kill -0` (same user across accounts); a
# session-id / UUID / name claimer against the live cc-sessions registry (best-effort — an
# unresolved oracle reads NOT-live, since by the time reap consults this the stale timeout has
# already elapsed and leaving the work stranded is the worse failure). Our own reap marker is
# never "live". rc 0 = live (⇒ do NOT reopen), rc 1 = not live / unknown.
claimer_live() {
  local by="$1"
  [ -n "$by" ] && [ "$by" != cc-backlog-reap ] || return 1
  local host; host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo localhost)"
  local pid="${by##*-}"
  if [ "$by" = "$host-$pid" ] && [[ "$pid" =~ ^[0-9]+$ ]]; then
    if kill -0 "$pid" 2>/dev/null; then return 0; fi
    return 1
  fi
  local sb; sb="$(_resolve_sessions_bin)"
  [ -n "$sb" ] || return 1
  "$sb" --json 2>/dev/null \
    | jq -e --arg b "$by" 'any(.[]?; (.paneUUID==$b) or (.name==$b) or (.sessionId==$b))' >/dev/null 2>&1
}

# cmd_reap — the stale-claim maintenance sweep (see the REAP header block). Append-only, idempotent,
# and safe to run every cc-reaper sweep. Terminal (done) and already-blocked items are never touched.
# --dry-run classifies + prints WOULD-* and writes NOTHING.
#
# Thresholds (all env-tunable; defaults calibrated from 75 real claim→done items — p50 33min / p90
# 55min, so a live worker under p90 is never double-dispatched by the 90-min stale gate):
#   CC_BACKLOG_STALE_CLAIM_S    (5400)  claimed idle past this ⇒ dead-worker candidate → reopen
#   CC_BACKLOG_MAX_THRASH       (2)     >= this many fast claim→reopen cycles ⇒ thrash → block
#   CC_BACKLOG_MAX_ATTEMPTS     (3)     >= this many total dispatch claims on a still-stale item ⇒ block
#   CC_BACKLOG_THRASH_WINDOW_S  (90)    a claim→reopen within this gap counts as one fast-fail cycle
#   CC_BACKLOG_NOW              (now)   epoch "now" seam (deterministic age/window math in tests)
cmd_reap() {
  local dry=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry=1 ;;
      *) printf 'cc-backlog reap: unknown arg %s\n' "$1" >&2; return 2 ;;
    esac
    shift
  done
  ensure_file
  local stale="${CC_BACKLOG_STALE_CLAIM_S:-5400}"
  local maxthrash="${CC_BACKLOG_MAX_THRASH:-2}"
  local maxattempts="${CC_BACKLOG_MAX_ATTEMPTS:-3}"
  local window="${CC_BACKLOG_THRASH_WINDOW_S:-90}"
  local now="${CC_BACKLOG_NOW:-$(date +%s)}"

  # Per non-terminal id → TSV [id, status, claimBy, claimAgeS, totalClaims, fastFailCycles].
  # status = last-event fold; claimBy/claimTs from the LAST claim (not our reap-reopen); fastFail =
  # adjacent claim→reopen pairs within $window (the intervening-done/block case can't be adjacent).
  local analysis
  analysis="$(valid_records | jq -s -r --argjson now "$now" --argjson window "$window" '
    def st($e): if $e=="done" then "done" elif $e=="block" then "blocked"
      elif $e=="unblock" then "open" elif $e=="claim" then "claimed"
      elif $e=="reopen" then "open" else "open" end;
    group_by(.id)
    | map(
        (sort_by(.ts)) as $g
        | ($g[-1]) as $last
        | { id: $last.id,
            status: st($last.event),
            claimBy: ([$g[] | select(.event=="claim")] | last | .by // ""),
            claimTs: ([$g[] | select(.event=="claim")] | last | .ts // ""),
            totalClaims: ([$g[] | select(.event=="claim")] | length),
            fastFail: ([ range(0; ($g|length)-1) as $i
                | select($g[$i].event=="claim" and $g[$i+1].event=="reopen"
                         and (($g[$i+1].ts|fromdateiso8601) - ($g[$i].ts|fromdateiso8601)) <= $window) ]
              | length) }
        | .claimAgeS = (if .claimTs=="" then -1 else ($now - (.claimTs|fromdateiso8601)) end)
      )
    | .[]
    | select(.status != "done" and .status != "blocked")
    | [.id, .status, .claimBy, (.claimAgeS|floor|tostring), (.totalClaims|tostring), (.fastFail|tostring)]
    | join("\u001f")
  ')"

  # Split on US (\037), NOT tab: an open item with no claim has an EMPTY claimBy field, and bash
  # `read` COALESCES consecutive whitespace-IFS chars (tab included) — two adjacent tabs would drop
  # the empty field and shift every later column left (fast → empty → "integer expression" error).
  # A non-whitespace IFS preserves empty fields positionally.
  local reopened=0 blocked=0 scanned=0 id status by ageS claims fast
  while IFS=$'\037' read -r id status by ageS claims fast; do
    [ -n "$id" ] || continue
    scanned=$((scanned + 1))
    # Rule B (priority): persistent thrash → block (out of the wave, surfaced to the desk).
    if [ "$fast" -ge "$maxthrash" ]; then
      local bmsg="persistent thrash — ${fast} fast claim→reopen cycle(s) (spawn-fail / land-conflict rebase-exit-5); the worker cannot land. Investigate the root cause, then \`cc-backlog unblock ${id}\`."
      if [ "$dry" = 1 ]; then
        printf 'cc-backlog reap: WOULD-BLOCK %s [thrash x%s]\n' "$id" "$fast"
      elif cmd_transition block "$id" --needs "$bmsg" --by cc-backlog-reap >/dev/null; then
        blocked=$((blocked + 1)); printf 'cc-backlog reap: BLOCK %s [thrash x%s]\n' "$id" "$fast"
      fi
      continue
    fi
    # Rule A: dead-worker stale claim → reopen (bounded → block after MAX_ATTEMPTS).
    if [ "$status" = claimed ] && [ "$ageS" -gt "$stale" ]; then
      if claimer_live "$by"; then
        [ "$dry" = 1 ] && printf 'cc-backlog reap: keep %s [claimed %ss — claimer %s LIVE]\n' "$id" "$ageS" "$by"
        continue
      fi
      if [ "$claims" -ge "$maxattempts" ]; then
        local smsg="dead-worker stall after ${claims} dispatch attempt(s) (idle ${ageS}s) — not auto-completable. Investigate, then \`cc-backlog unblock ${id}\`."
        if [ "$dry" = 1 ]; then
          printf 'cc-backlog reap: WOULD-BLOCK %s [stall, %s attempts]\n' "$id" "$claims"
        elif cmd_transition block "$id" --needs "$smsg" --by cc-backlog-reap >/dev/null; then
          blocked=$((blocked + 1)); printf 'cc-backlog reap: BLOCK %s [stall, %s attempts]\n' "$id" "$claims"
        fi
      elif [ "$dry" = 1 ]; then
        printf 'cc-backlog reap: WOULD-REOPEN %s [dead-worker, claimed %ss, %s attempt(s)]\n' "$id" "$ageS" "$claims"
      elif cmd_transition reopen "$id" --by cc-backlog-reap >/dev/null; then
        reopened=$((reopened + 1)); printf 'cc-backlog reap: REOPEN %s [dead-worker, claimed %ss]\n' "$id" "$ageS"
      fi
    fi
  done <<< "$analysis"

  if [ "$dry" = 1 ]; then
    printf 'cc-backlog reap (dry-run): %s non-terminal item(s) scanned — no writes\n' "$scanned"
  else
    printf 'cc-backlog reap: %s reopened, %s blocked (%s non-terminal scanned)\n' "$reopened" "$blocked" "$scanned"
  fi
}

command -v jq >/dev/null 2>&1 || { echo "cc-backlog: jq is required" >&2; exit 1; }

case "${1:-}" in
  add)     shift; cmd_add "$@" ;;
  list)    shift; cmd_list "$@" ;;
  claim)   shift; cmd_transition claim "$@" ;;
  done)    shift; cmd_transition "done" "$@" ;;
  reopen)  shift; cmd_transition reopen "$@" ;;
  block)   shift; cmd_transition block "$@" ;;
  unblock) shift; cmd_transition unblock "$@" ;;
  reap)    shift; cmd_reap "$@" ;;
  compact) shift; cmd_compact "$@" ;;
  ""|-h|--help|help) usage ;;
  *) printf 'cc-backlog: unknown verb %s\n\n' "$1" >&2; usage >&2; exit 2 ;;
esac
