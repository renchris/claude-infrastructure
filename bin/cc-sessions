#!/bin/bash
# cc-sessions — list live Claude Code sessions in the cross-session comms registry.
#
# Part of the two-way session-comms feature (with cc-notify / cc-await-ping).
# Reads $HOME/.claude/cc-registry/<paneUUID>.json entries written by the
# session-register.sh SessionStart hook, and lazily SWEEPS stale ones on read:
#   - owning process dead      (`kill -0 <pid>` fails — authoritative, same user
#                               across accounts), OR
#   - iTerm2 pane gone         (UUID absent from `it2 session list --json`, but
#                               ONLY when that list is readable — a transient it2
#                               error never triggers a sweep; fail-safe).
#
# Usage:
#   cc-sessions            pretty table: NAME  UUID  ACCOUNT  AGE  CWD
#   cc-sessions --json     JSON array of live entries (cc-notify uses this to
#                          resolve a friendly name → pane UUID)
#   cc-sessions --names    one friendly name per line
#   cc-sessions -h         this help
#
# Env overrides (for tests): CC_REGISTRY_DIR, IT2_BIN.
# Read-only except for the lazy stale-sweep. Always exit 0 (empty registry too).
set -uo pipefail

REG_DIR="${CC_REGISTRY_DIR:-$HOME/.claude/cc-registry}"
IT2="${IT2_BIN:-$HOME/.claude/bin/it2}"

usage() {
  sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
}

MODE=table; ALL=0
# --all = the FORENSIC view (live + retained-dead rows). The default stays the ADDRESSING view
# (live only), so cc-notify can never resolve a friendly name onto a dead pane.
for a in "$@"; do
  case "$a" in
    --json)     MODE=json ;;
    --names)    MODE=names ;;
    --all)      ALL=1 ;;
    -h|--help)  usage; exit 0 ;;
    '')         ;;
    *)          echo "cc-sessions: unknown option '$a'" >&2; usage >&2; exit 2 ;;
  esac
done

command -v jq >/dev/null 2>&1 || { echo "cc-sessions: jq required" >&2; exit 1; }

if [ ! -d "$REG_DIR" ]; then
  [ "$MODE" = json ] && echo '[]'
  [ "$MODE" = table ] && echo "(no sessions registered)"
  exit 0
fi

# Authoritative live pane-UUID set (best-effort). have_panes=0 means "unknown" —
# we then never sweep on the pane signal, only on dead-pid.
live_panes=""
have_panes=0
if pl=$("$IT2" session list --json 2>/dev/null) && [ -n "$pl" ]; then
  lp=$(printf '%s' "$pl" | jq -r 'if type=="array" then .[].id // empty else empty end' 2>/dev/null)
  if [ -n "$lp" ]; then live_panes="$lp"; have_panes=1; fi
fi

# PRESENCE MUST NOT ENCODE LIVENESS (P8, 2026-07-14). This loop used to `rm -f` a row the moment
# its pid died or its pane vanished — i.e. it DELETED EXACTLY THE ROWS THAT PROVE HOW A SESSION
# DIED. A pane that comes up and dies at spawn (D8 trigger 1) would register, die, and have its
# evidence erased on the next read: the spawn-death detector P8 exists to provide would report
# nothing, and the blind spot would persist while LOOKING fixed. Same class as cc-context deleting
# a live stall's telemetry (93720eb) and cc-notify's verifier that could only abstain (3b12107):
# a reaper keyed on DEADNESS erases the forensics.
#
# Cleanup and forensics want opposite things from one record, so they are now separated:
#   LIVENESS  -> the `pid` field (kill -0). Readers decide; presence says nothing.
#   VIEW      -> this lister still emits LIVE rows only, so cc-notify never resolves a name to a
#                dead pane (addressing semantics UNCHANGED — that path is load-bearing for W4).
#   RETENTION -> deletion is now an AGE decision, never a liveness one: corrupt rows go
#                immediately; dead rows are kept for CC_REG_RETAIN_H (default 24h) so a
#                spawn-death is still investigable, then reaped for hygiene.
# `cc-sessions --all` exposes the dead rows (cc-board joins them against telemetry).
RETAIN_S=$(( ${CC_REG_RETAIN_H:-24} * 3600 ))
now=$(date +%s)
live=()
dead=()
for f in "$REG_DIR"/*.json; do
  [ -e "$f" ] || continue
  uuid=$(jq -r '.paneUUID // empty' "$f" 2>/dev/null)
  if [ -z "$uuid" ]; then rm -f "$f" 2>/dev/null; continue; fi   # corrupt → sweep (not a liveness call)
  pid=$(jq -r '.pid // empty' "$f" 2>/dev/null)

  stale=0
  if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then stale=1; fi
  if [ "$have_panes" = 1 ] && ! printf '%s\n' "$live_panes" | grep -qxF "$uuid"; then stale=1; fi

  if [ "$stale" = 1 ]; then
    # RETENTION, not liveness: keep the evidence for the investigation window, then reap.
    started=$(jq -r '.startedAt // 0' "$f" 2>/dev/null); started=$(( ${started:-0} / 1000 ))
    if [ "$started" -gt 0 ] && [ $(( now - started )) -gt "$RETAIN_S" ]; then
      rm -f "$f" 2>/dev/null
    else
      dead+=("$f")
    fi
    continue
  fi
  live+=("$f")
done
# --all → live + retained-dead (the forensic view). Default → live only (addressing view).
if [ "${ALL:-0}" = 1 ]; then live+=("${dead[@]+"${dead[@]}"}"); fi

if [ "${#live[@]}" -eq 0 ]; then
  case "$MODE" in
    json)  echo '[]' ;;
    table) echo "(no live sessions registered)" ;;
    names) : ;;
  esac
  exit 0
fi

case "$MODE" in
  json)  jq -s '.' "${live[@]}" ;;
  names) jq -r '.name' "${live[@]}" ;;
  table)
    {
      printf 'NAME\tUUID\tACCOUNT\tAGE\tCWD\n'
      for f in "${live[@]}"; do
        jq -r --argjson now "$now" '
          (($now - ((.startedAt // 0) / 1000)) | floor) as $age |
          ( if   $age < 60    then "\($age)s"
            elif $age < 3600  then "\(($age / 60)    | floor)m"
            elif $age < 86400 then "\(($age / 3600)  | floor)h"
            else                   "\(($age / 86400) | floor)d" end ) as $ago |
          [ .name, (.paneUUID[0:8]), .account, $ago, .cwd ] | @tsv
        ' "$f"
      done
    } | { if command -v column >/dev/null 2>&1; then column -t -s "$(printf '\t')"; else cat; fi; }
    ;;
esac
exit 0
