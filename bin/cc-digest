#!/bin/bash
# cc-digest — the batched morning-review surface (P15 §3.4, T-P15-6). Reads the escalation
# substrate and emits ONE legible markdown digest to stdout AND to
# ${CC_DIGESTS_DIR:-~/.claude/autonomy/digests}/<date>.md. This is the DESIGNED operator touch:
# batched, never an interrupt. Sections:
#   Landed          land.log tail — what shipped unattended
#   Backlog         cc-backlog open items
#   Decisions       open packets (awaiting early-veto) + class-B defaults fired in the last 24h
#   Pages           total page stamps + how many the sweep has surfaced (.seen)
#   Inert-check     the D9 monitor: a hook that abstained on ALL of its recent evals (>=N within the
#                   last H hours) AND fired NONE of them is INERT (its check stopped observing what
#                   it guards) → an ALARM line. Actor/flood records are excluded BEFORE windowing and
#                   a fire inside the recency horizon exonerates, so a rarely-firing healthy guard is
#                   not falsely flagged after a record-flood night (fix e7d326caa6a7, inv7).
#
# Push wiring (T-P15-6 delivery): `cc-digest push [--no-phone] [--no-desk] [--role <r>]` also DELIVERS the
#   digest instead of only leaving it on disk — a QUIET, batched, never-interrupt phone push (push-send.sh,
#   priority -1, a counts SUMMARY; the full digest stays on disk within Pushover's 1024-char cap) + a light
#   desk-ROLE wake (cc-announce → points at the on-disk digest; it never injects KBs of markdown into a live
#   composer — that would BE the interrupt this surface avoids). Bare `cc-digest` (no subcommand) is
#   unchanged: emit to stdout + disk only.
#
# Env (tests): CC_LAND_LOG · CC_BACKLOG_FILE/CC_BACKLOG_BIN · CC_DECISIONS_DIR · CC_PAGES_DIR
#   · CC_SWEEP_SEEN_DIR · CC_IDL · CC_DIGESTS_DIR · CC_DIGEST_DATE · CC_DIGEST_INERT_HORIZON_H
#   (default 168 = 7d, the last-fired recency window) · CC_DIGEST_INERT_MIN (default 10 evals). The
#   D9 read greps the append-only IDL down to just its hook-eval records FIRST (never a full slurp),
#   then windows PER-HOOK (no global tail — see the Inert-check block).
#   Push: CC_PUSH_SEND_BIN · CC_ANNOUNCE_BIN · CC_DIGEST_ROLE (default desk).
# BSD+GNU portable, no eval, fail-loud. Exit 0 (emit) · 2 (usage) · 5 (push: a requested delivery leg FAILED).
set -uo pipefail

LAND_LOG="${CC_LAND_LOG:-$HOME/.claude/land.log}"
DECISIONS_DIR="${CC_DECISIONS_DIR:-$HOME/.claude/autonomy/decisions}"
PAGES_DIR="${CC_PAGES_DIR:-$HOME/.claude/autonomy/pages}"
SEEN_DIR="${CC_SWEEP_SEEN_DIR:-$HOME/.claude/autonomy/sweep-seen}"
IDL="${CC_IDL:-$HOME/.claude/autonomy/idl.jsonl}"
DIGESTS_DIR="${CC_DIGESTS_DIR:-$HOME/.claude/autonomy/digests}"
LAND_TAIL="${CC_DIGEST_LAND_TAIL:-10}"

usage() { sed -n '2,/^set -uo/p' "$0" | sed 's/^# \{0,1\}//; /^set -uo/d'; }
# Arg parse: bare (no subcommand) = emit-only (unchanged). `push`/`--push` = emit THEN deliver.
DO_PUSH=0; PUSH_PHONE=1; PUSH_DESK=1; PUSH_ROLE="${CC_DIGEST_ROLE:-desk}"
case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  push|--push)
    DO_PUSH=1; shift
    while [ $# -gt 0 ]; do
      case "$1" in
        --no-phone) PUSH_PHONE=0; shift ;;
        --no-desk)  PUSH_DESK=0; shift ;;
        --role)     PUSH_ROLE="${2:?--role needs a value}"; shift 2 ;;
        *)          echo "cc-digest: unknown push arg '$1' (use --no-phone|--no-desk|--role <r>)" >&2; exit 2 ;;
      esac
    done ;;
  "") ;;
  *)  echo "cc-digest: unknown command '$1' (use 'push' or --help)" >&2; exit 2 ;;
esac

command -v jq >/dev/null 2>&1 || { echo "cc-digest: jq required" >&2; exit 1; }

DATE="${CC_DIGEST_DATE:-$(date -u +%Y-%m-%d 2>/dev/null || echo unknown)}"
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo '')"
CUTOFF_24H="$(date -u -v-24H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
            || date -u -d '-24 hours' +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo '')"
# D9 inert-check recency horizon: a hook that fired at or after INERT_CUTOFF is NOT inert. Empty
# cutoff (date failure) degrades to all-time — the safe, lenient direction (fewer alarms).
INERT_HORIZON_H="${CC_DIGEST_INERT_HORIZON_H:-168}"
INERT_MIN="${CC_DIGEST_INERT_MIN:-10}"
INERT_CUTOFF="$(date -u -v-"${INERT_HORIZON_H}"H +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
             || date -u -d "-${INERT_HORIZON_H} hours" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo '')"

# D9 BLIND reason-tokens (blind-check law §3i) — the "could-not-observe-my-guard" abstain reasons
# (matched on the token BEFORE the first ':', so dynamic suffixes like `stale-telemetry:120s` hit).
# A hook ALARMS only when EVERY in-horizon abstention is BLIND; any DORMANT (condition-not-met)
# reason — or an unlisted/absent one — proves the hook still sees reality (fail toward NOT alarming).
# Kept BYTE-FOR-BYTE in lockstep with scripts/idl-abstain-alarm.sh (_default_blind) and cc-discover's
# C3 critic — edit all three together.
_inert_blind=(no-jq no-session-id no-stdin no-telemetry stale-telemetry \
              no-transcript-path transcript-missing not-a-repo no-cwd no-assistant-text)
INERT_BLIND_JSON="$(printf '%s\n' "${_inert_blind[@]}" | jq -Rsc 'split("\n")|map(select(length>0))' 2>/dev/null)"

# cc-backlog: env override → beside → ~/.claude/bin → PATH.
resolve_bin() { local o="$1" n="$2" c
  if [ -n "$o" ]; then [ -x "$o" ] && printf '%s' "$o"; return 0; fi
  for c in "$(dirname "$0")/$n" "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/$n" "$HOME/.claude/bin/$n"; do
    [ -x "$c" ] && { printf '%s' "$c"; return 0; }
  done
  command -v "$n" >/dev/null 2>&1 && printf '%s' "$(command -v "$n")"; return 0
}
BACKLOG="$(resolve_bin "${CC_BACKLOG_BIN:-}" cc-backlog)"

# push-send.sh lives in scripts/ (not bin/), so it needs a scripts-aware resolver; cc-announce is in bin/.
resolve_script() { local o="$1" n="$2" c
  if [ -n "$o" ]; then [ -x "$o" ] && printf '%s' "$o"; return 0; fi
  for c in "$(dirname "$0")/../scripts/$n" "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/$n" "$HOME/.claude/scripts/$n"; do
    [ -x "$c" ] && { printf '%s' "$c"; return 0; }
  done
  command -v "$n" >/dev/null 2>&1 && printf '%s' "$(command -v "$n")"; return 0
}
PUSH_SEND="$(resolve_script "${CC_PUSH_SEND_BIN:-}" push-send.sh)"
ANNOUNCE="$(resolve_bin "${CC_ANNOUNCE_BIN:-}" cc-announce)"

emit() {
  printf '# Desk digest — %s\n\n' "$DATE"

  printf '## Landed (recent)\n\n'
  if [ -f "$LAND_LOG" ] && [ -s "$LAND_LOG" ]; then
    tail -n "$LAND_TAIL" "$LAND_LOG" | sed 's/^/    /'      # 4-space indent = markdown code block
  else
    printf '_no landings recorded_\n'
  fi
  printf '\n'

  printf '## Backlog (open)\n\n'
  local bl=""
  [ -n "$BACKLOG" ] && bl="$("$BACKLOG" list --open 2>/dev/null || true)"
  if [ -n "$bl" ]; then printf '%s\n' "$bl" | sed 's/^/    /'; else printf '_no open backlog items_\n'; fi
  printf '\n'

  printf '## Decisions\n\n'
  printf '### Open — awaiting early-veto\n\n'
  local anyopen=0 f st cls id what dl def res
  if [ -d "$DECISIONS_DIR" ]; then
    for f in "$DECISIONS_DIR"/*.json; do
      [ -e "$f" ] || continue
      st="$(jq -r '.status // ""' "$f" 2>/dev/null || echo "")"
      [ "$st" = "open" ] || continue
      cls="$(jq -r '.class // "?"' "$f" 2>/dev/null)"; id="$(jq -r '.id // "?"' "$f" 2>/dev/null)"
      what="$(jq -r '.what_plain // ""' "$f" 2>/dev/null)"; dl="$(jq -r '.veto_deadline // ""' "$f" 2>/dev/null)"
      printf -- '- [%s] %s — %s%s\n' "$cls" "$id" "$what" "${dl:+ (veto by $dl)}"
      anyopen=1
    done
  fi
  [ "$anyopen" -eq 0 ] && printf '_none open_\n'
  printf '\n### Class-B defaults fired (last 24h)\n\n'
  local anyfired=0
  if [ -d "$DECISIONS_DIR" ]; then
    for f in "$DECISIONS_DIR"/*.json; do
      [ -e "$f" ] || continue
      st="$(jq -r '.status // ""' "$f" 2>/dev/null || echo "")"
      [ "$st" = "expired-actioned" ] || continue
      res="$(jq -r '.resolved // ""' "$f" 2>/dev/null)"
      { [ -n "$CUTOFF_24H" ] && [ -n "$res" ] && [ "$res" \< "$CUTOFF_24H" ]; } && continue
      id="$(jq -r '.id // "?"' "$f" 2>/dev/null)"; what="$(jq -r '.what_plain // ""' "$f" 2>/dev/null)"
      def="$(jq -r '.default_if_no_veto // ""' "$f" 2>/dev/null)"
      printf -- '- %s — %s → default fired: %s\n' "$id" "$what" "$def"
      anyfired=1
    done
  fi
  [ "$anyfired" -eq 0 ] && printf '_none in the last 24h_\n'
  printf '\n'

  printf '## Pages\n\n'
  local total=0 surfaced=0 key
  if [ -d "$PAGES_DIR" ]; then
    for f in "$PAGES_DIR"/*.page; do
      [ -e "$f" ] || continue
      total=$((total + 1))
      key="$(printf '%s' "$f" | shasum -a 256 | cut -c1-32)"
      [ -f "$SEEN_DIR/$key" ] && surfaced=$((surfaced + 1))
    done
  fi
  printf -- '- %d page stamp(s) total; %d surfaced by the sweep, %d pending\n\n' \
    "$total" "$surfaced" "$((total - surfaced))"

  printf '## Inert-check alarms (D9)\n\n'
  # A hook is INERT when its tells stopped matching reality: it abstained on ALL its recent evals,
  # fired NONE, AND every abstention was BLIND (could not observe its guard). Three guards against the
  # false-positive (a healthy quiet advisory nightly-alarmed, 2026-07-19, e7d326caa6a7 / 117bf1aea7b7):
  #   (1) actor-record exclusion — grep the append-only IDL to ONLY hook-eval records (they carry
  #       BOTH "hook" and "disposition"; a tiny fraction of the file) BEFORE windowing, so flood
  #       records never consume the read budget. jq never slurps the whole IDL.
  #   (2) PER-HOOK windowing + last-fired recency horizon — group_by(.hook) counts EACH hook's OWN
  #       in-horizon (>=INERT_CUTOFF) evals; there is NO global line tail, so a high-frequency hook's
  #       churn can never crowd a rare hook's fire out of view. A fire in-horizon exonerates it
  #       (completion-assert fired 03:08Z the night it was falsely flagged). jq `>=` on ISO-Z
  #       (fixed-width, UTC) timestamps is a lexicographic string compare == a correct time compare.
  #   (3) abstain-REASON discrimination (blind-check law §3i) — a DORMANT abstention (guard reached,
  #       fire condition legitimately not met: no-tell / not-armed / below-threshold / ledger-clean)
  #       proves the hook still sees reality; a hook alarms only when EVERY abstention is BLIND
  #       (the _inert_blind set above; unlisted/absent reason ⇒ DORMANT, fail toward NOT alarming).
  #       Reasons match on the token BEFORE the first ':'. Without this every quiet advisory paged.
  # Kept in lockstep with cc-discover's critic_wiring_inert + scripts/idl-abstain-alarm.sh (same
  # predicate + _default_blind).
  local alarms=""
  if [ -f "$IDL" ]; then
    alarms="$(grep -F '"disposition"' "$IDL" 2>/dev/null | grep -F '"hook"' \
      | jq -rs --arg cutoff "$INERT_CUTOFF" --argjson n "$INERT_MIN" --argjson blind "$INERT_BLIND_JSON" '
      map(select(type=="object" and .hook and .disposition and .ts))
      | group_by(.hook)
      | map({hook: .[0].hook,
             total:      (map(select(.ts >= $cutoff)) | length),
             abstained:  (map(select(.ts >= $cutoff and .disposition=="abstained")) | length),
             blind:      (map(select(.ts >= $cutoff and .disposition=="abstained"
                            and (((.reason // "") | split(":")[0]) as $rt | ($blind | index($rt)) != null))) | length),
             last_fired: (map(select(.disposition!="abstained")) | if length>0 then max_by(.ts).ts else null end)})
      | .[] | select(.total >= $n and .abstained == .total and .blind == .abstained)
      | "ALARM: hook \(.hook) blind \(.blind)/\(.total) recent evals (100% blind — could not observe its guard), never fired — INERT check: its tells stopped matching reality (last fired: \(.last_fired // "never"))"
    ' 2>/dev/null || true)"
  fi
  if [ -n "$alarms" ]; then printf '%s\n' "$alarms"; else printf '_no inert checks — every guard fired in-horizon, is DORMANT (healthy condition-not-met), or has too few recent evals_\n'; fi
  printf '\n_generated %s_\n' "$NOW"
}

# ── push wiring (T-P15-6 delivery) ─────────────────────────────────────────────────────────────────────
# Counts for the phone SUMMARY. The 4 list counts read the SAME sources emit() uses; the INERT count is
# derived from the ALREADY-GENERATED digest ($1) — emit()'s authoritative ALARM lines — NEVER a second copy
# of the D9 predicate (which e7d326caa6a7 changed), so the summary can never drift from the digest.
# Order: landed backlog decisions_open pages_pending inert_alarms.
compute_counts() { # <digest_file>
  local dfile="$1" landed=0 backlog=0 dopen=0 ptot=0 psurf=0 inert=0 f st key
  if [ -f "$LAND_LOG" ] && [ -s "$LAND_LOG" ]; then
    landed="$(tail -n "$LAND_TAIL" "$LAND_LOG" 2>/dev/null | grep -c .)"; landed="${landed:-0}"
  fi
  if [ -n "$BACKLOG" ]; then
    backlog="$("$BACKLOG" list --open 2>/dev/null | grep -c .)"; backlog="${backlog:-0}"
  fi
  if [ -d "$DECISIONS_DIR" ]; then
    for f in "$DECISIONS_DIR"/*.json; do [ -e "$f" ] || continue
      st="$(jq -r '.status // ""' "$f" 2>/dev/null || echo "")"; [ "$st" = open ] && dopen=$((dopen + 1)); done
  fi
  if [ -d "$PAGES_DIR" ]; then
    for f in "$PAGES_DIR"/*.page; do [ -e "$f" ] || continue
      ptot=$((ptot + 1)); key="$(printf '%s' "$f" | shasum -a 256 | cut -c1-32)"
      [ -f "$SEEN_DIR/$key" ] && psurf=$((psurf + 1)); done
  fi
  inert="$(grep -c '^ALARM:' "$dfile" 2>/dev/null)"; inert="${inert:-0}"
  printf '%s %s %s %s %s' "$landed" "$backlog" "$dopen" "$((ptot - psurf))" "$inert"
}

# Deliver the digest: a quiet phone summary + a light desk-role wake. NEVER silent — a leg that SHOULD work
# (creds/role present) but fails is LOUD (return 5); INERT phone (no creds yet) is a NOTE, not a failure.
deliver_push() { # <digest_file>
  local dfile="$1" counts landed backlog dopen ppend inert summary saved rc worst=0
  counts="$(compute_counts "$dfile")"
  read -r landed backlog dopen ppend inert <<< "$counts"
  saved="$DIGESTS_DIR/$DATE.md"
  summary="Desk digest $DATE — ${landed} landed · ${backlog} backlog · ${dopen} decision(s) awaiting veto · ${ppend} page(s) pending · ${inert} inert alarm(s). Full: $saved"

  if [ "$PUSH_PHONE" = 1 ]; then
    if [ -n "$PUSH_SEND" ] && [ -x "$PUSH_SEND" ]; then
      "$PUSH_SEND" send --title "Desk digest — $DATE" --message "$summary" --priority -1 --from cc-digest >/dev/null 2>&1; rc=$?
      case "$rc" in
        0) echo "cc-digest: ✅ phone push delivered (quiet summary; full digest on disk)" >&2 ;;
        3) echo "cc-digest: ⚠ phone push INERT — PUSHOVER creds unset (P0-7 operator step); digest is on disk" >&2 ;;
        *) echo "cc-digest: ⛔ phone push FAILED (push-send rc=$rc)" >&2; worst=5 ;;
      esac
    else
      echo "cc-digest: ⚠ phone push skipped — push-send.sh not found" >&2
    fi
  fi

  if [ "$PUSH_DESK" = 1 ]; then
    if [ -n "$ANNOUNCE" ] && [ -x "$ANNOUNCE" ]; then
      "$ANNOUNCE" --from cc-digest --event digest "$PUSH_ROLE" "Morning digest ready — $summary" >/dev/null 2>&1; rc=$?
      if [ "$rc" = 0 ]; then echo "cc-digest: ✅ desk-role wake delivered ($PUSH_ROLE)" >&2
      else echo "cc-digest: ⛔ desk-role wake NOT verified ($PUSH_ROLE, cc-announce rc=$rc)" >&2; worst=5; fi
    else
      echo "cc-digest: ⚠ desk-role wake skipped — cc-announce not found" >&2
    fi
  fi
  return "$worst"
}

tmp="$(mktemp 2>/dev/null || echo "/tmp/cc-digest.$$")"
emit > "$tmp" 2>/dev/null || emit > "$tmp"
cat "$tmp"
if mkdir -p "$DIGESTS_DIR" 2>/dev/null; then cp "$tmp" "$DIGESTS_DIR/$DATE.md" 2>/dev/null || true; fi
push_rc=0
[ "$DO_PUSH" = 1 ] && { deliver_push "$tmp"; push_rc=$?; }
rm -f "$tmp" 2>/dev/null || true
exit "$push_rc"
