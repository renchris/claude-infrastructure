#!/bin/bash
# cc-board — operator all-sessions glance view (SESSION_AUTONOMY §3.1 P7, axis a).
#
# ONE screen replaces the hand-run /context + /accounts relays that drove W0-W3 (audit
# §1): every live session's context fill × its account's 5h/weekly/Fable headroom × a
# stall state, plus the best next account to place work. Read-only; joins the atomic
# telemetry (statusline export) with the 90s-cached claude-accounts feed. `watch -n5 cc-board`.
#
# States (display-only — ACTION belongs to the supervisor, ruling #1 page-only):
#   OK · DUE (ctx ≥ handoff threshold, default 73%) · LIMIT (account 5h≥85% or weekly≥90%)
#   · DEAD (the owning claude pid is GONE — effect-verified, P9) · STALL? (pid ALIVE but telemetry
#   age >15m: either genuinely hung OR healthy inside one long operation — AGE CANNOT TELL THEM
#   APART, since both render zero times. So STALL? is a CANDIDATE: page / lead-check, NEVER reap.
#   The fixtures-b2 lesson: a teammate ran >1h past red-100% and completed.) · STALE (age >15m,
#   pid unknown — a legacy row from before the pid export; treat as STALL? and verify by hand).
#   Proven 2026-07-14: a respawn sat nominally-RUNNING 1h25m with 78m-stale telemetry.
set -u
TDIR="${CC_TELEMETRY_DIR:-/tmp/cc-telemetry}"
HANDOFF_T="${CC_BOARD_HANDOFF_PCT:-73}"
STALE_S="${CC_BOARD_STALE_S:-900}"
[ -d "$TDIR" ] || { echo "no telemetry ($TDIR absent — statusline exports each turn boundary)" >&2; exit 3; }

# config_dir → account name (statusline suffix convention; accounts rows carry no config_dir)
map_acct() { case "$1" in
  */.claude-next)       echo next  ;;  */.claude-secondary)  echo next2 ;;
  */.claude-tertiary)   echo next3 ;;  */.claude-quaternary) echo next4 ;;  *) echo "" ;;
esac ; }

# ONE cached accounts read (never --fresh: 90s single-flight); joined per row below.
ACCTS_JSON=""
command -v claude-accounts >/dev/null 2>&1 && ACCTS_JSON=$(claude-accounts --json 2>/dev/null)
qrow() {  # $1=acct → "5h<TAB>wk<TAB>fable"  (or "?\t?\t?")
  local r=""
  [ -n "$ACCTS_JSON" ] && [ -n "$1" ] && r=$(printf '%s' "$ACCTS_JSON" | jq -r --arg a "$1" \
    '(.rows//[])[]|select(.acct==$a)|[.session_pct,.weekly_pct,.fable_pct]|@tsv' 2>/dev/null | head -1)
  [ -n "$r" ] && printf '%s' "$r" || printf '?\t?\t?'
}

# ── value ledger (T-P14-7 / T-P8-5): a per-session VALUE column + a fleet/per-account footer, read
# from cc-value's TTL cache so the render stays instant (warm) and pays the ~1s scan only ~1/min.
# The ledger is AUXILIARY — every read is guarded (+ a `timeout` cap when available) so cc-board
# renders exactly as before if cc-value is missing/slow: VAL shows "-" and the footer is dropped.
# resolve cc-value next to the REAL cc-board, following a one-level deploy symlink
# (~/.claude/bin/cc-board → repo/bin/cc-board) so the ledger is found whether cc-board runs from
# the repo or via its deployed symlink — no separate ~/.claude/bin/cc-value symlink required.
_cbsrc="$0"
if [ -L "$_cbsrc" ]; then
  _tgt="$(readlink "$_cbsrc")"
  case "$_tgt" in /*) _cbsrc="$_tgt" ;; *) _cbsrc="$(dirname "$_cbsrc")/$_tgt" ;; esac
fi
CCVAL_BIN="$(cd "$(dirname "$_cbsrc")" 2>/dev/null && pwd)/cc-value"; CCVAL_JSON=""; VALFILE=""
if [ -x "$CCVAL_BIN" ]; then
  if command -v timeout >/dev/null 2>&1; then
    CCVAL_JSON="$(CC_ACCTS_JSON="$ACCTS_JSON" timeout 12 "$CCVAL_BIN" --cached --json 2>/dev/null || true)"
  else
    CCVAL_JSON="$(CC_ACCTS_JSON="$ACCTS_JSON" "$CCVAL_BIN" --cached --json 2>/dev/null || true)"
  fi
  printf '%s' "$CCVAL_JSON" | jq -e '.sessions' >/dev/null 2>&1 || CCVAL_JSON=""
fi
if [ -n "$CCVAL_JSON" ]; then
  VALFILE="$(mktemp "${TMPDIR:-/tmp}/cc-board-val.XXXXXX" 2>/dev/null)" \
    && printf '%s' "$CCVAL_JSON" | jq -r '.sessions[]|"\(.sid) \(.commits//0)"' > "$VALFILE" 2>/dev/null
fi
# val_cell <full-sid> → "+Nc" when the session has attributed landed commits, else "-" (bash-3.2 safe:
# temp-file + awk, no associative arrays; ASCII "-" keeps the following CWD column byte-aligned).
val_cell() {
  local n=0
  [ -n "$VALFILE" ] && [ -f "$VALFILE" ] && n="$(awk -v s="$1" '$1==s{print $2; exit}' "$VALFILE" 2>/dev/null)"
  case "$n" in ''|*[!0-9]*) n=0 ;; esac
  if [ "$n" -gt 0 ] 2>/dev/null; then printf '+%sc' "$n"; else printf '%s' '-'; fi
}

now=$(date +%s)
printf "%-9s %-5s %-5s %-6s %-4s %-4s %-6s %-7s %-4s %s\n" SESSION AGE CTX ACCT 5h WK FABLE STATE VAL CWD
# shellcheck disable=SC2045  # `ls -t` is intentional: newest-telemetry-first ordering (a glob cannot sort by mtime); filenames are session-ids, no whitespace
for f in $(ls -t "$TDIR"/*.json 2>/dev/null); do
  # \037 (unit separator), NOT @tsv: tab is IFS-WHITESPACE, so `IFS=$'\t' read` collapses runs of
  # tabs and a single empty field (an empty config_dir) shifts every later field left — which would
  # slide a PATH into $pid, fail `kill -0`, and render a LIVE session as DEAD. Non-whitespace IFS
  # delimits exactly once per occurrence, so empty fields survive.
  IFS=$'\037' read -r sid ts used cfg cwd pid < <(jq -r \
    '[(.session_id//"?"),(.ts//0),((.used_pct//0)|floor),(.config_dir//""),(.cwd//"?"),(.pid//"")]|map(tostring)|join("\u001f")' "$f" 2>/dev/null) || continue
  case "$pid" in ''|*[!0-9]*) pid="" ;; esac   # only a real numeric pid ever reaches kill -0
  [ -n "$sid" ] || continue
  age=$((now - ts))
  if   [ "$age" -lt 120 ];  then astr="${age}s"
  elif [ "$age" -lt 7200 ]; then astr="$((age/60))m"
  else                           astr="$((age/3600))h" ; fi
  acct=$(map_acct "$cfg")
  IFS=$'\t' read -r a5 awk_ afb < <(qrow "$acct")
  state=OK
  [ "$used" -ge "$HANDOFF_T" ] 2>/dev/null && state=DUE
  { [ "$awk_" != "?" ] && [ "$awk_" -ge 90 ] 2>/dev/null; } && state=LIMIT
  { [ "$a5"  != "?" ] && [ "$a5"  -ge 85 ] 2>/dev/null; } && state=LIMIT
  # liveness LAST — it outranks every other state (a DEAD row's ctx/quota is meaningless).
  # Effect-verified (invariant 1): trust `kill -0`, never telemetry freshness.
  if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then
    state=DEAD
  elif [ "$age" -gt "$STALE_S" ]; then
    if [ -n "$pid" ]; then state="STALL?"; else state=STALE; fi
  fi
  printf "%-9s %-5s %-5s %-6s %-4s %-4s %-6s %-7s %-4s %s\n" \
    "${sid:0:8}" "$astr" "${used}%" "${acct:-?}" "${a5}%" "${awk_}%" "${afb}%" "$state" "$(val_cell "$sid")" "$cwd"
done
# --- P8 JOIN: registry x telemetry -> make the SILENT ABSENCE loud -----------------------------
# cc-board's spine is the telemetry FILES, so a pane that never rendered has no row at all: ABSENT,
# not STALE — and absence is silent. The registry (SessionStart hook) exists BEFORE the first render,
# so joining it on session_id surfaces exactly the sessions the telemetry spine cannot see:
#   registered + no telemetry + pid DEAD   -> DIED-UNRENDERED  (spawn death — D8 trigger 1)
#   registered + no telemetry + pid ALIVE  -> NO-RENDER?       (up, but never rendered: hung/GO-deaf)
# GRACE: a session that registered seconds ago has simply not rendered YET — flagging it would be a
# false positive on every single startup, which is how a detector earns being ignored.
REG_DIR="${CC_REGISTRY_DIR:-$HOME/.claude/cc-registry}"
GRACE_S="${CC_BOARD_GRACE_S:-120}"
if [ -d "$REG_DIR" ]; then
  for rf in "$REG_DIR"/*.json; do
    [ -e "$rf" ] || continue
    IFS=$'\037' read -r rsid rname rpid rstart rcwd < <(jq -r \
      '[(.session_id//""),(.name//"?"),(.pid//""),((.startedAt//0)/1000|floor),(.cwd//"?")]|map(tostring)|join("\u001f")' \
      "$rf" 2>/dev/null) || continue
    [ -n "$rsid" ] || continue                       # legacy row (pre-join-key) — cannot join
    [ -f "$TDIR/$rsid.json" ] && continue            # it HAS rendered -> already a row above
    case "$rpid" in ''|*[!0-9]*) rpid="" ;; esac
    ragen=$(( now - ${rstart:-0} ))
    [ "${rstart:-0}" -gt 0 ] && [ "$ragen" -lt "$GRACE_S" ] && continue   # still starting up
    if [ -n "$rpid" ] && ! kill -0 "$rpid" 2>/dev/null; then rstate="DIED-UNRENDERED"; else rstate="NO-RENDER?"; fi
    if   [ "$ragen" -lt 7200 ]; then rastr="$((ragen/60))m"; else rastr="$((ragen/3600))h"; fi
    printf "%-9s %-5s %-5s %-6s %-4s %-4s %-6s %-7s %-4s %s\n" \
      "${rsid:0:8}" "$rastr" "--" "?" "?%" "?%" "?%" "$rstate" "-" "$rcwd ($rname)"
  done
fi

if [ -n "$ACCTS_JSON" ]; then
  nxt=$(claude-accounts --rank general 2>/dev/null | head -3 | awk '{printf "%s ", $1}')
  [ -n "$nxt" ] && echo "── place next → ${nxt}──"
fi

# ── value-ledger footer (T-P14-7 / T-P8-5): the fleet {commits + tasks} ÷ spend rollup + the
# net-negative churn callout — the single "is the fleet earning its quota, or burning it?" line the
# desk previously had no way to see. Drawn from the same cc-value JSON; skipped if unavailable.
if [ -n "$CCVAL_JSON" ]; then
  printf '%s' "$CCVAL_JSON" | jq -r '
    .window_h as $w | (.fleet | "── value \(.value) = \(.commits)c"
       + (if .commits_unattributed>0 then "(\(.commits_unattributed)u)" else "" end)
       + " + \(.tasks)t  ·  spend ~\(.spend_pct)% (\(.active_sessions) active · \($w)h)"
       + (if .ratio!=null then "  ·  v/spend \(.ratio)" else "" end)
       + (if .churn then "   ⚠ FLEET CHURN — spend, 0 landed ──" else " ──" end)),
    ( [ .accounts[] | select(.churn) | "\(.acct) \(.session_pct // "?")%" ] as $ch
      | if ($ch|length)>0 then "   ⚠ net-negative: " + ($ch|join(" · ")) + " — spending, 0 landed" else empty end)
  ' 2>/dev/null
fi
[ -n "$VALFILE" ] && rm -f "$VALFILE" 2>/dev/null
