#!/bin/bash
# cc-reconcile — self-heal the cross-session registry so the reaper is never blind to a live pane.
#
# THE BUG THIS CLOSES. Registration is WRITE-ONCE at SessionStart (hooks/session-register.sh). A
# session whose account had the register hook wired AFTER it started — the whole pre-2026-07-18 cohort,
# a hook wired mid-fleet, a future outage, or any spawn mode that doesn't fire SessionStart — NEVER
# back-registers, because SessionStart already fired for it. It stays live, holding quota, INVISIBLE to
# cc-sessions / cc-classify / cc-reaper: the reaper's P0-12b self-check can only SURFACE the delta
# (`live panes − enumerated`), it cannot CLOSE it. Verified 2026-07-19: 12 live interactive claude panes,
# 8 registered — the 4 unseen all started before their account's hook was wired (NOT a broken spawn mode;
# every mode registers post-wiring). See docs & the backlog item 2be82e9732c1.
#
# THE FIX — reconciliation, not another SessionStart write. For every LIVE interactive claude pane that
# has no cc-registry row, synthesize the exact row SessionStart would have written, from two authoritative
# sources that already exist for every session:
#   • the pane identity + account — from the process ENV (ITERM_SESSION_ID → paneUUID, CLAUDE_CONFIG_DIR
#     → account) — the same fields hooks/session-register.sh reads;
#   • the session_id + cwd + startedAt — from Claude Code's OWN per-pid registry ~/.claude*/sessions/<pid>.json
#     (CC writes it for every session; it carries {pid, sessionId, cwd, startedAt, kind, status}).
# This makes the registry SELF-HEALING: "ensure every spawn registers" becomes a structural guarantee
# independent of which hook was wired when, instead of a spawn-mode whack-a-mole.
#
# SECOND BLIND SPOT — a STALE row on a RECYCLED pane (item a60d62a215f1). A row is WRITE-ONCE per pane,
# but a MONITORING DESK recycles in place: same pane uuid, new pid + session + cwd (often a new account).
# Its row rots to a DEAD pid, so cc-sessions sweeps it stale and cc-classify never enumerates the pane —
# yet the pane is LIVE, so the reaper self-check false-pages Δ1 forever (the desk is never a reap target:
# harmless but recurring page-noise). Mere file-existence hid this from reconcile too (it counted the
# rotted row "present"). The fix ALIGNS reconcile's present-test with cc-sessions' liveness (kill -0 on
# the recorded pid): a dead-pid row on a LIVE pane is HEALED (rewritten from the current occupant), not
# counted present. Mirrors the "registered desk exempt" precedent (4052d02): liveness-grounded, not blanket.
#
# INVARIANTS (each load-bearing):
#   ADDITIVE + STALE-HEAL — CREATES a row for a live pane with none, OR HEALS a row whose recorded pid is
#                     DEAD while the pane is live (a recycle-in-place: same pane, new pid/session). NEVER
#                     touches a row whose pid is ALIVE (a fresh SessionStart row stays authoritative),
#                     NEVER deletes. P8 HOLDS: a genuine spawn-death leaves a DEAD pane with no live pid,
#                     which this scan never iterates — only a LIVE pane's own superseded row is rewritten;
#                     retention/sweep stays with cc-sessions (age-based, P8).
#   P8 JOIN HELD    — a row is written ONLY with a real session_id (from CC's registry). A null-sid row
#                     would look like a spawn-death to cc-board's telemetry join, so we SKIP (surface via
#                     the reaper self-check) rather than write a false one.
#   SCHEMA-IDENTICAL— byte-compatible with hooks/session-register.sh's row {paneUUID,name,cwd,account,pid,
#                     startedAt,session_id}; cc-sessions can't tell a backfilled row from a hook-written one.
#   FAIL-SAFE       — best-effort; a pane we cannot resolve (no ITERM_SESSION_ID, no sessions/<pid>.json,
#                     no sid) is left for the self-check to surface. Always exits 0.
#
# Usage:
#   cc-reconcile            backfill missing rows for live panes; print a one-line summary
#   cc-reconcile --dry-run  show what WOULD be backfilled; write nothing
#   cc-reconcile --json     summary as a JSON object
#   cc-reconcile -h         this help
#
# Env overrides (tests): CC_REGISTRY_DIR · CC_RECONCILE_PS_BIN · CC_RECONCILE_SESSIONS_DIRS
#   (space-separated dirs holding <pid>.json) · CC_RECONCILE_LOG · CC_RECONCILE_NOW_MS ·
#   CC_RECONCILE_IT2_BIN (pane-liveness transport for the prune) · CC_REG_RETAIN_H.
#
# GUARDED PRUNE (f9385874de10): after backfill/heal, rows for CONFIRMED-GONE panes (pid dead AND
#   pane absent from `it2 session list`) are removed once past the CC_REG_RETAIN_H forensic window —
#   the same retention contract cc-sessions applies, so P8 (a spawn-death stays investigable) holds.
#   A LIVE pane's stale-pid row is HEALED, never pruned. it2 unreadable ⇒ prune NOTHING (fail-closed).
# bash 3.2-safe. Read-only except for the additive row writes.
set -uo pipefail

REG_DIR="${CC_REGISTRY_DIR:-$HOME/.claude/cc-registry}"
PS_BIN="${CC_RECONCILE_PS_BIN:-/bin/ps}"
IT2_BIN="${CC_RECONCILE_IT2_BIN:-$HOME/.claude/bin/it2}"
# CC's per-pid session registries across the accounts. ~/.claude-next/sessions symlinks to
# ~/.claude/sessions, so that one dir covers both; realpath-dedup below drops the alias.
SESSIONS_DIRS="${CC_RECONCILE_SESSIONS_DIRS:-$HOME/.claude/sessions $HOME/.claude-secondary/sessions $HOME/.claude-tertiary/sessions $HOME/.claude-quaternary/sessions}"
LOG_FILE="${CC_RECONCILE_LOG:-$HOME/.claude/logs/cc-reconcile.log}"

MODE=backfill; JSON=0
for a in "$@"; do
  case "$a" in
    --dry-run)  MODE=dryrun ;;
    --json)     JSON=1 ;;
    -h|--help)  sed -n '2,/^set -uo pipefail/p' "$0" | sed '$d' | sed 's/^# \{0,1\}//'; exit 0 ;;
    '')         ;;
    *)          printf 'cc-reconcile: unknown option %s\n' "$a" >&2; exit 2 ;;
  esac
done

command -v jq >/dev/null 2>&1 || { [ "$JSON" = 1 ] && echo '{"error":"jq required"}'; exit 0; }

log() { printf '[%s] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)" "$*" >> "$LOG_FILE" 2>/dev/null || true; }

# realpath-deduped sessions dirs (drop the .claude-next→.claude symlink alias so we scan each once).
uniq_sessions_dirs() {
  local d rp seen=""
  for d in $SESSIONS_DIRS; do
    [ -d "$d" ] || continue
    rp="$(cd "$d" 2>/dev/null && pwd -P)" || continue
    case " $seen " in *" $rp "*) ;; *) seen="$seen $rp"; printf '%s\n' "$rp" ;; esac
  done
}

# LIVE interactive claude pids — the SAME argv scan cc-reaper's live_pane_count uses (argv0 is claude /
# */claude / *cli.js; a print/version invocation is not a session). Emits one pid per line.
live_claude_pids() {
  "$PS_BIN" -wwo pid=,command= 2>/dev/null | awk '
    { pid=$1; a=$2
      if (a!="claude" && a !~ /\/claude$/ && a !~ /cli\.js/) next
      for (i=3; i<=8 && i<=NF; i++) if ($i=="-p" || $i=="--print" || $i=="--version") next
      print pid }'
}

# One env read per pid; callers grep the cached line. ITERM_SESSION_ID and CLAUDE_CONFIG_DIR are
# space-free, so word-splitting the env blob is safe for exactly these two keys.
env_val() { # <env-blob> <KEY>
  printf '%s' "$1" | tr ' ' '\n' | grep -E "^$2=" | head -1 | cut -d= -f2-
}

# Find CC's <pid>.json across the (deduped) sessions dirs; echo its path or empty.
sessions_file_for() { # <pid>
  local d f
  while IFS= read -r d; do
    f="$d/$1.json"
    [ -f "$f" ] && { printf '%s\n' "$f"; return 0; }
  done <<EOF
$(uniq_sessions_dirs)
EOF
  return 1
}

now_ms="${CC_RECONCILE_NOW_MS:-$(( $(date +%s) * 1000 ))}"
mkdir -p "$REG_DIR" 2>/dev/null || true

n_live=0 n_present=0 n_backfilled=0 n_healed=0 n_no_pane=0 n_no_sid=0 n_skipped=0
backfilled_names="" healed_names=""

while IFS= read -r pid; do
  [ -n "$pid" ] || continue
  n_live=$(( n_live + 1 ))

  env_blob="$("$PS_BIN" eww -p "$pid" -o command= 2>/dev/null)"
  # paneUUID from ITERM_SESSION_ID (strip the wNtNpN: prefix). No pane / not a UUID ⇒ unaddressable,
  # exactly as SessionStart would skip it (return 0 on a bad ITERM_SESSION_ID).
  pane="$(env_val "$env_blob" ITERM_SESSION_ID)"; pane="${pane##*:}"
  case "$pane" in
    ''|*[!0-9A-Fa-f-]*) n_no_pane=$(( n_no_pane + 1 )); continue ;;
  esac

  # PRESENT MUST MEAN LIVE — aligned with cc-sessions' kill -0, NOT mere file-existence. A row whose
  # recorded pid is ALIVE is genuinely present: leave it untouched (idempotent — a fresh SessionStart row
  # stays authoritative). A row whose pid is DEAD while THIS pane is live is a STALE row for a SUPERSEDED
  # incarnation — a recycle-in-place (the monitoring desk keeps its pane across a recycle but gets a new
  # pid/session, so its write-once row rots to a dead pid). cc-sessions sweeps that row, so cc-classify
  # never enumerates the pane and the reaper self-check false-pages Δ1. HEAL it below (rewrite from the
  # live pid's <pid>.json) instead of miscounting it "present". (Item a60d62a215f1.)
  heal=0
  if [ -f "$REG_DIR/$pane.json" ]; then
    rowpid="$(jq -r '.pid // empty' "$REG_DIR/$pane.json" 2>/dev/null)"
    if [ -n "$rowpid" ] && kill -0 "$rowpid" 2>/dev/null; then
      n_present=$(( n_present + 1 )); continue          # recorded pid alive → genuinely present, untouched
    fi
    heal=1                                              # dead-pid row on a live pane → recycle: heal (rewrite) below
  fi

  sfile="$(sessions_file_for "$pid")" || sfile=""
  if [ -z "$sfile" ]; then n_no_sid=$(( n_no_sid + 1 )); continue; fi

  kind="$(jq -r '.kind // empty' "$sfile" 2>/dev/null)"
  [ "$kind" = "interactive" ] || { n_skipped=$(( n_skipped + 1 )); continue; }
  sid="$(jq -r '.sessionId // empty' "$sfile" 2>/dev/null)"
  cwd="$(jq -r '.cwd // empty'       "$sfile" 2>/dev/null)"
  started="$(jq -r '.startedAt // empty' "$sfile" 2>/dev/null)"
  # P8: never synthesize a null-sid row (it would read as a spawn-death). Missing cwd ⇒ can't name/scope.
  { [ -n "$sid" ] && [ -n "$cwd" ]; } || { n_no_sid=$(( n_no_sid + 1 )); continue; }
  case "$started" in ''|*[!0-9]*) started="$now_ms" ;; esac

  # account = basename(CLAUDE_CONFIG_DIR or ~/.claude), leading dot stripped — identical to
  # session-register.sh:54. name = basename(cwd)-<short-uuid> — identical to session-register.sh:56.
  ccd="$(env_val "$env_blob" CLAUDE_CONFIG_DIR)"; [ -n "$ccd" ] || ccd="$HOME/.claude"
  acct="$(basename "$ccd" | sed 's/^\.//')"
  short="${pane%%-*}"
  name="$(basename "$cwd")-$short"

  if [ "$MODE" = dryrun ]; then
    if [ "$heal" = 1 ]; then
      n_healed=$(( n_healed + 1 )); healed_names="$healed_names $name"
    else
      n_backfilled=$(( n_backfilled + 1 )); backfilled_names="$backfilled_names $name"
    fi
    continue
  fi

  # Atomic write (tmp + mv) — a concurrent cc-sessions read never sees a partial file. Schema byte-
  # identical to hooks/session-register.sh:75-81.
  tmp="$REG_DIR/.$pane.$$.tmp"
  if jq -n --arg paneUUID "$pane" --arg name "$name" --arg cwd "$cwd" \
          --arg account "$acct" --arg sessionId "$sid" \
          --argjson pid "$pid" --argjson startedAt "$started" \
        '{paneUUID:$paneUUID, name:$name, cwd:$cwd, account:$account, pid:$pid,
          startedAt:$startedAt, session_id:(if $sessionId=="" then null else $sessionId end)}' \
        > "$tmp" 2>/dev/null; then
    if mv -f "$tmp" "$REG_DIR/$pane.json" 2>/dev/null; then
      if [ "$heal" = 1 ]; then
        n_healed=$(( n_healed + 1 )); healed_names="$healed_names $name"
        log "healed $name pane=$pane pid=$pid account=$acct sid=$sid (stale-pid row rewritten from live occupant)"
      else
        n_backfilled=$(( n_backfilled + 1 )); backfilled_names="$backfilled_names $name"
        log "backfilled $name pane=$pane pid=$pid account=$acct sid=$sid"
      fi
    else
      rm -f "$tmp" 2>/dev/null; n_skipped=$(( n_skipped + 1 ))
    fi
  else
    rm -f "$tmp" 2>/dev/null; n_skipped=$(( n_skipped + 1 ))
  fi
done <<EOF
$(live_claude_pids)
EOF

# ── GUARDED PRUNE — confirmed-gone rows only (item f9385874de10) ──────────────────────────────────
# The registry leaked rows: hooks/session-deregister.sh was written to drop a pane's own row on
# SessionEnd but was never WIRED into settings.json, so every clean close and every `handoff-fire.sh
# self-close` left its row behind (82 stale rows, 2026-07-20) and cc-reaper read those ghosts as
# crashed sessions. Wiring the hook stops NEW leaks; this sweeps the accumulated ones.
#
# THE INVARIANTS THIS MUST NOT BREAK:
#   P8 (presence ≠ liveness) — a dead row is the ONLY evidence of a spawn-death, so deletion stays an
#     AGE decision, never a liveness one. Same CC_REG_RETAIN_H window cc-sessions uses (default 24h).
#     We only fix the leak IN that policy: cc-sessions requires `startedAt > 0` to age a row out, so a
#     row with a missing/zero timestamp was IMMORTAL. Undated rows now age by file mtime.
#   HEAL, DO NOT PRUNE — a LIVE pane whose row carries a stale pid is cc-reconcile's heal case
#     (handled above); it must never be deleted here. Hence pid-dead AND pane-gone, both required.
#   FAIL-CLOSED — if it2 cannot answer, pane liveness is UNKNOWN, so NOTHING is pruned. An
#     unreadable transport must never look like "every pane is gone".
n_pruned=0
RETAIN_S=$(( ${CC_REG_RETAIN_H:-24} * 3600 ))
now_s=$(( now_ms / 1000 ))
live_panes=""; have_panes=0
if pl="$("$IT2_BIN" session list --json 2>/dev/null)" && [ -n "$pl" ]; then
  lp="$(printf '%s' "$pl" | jq -r 'if type=="array" then .[].id // empty else empty end' 2>/dev/null)"
  [ -n "$lp" ] && { live_panes="$lp"; have_panes=1; }
fi
if [ "$have_panes" = 1 ]; then
  for f in "$REG_DIR"/*.json; do
    [ -e "$f" ] || continue
    uuid="$(jq -r '.paneUUID // empty' "$f" 2>/dev/null)"
    [ -n "$uuid" ] || continue                                   # corrupt row → cc-sessions' call, not ours
    printf '%s\n' "$live_panes" | grep -qxF "$uuid" && continue  # pane LIVE → never prune (heal case)
    rowpid="$(jq -r '.pid // empty' "$f" 2>/dev/null)"
    [ -n "$rowpid" ] && kill -0 "$rowpid" 2>/dev/null && continue # pid alive → not confirmed gone
    # CONFIRMED GONE. Age it out under the retention window; undated rows fall back to mtime so
    # they can expire at all (the cc-sessions `startedAt > 0` immortality gap).
    started="$(jq -r '.startedAt // 0' "$f" 2>/dev/null)"
    case "$started" in ''|*[!0-9]*) started=0 ;; esac
    started=$(( started / 1000 ))
    [ "$started" -gt 0 ] || started="$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)"
    case "$started" in ''|*[!0-9]*) started=0 ;; esac
    [ "$started" -gt 0 ] && [ $(( now_s - started )) -gt "$RETAIN_S" ] || continue
    if [ "$MODE" = dryrun ]; then
      n_pruned=$(( n_pruned + 1 ))
    elif rm -f "$f" 2>/dev/null; then
      n_pruned=$(( n_pruned + 1 ))
      log "pruned pane=$uuid pid=${rowpid:-none} (pane gone + pid dead, age > ${RETAIN_S}s)"
    fi
  done
fi

verb=$([ "$MODE" = dryrun ] && echo "would backfill" || echo "backfilled")
healverb=$([ "$MODE" = dryrun ] && echo "would heal" || echo "healed")
pruneverb=$([ "$MODE" = dryrun ] && echo "would prune" || echo "pruned")
if [ "$JSON" = 1 ]; then
  jq -nc --argjson live "$n_live" --argjson present "$n_present" --argjson backfilled "$n_backfilled" \
         --argjson healed "$n_healed" --argjson pruned "$n_pruned" \
         --argjson no_pane "$n_no_pane" --argjson no_sid "$n_no_sid" --argjson skipped "$n_skipped" \
         --arg mode "$MODE" \
    '{mode:$mode, live:$live, present:$present, backfilled:$backfilled, healed:$healed,
      pruned:$pruned, no_pane:$no_pane, no_sid:$no_sid, skipped:$skipped}'
else
  printf 'cc-reconcile: %d live · %d present · %s %d · %s %d · %s %d · skipped %d (no-pane %d, no-sid %d)\n' \
    "$n_live" "$n_present" "$verb" "$n_backfilled" "$healverb" "$n_healed" \
    "$pruneverb" "$n_pruned" "$n_skipped" "$n_no_pane" "$n_no_sid"
  [ -n "$backfilled_names" ] && printf '  %s:%s\n' "$verb" "$backfilled_names"
  [ -n "$healed_names" ] && printf '  %s:%s\n' "$healverb" "$healed_names"
fi
exit 0
