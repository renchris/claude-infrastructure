#!/bin/bash
# Manually update/manage Claude Code versions
#
# Usage:
#   claude-update              # Update to latest
#   claude-update 2.1.8        # Install specific version
#   claude-update --cleanup    # Remove old versions (keep current + 1 previous)

set -euo pipefail

VERSIONS_DIR="$HOME/.claude-versions"
CURRENT_LINK="$VERSIONS_DIR/current"

KEEP_COUNT="${CLAUDE_VERSIONS_KEEP:-2}"

atomic_symlink() {
  local target="$1" link="$2"
  local tmp="${link}.tmp_$$"
  ln -s "$target" "$tmp"
  mv -f "$tmp" "$link"
}

cleanup_old_versions() {
  echo "Cleaning up old versions (keeping current + $KEEP_COUNT previous)..."

  local current_target
  current_target=$(readlink "$CURRENT_LINK" 2>/dev/null | xargs basename 2>/dev/null || echo "")

  local versions=()
  for dir in "$VERSIONS_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    local v
    v=$(basename "$dir")
    [[ "$v" == "current" || "$v" == .* ]] && continue
    versions+=("$v")
  done

  # Sort by semver descending
  IFS=$'\n' versions=($(printf '%s\n' "${versions[@]}" | sort -t. -k1,1rn -k2,2rn -k3,3rn))
  unset IFS

  # Build keep set
  local -A keep_set
  keep_set["$current_target"]=1
  local kept=0
  for v in "${versions[@]}"; do
    [[ "$v" == "$current_target" ]] && continue
    if [[ $kept -lt $KEEP_COUNT ]]; then
      keep_set["$v"]=1
      kept=$((kept + 1))
    fi
  done

  local deleted=0
  for v in "${versions[@]}"; do
    if [[ -n "${keep_set[$v]:-}" ]]; then
      echo "  Keeping $v"
    else
      # Process guard
      if pgrep -f "claude-versions/$v" >/dev/null 2>&1; then
        echo "  Skipping $v (in use by running session)"
        continue
      fi
      echo "  Removing $v..."
      rm -rf "$VERSIONS_DIR/$v" 2>/dev/null || echo "  ⚠ Could not fully remove $v"
      deleted=$((deleted + 1))
    fi
  done

  echo "✓ Cleanup complete ($deleted removed)"
}

install_version() {
  local VERSION="$1"
  local VERSION_DIR="$VERSIONS_DIR/$VERSION"

  if [[ -d "$VERSION_DIR" ]]; then
    echo "Version $VERSION already installed"
    atomic_symlink "$VERSION_DIR" "$CURRENT_LINK"
    echo "✓ Switched to $VERSION"
    return
  fi

  echo "Installing Claude Code $VERSION..."
  mkdir -p "$VERSION_DIR"
  npm install --prefix "$VERSION_DIR" @anthropic-ai/claude-code@"$VERSION"

  # Post-install validation
  if [[ ! -x "$VERSION_DIR/node_modules/.bin/claude" ]]; then
    echo "✗ Install failed (binary missing)"
    rm -rf "$VERSION_DIR"
    return 1
  fi

  atomic_symlink "$VERSION_DIR" "$CURRENT_LINK"
  echo "✓ Installed and switched to $VERSION"
}

# Main
mkdir -p "$VERSIONS_DIR"

if [[ "${1:-}" == "--cleanup" ]]; then
  cleanup_old_versions
  exit 0
fi

VERSION="${1:-latest}"

if [[ "$VERSION" == "latest" ]]; then
  VERSION=$(npm view @anthropic-ai/claude-code version)
  echo "Latest version: $VERSION"
fi

CURRENT=$(basename "$(readlink "$CURRENT_LINK" 2>/dev/null)" || echo "none")
echo "Current version: $CURRENT"
echo ""

install_version "$VERSION"
