#!/bin/bash
# cc-await-ping — block until a NEW line lands in this session's mailbox, print it,
# and exit. The modal-safe PULL complement to cc-notify's push.
#
# Launch it via Bash(run_in_background) before going idle after a `--notify-back`
# handoff: when the fired peer pings (a mailbox write), this exits and the harness's
# task-completion notification re-invokes you — even if the peer's composer injection
# mislanded because you were at a permission/modal prompt. The mailbox write is the
# wake; the injection is the interrupt. Both paths, one loop closed.
#
#   cc-await-ping [<uuid>]          default uuid = own pane ($ITERM_SESSION_ID)
#
# Options:
#   --role <name>   watch the ROLE's mailbox (~/.claude/cc-roles/<name>), re-resolved
#                   EVERY poll cycle — follows a recycle that re-points the role file.
#                   On a mid-wait switch the new mailbox baselines at 0 (never miss the
#                   ping; a rare replay-wake is benign). Mutually exclusive with <uuid>.
#   --timeout <s>   give up after S seconds (default 1800; exit 2)
#   --interval <s>  poll cadence in seconds (default 15)
#   -h, --help
#
# Exit: 0 = new line(s) arrived (printed to stdout); 2 = timed out; 3 = no uuid/role.
# Env overrides (tests): CC_MAILBOX_DIR, CC_ROLES_DIR.
set -uo pipefail

MAILBOX_DIR="${CC_MAILBOX_DIR:-$HOME/.claude/mailbox}"
ROLES_DIR="${CC_ROLES_DIR:-$HOME/.claude/cc-roles}"
TIMEOUT=1800
INTERVAL=15
UUID=""
ROLE=""

usage() { sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'; }

while [ $# -gt 0 ]; do
  case "$1" in
    --role)     ROLE="${2:?--role needs a value}"; shift 2 ;;
    --timeout)  TIMEOUT="${2:?--timeout needs a value}"; shift 2 ;;
    --interval) INTERVAL="${2:?--interval needs a value}"; shift 2 ;;
    -h|--help)  usage; exit 0 ;;
    --*)        echo "cc-await-ping: unknown option '$1'" >&2; usage >&2; exit 2 ;;
    *)          if [ -z "$UUID" ]; then UUID="$1"; shift; else echo "cc-await-ping: too many arguments" >&2; exit 2; fi ;;
  esac
done

if [ -n "$ROLE" ] && [ -n "$UUID" ]; then
  echo "cc-await-ping: --role and <uuid> are mutually exclusive" >&2; exit 2
fi

resolve_uuid() {
  # role mode: re-read the role file each call (follows recycles); else the fixed uuid.
  if [ -n "$ROLE" ]; then
    local rf="$ROLES_DIR/$ROLE"
    [ -f "$rf" ] || { echo ""; return; }
    tr -d '[:space:]' < "$rf"
  else
    echo "$UUID"
  fi
}

if [ -z "$ROLE" ] && [ -z "$UUID" ]; then
  _it="${ITERM_SESSION_ID:-}"; UUID="${_it##*:}"
fi
CUR_UUID="$(resolve_uuid)"
[ -n "$CUR_UUID" ] || { echo "cc-await-ping: no uuid given and no \$ITERM_SESSION_ID (or role file '$ROLES_DIR/$ROLE' missing)" >&2; exit 3; }

# ── shared cursor lib (critique F6a): baseline off the SAME .seen cursor the drain/fold use, so mail
#    ALREADY pending when we arm fires IMMEDIATELY — the old `wc -l` arm-time baseline missed exactly
#    that line. On fire, mailbox_take advances seen+acked (our stdout rides the harness task-completion
#    notification → a reliable delivery the model reads). Lib absent → the standalone grep -c '' fallback.
_bd="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
_mbxlib="$_bd/../hooks/lib/mailbox-pending.sh"
[ -f "$_mbxlib" ] || _mbxlib="$HOME/.claude/hooks/lib/mailbox-pending.sh"
_have_lib=0
if [ -f "$_mbxlib" ] && command -v jq >/dev/null 2>&1; then
  # shellcheck source=/dev/null
  . "$_mbxlib" 2>/dev/null && command -v mailbox_has_pending >/dev/null 2>&1 && _have_lib=1
fi

MBOX="$MAILBOX_DIR/$CUR_UUID.md"
_lc() { if [ -f "$MBOX" ]; then grep -c '' "$MBOX" 2>/dev/null; else echo 0; fi; }   # grep -c '' — matches the lib (F1)
baseline="$(_lc)"
echo "cc-await-ping: watching $CUR_UUID inbox ($([ "$_have_lib" = 1 ] && echo 'shared .seen cursor' || echo "from line $baseline"); timeout ${TIMEOUT}s, every ${INTERVAL}s)" >&2

# Wake-path HEARTBEAT (critique F5): touch <uuid>.watching each poll so cc-notify/cc-announce can tell a
# live session that WILL be woken (a fresh watcher heartbeat) from a live-but-idle one that only drains on
# its next turn. Cleaned on exit. Works for uuid- AND role-watchers (both resolve to a concrete uuid).
_watchfile() { printf '%s/%s.watching' "$MAILBOX_DIR" "$CUR_UUID"; }
trap 'rm -f "$(_watchfile)" 2>/dev/null || true' EXIT

elapsed=0
while [ "$elapsed" -lt "$TIMEOUT" ]; do
  next_uuid="$(resolve_uuid)"
  if [ -n "$next_uuid" ] && [ "$next_uuid" != "$CUR_UUID" ]; then
    rm -f "$(_watchfile)" 2>/dev/null || true
    CUR_UUID="$next_uuid"; MBOX="$MAILBOX_DIR/$CUR_UUID.md"; baseline="$(_lc)"
    echo "cc-await-ping: role re-pointed → now watching $CUR_UUID" >&2
  fi
  mkdir -p "$MAILBOX_DIR" 2>/dev/null || true; : > "$(_watchfile)" 2>/dev/null || true   # heartbeat

  if [ "$_have_lib" = 1 ]; then
    if mailbox_has_pending "$CUR_UUID"; then
      mailbox_take "$CUR_UUID" 1    # print the new line(s) + advance the shared cursor (reliable delivery)
      exit 0
    fi
  else
    cur="$(_lc)"
    if [ "$cur" -gt "$baseline" ]; then tail -n +"$((baseline + 1))" "$MBOX"; exit 0; fi
  fi
  sleep "$INTERVAL"
  elapsed=$((elapsed + INTERVAL))
done

echo "cc-await-ping: timed out after ${TIMEOUT}s — no new ping for $CUR_UUID" >&2
exit 2
