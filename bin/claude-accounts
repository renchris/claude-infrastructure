#!/usr/bin/env python3
"""claude-accounts — cross-account Claude Max usage dashboard, auth-state prober + work router.

Successor to ~/.reso/bin/reso-quota (2026-07-04), promoted into claude-infrastructure with the
2026-07-10 research fixes. Reads the account map from ~/.claude/accounts.json (SSOT — launchers,
config dirs, emails, Dia profiles) and, per account: auth state from the macOS Keychain, live
limits from api.anthropic.com/api/oauth/usage, live session concurrency from ps. Routes work with
the adversarially-verified scorer (use-it-or-lose-it x Fable-sub-cap coupling x 5h-safety x
rate-spread), with the Fable window read LIVE from ~/.claude/model-config.yaml frontier_access
(never a hardcoded date — the reso-quota JUL7 bug: the operator extended the window Jul-9 and the
hardcode silently killed all Fable routing).

Auth policy (rotation-safe by construction):
  - NEVER mints or persists tokens itself. Staleness is read from the keychain payload's
    expiresAt (no network needed).
  - Healing a stale/expired token is delegated to the official binary: headless
    `CLAUDE_CODE_OAUTH_REFRESH_TOKEN=... claude auth login`, which performs the refresh grant AND
    persists whatever (possibly rotated) tokens come back to the same keychain item. Heal runs
    ONLY when the account has zero live sessions (no rotation race with a running CC) and under a
    per-account lock. reso-quota's refresh-and-discard pattern is retired: refresh tokens MAY
    rotate (GH anthropics/claude-code#54443, unanswered) and a discarded rotation = logged out.
  - "logged-out" is only declared after a fresh keychain re-read (no item, or the binary's heal
    reports an invalid refresh token).
  - Token-exposure note (decided trade-off): access tokens travel only in-process (urllib
    header — never curl argv). The ONE exception is the heal child's env
    (CLAUDE_CODE_OAUTH_REFRESH_TOKEN), visible to same-user `ps -E` for the <=90s heal — the
    official binary's only headless-auth contract, and equivalent exposure to the same user's
    existing keychain read access.

Usage:
  claude-accounts                     human table + route hints
  claude-accounts --json              machine-readable (rows + window + scores; tokens redacted)
  claude-accounts --route general|fable   best account name (bare, on stdout)
  claude-accounts --rank general|fable    ranked "name score" lines for wave spread (handoff)
      Both print the EXCLUDED accounts and why on stderr, on every invocation — a winner is
      "best of what we could see", and a transient throttle silently removes a candidate.
      Exit: 0 routable · 2 data was fine but nothing routable by POLICY (exhausted / 5h
      cutoff / window — callers must NOT fire blind) · 3 data unavailable for every account
      (callers may degrade to a proxy). A non-zero exit is an ANSWER, not a tool failure.
  claude-accounts --relogin-info NAME     JSON identity block for the account-relogin skill
  claude-accounts --fresh             bypass the shared cache
  claude-accounts --no-heal           never run the headless heal (pure read-only)
  claude-accounts --no-color          plain output (also: NO_COLOR env, pipes, TERM=dumb;
                                      FORCE_COLOR=1 forces color for screenshots)

Shared cache: /tmp/claude-accounts-cache.json (default TTL 90s, flock single-flight) so N
concurrent callers (handoff waves, statuslines, sessions) produce one endpoint sweep, not N —
both oauth endpoints rate-limit under load.
"""
import fcntl
import json
import os
import re
import subprocess
import sys
import time
import traceback
import unicodedata
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone
from hashlib import sha256

HOME = os.path.expanduser("~")
CFG_PATH = os.environ.get("CLAUDE_ACCOUNTS_JSON", os.path.join(HOME, ".claude", "accounts.json"))
LOG_PATH = os.path.join(HOME, ".claude", "logs", "claude-accounts.log")
# Last-good quota ledger: TTL-free, per-account, persisted OUTSIDE /tmp so a reboot/tmp-sweep
# never strands the last-known numbers. Env-overridable (mirrors CLAUDE_ACCOUNTS_JSON) so tests
# and scratch configs never touch the real ledger.
def _lastgood_path():
    explicit = os.environ.get("CLAUDE_ACCOUNTS_LASTGOOD")
    if explicit:
        return explicit
    logs = os.path.join(HOME, ".claude", "logs")
    # CLAUDE_ACCOUNTS_LASTGOOD is an INDEPENDENT variable that CLAUDE_ACCOUNTS_JSON does not
    # imply, so a scratch/test SSOT that overrode only the config still read and wrote the
    # REAL ledger — the cache is protected from exactly this by its cfg_key guard. Derive a
    # sibling ledger in that case. The default SSOT keeps the unchanged path on purpose:
    # deriving it unconditionally would orphan the whole accumulated ledger the day an
    # account is added or the SSOT moves, blanking "last-known" precisely when it matters.
    if os.environ.get("CLAUDE_ACCOUNTS_JSON"):
        h = sha256(os.path.realpath(CFG_PATH).encode()).hexdigest()[:8]
        return os.path.join(logs, f"claude-accounts-lastgood-{h}.json")
    return os.path.join(logs, "claude-accounts-lastgood.json")


LASTGOOD_PATH = _lastgood_path()


def log_event(msg):
    try:
        os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
        with open(LOG_PATH, "a") as f:
            f.write(f"{datetime.now(timezone.utc).isoformat()} {msg}\n")
    except OSError:
        pass


def load_cfg():
    try:
        with open(CFG_PATH) as f:
            cfg = json.load(f)
    except (OSError, json.JSONDecodeError) as e:
        sys.exit(f"claude-accounts: cannot read SSOT {CFG_PATH}: {e}")
    for a in cfg["accounts"]:
        a["config_dir"] = os.path.expanduser(a["config_dir"])
    for k in ("claude_bin", "model_config_ssot", "dia_local_state"):
        cfg[k] = os.path.expanduser(cfg[k])
    _validate_router(cfg)
    return cfg


ROUTER_KEYS = ("S_CUT", "S_SOFT", "SF_FLOOR", "KMAX", "KFLOOR", "MARGIN_H", "EPS_H",
               "WEEKLY_FLOOR", "FABLE_FLOOR", "JB_BONUS")


def _validate_router(cfg):
    """Fail with a MESSAGE on a bad router block, never with a traceback.

    The constants are documented as operator-tunable (KMAX was hand-raised 4 -> 8), and they
    are consumed unguarded — _soft divides by (S_CUT - S_SOFT), so S_SOFT == S_CUT is a
    ZeroDivisionError inside every consumer of this tool at once, and a typo'd key is a
    KeyError with no hint which file caused it. Same fail-loud contract load_cfg already uses
    for an unreadable SSOT."""
    R = cfg.get("router")
    if not isinstance(R, dict):
        sys.exit(f"claude-accounts: {CFG_PATH} has no 'router' block")
    bad = [k for k in ROUTER_KEYS
           if not isinstance(R.get(k), (int, float)) or isinstance(R.get(k), bool)]
    if bad:
        sys.exit(f"claude-accounts: router constants missing or non-numeric in {CFG_PATH}: "
                 + ", ".join(bad))
    problems = []
    if not 0 <= R["S_SOFT"] < R["S_CUT"] <= 1:
        problems.append(f"require 0 <= S_SOFT ({R['S_SOFT']}) < S_CUT ({R['S_CUT']}) <= 1")
    if R["KMAX"] < 1:
        problems.append(f"KMAX must be >= 1 (got {R['KMAX']})")
    if R["EPS_H"] <= 0:
        problems.append(f"EPS_H must be > 0 (got {R['EPS_H']})")
    if problems:
        sys.exit(f"claude-accounts: invalid router constants in {CFG_PATH}: "
                 + "; ".join(problems))


# ---- keychain -------------------------------------------------------------------------------

def keychain_service(config_dir):
    # CC 2.1.183: service = "Claude Code-credentials-" + sha256(NFC(config_dir))[:8] when
    # CLAUDE_CONFIG_DIR is set (all 4 accounts are); bare ~/.claude default gets no suffix.
    h = sha256(unicodedata.normalize("NFC", config_dir).encode()).hexdigest()[:8]
    return f"Claude Code-credentials-{h}"


def read_creds(config_dir, kc_account):
    """-> (payload dict | None, state) — state in {present, no-keychain-item, keychain-error}."""
    try:
        p = subprocess.run(
            ["/usr/bin/security", "find-generic-password", "-s", keychain_service(config_dir),
             "-a", kc_account, "-w"],
            capture_output=True, text=True, timeout=10)
    except subprocess.TimeoutExpired:
        return None, "keychain-error"
    if p.returncode == 44:                       # errSecItemNotFound
        return None, "no-keychain-item"
    if p.returncode != 0:                        # locked keychain / ACL / other
        return None, "keychain-error"
    try:
        d = json.loads(p.stdout)
    except json.JSONDecodeError:
        return None, "keychain-error"
    # A keychain password that is valid JSON but NOT an object (null, a list, a bare string)
    # used to reach .get() and raise AttributeError, which only json.JSONDecodeError was
    # catching — the traceback escaped main() and killed every mode. A non-object payload is
    # a corrupt item, not a missing one: "keychain-error", never "no-keychain-item" (the
    # latter maps to auth=logged-out at the caller and would trigger a pointless relogin).
    if not isinstance(d, dict):
        return None, "keychain-error"
    return (d.get("claudeAiOauth") or None), "present"


# ---- frontier window (SSOT read — never hardcode) --------------------------------------------

def frontier_window(cfg):
    """Parse frontier_access.{active,end} from model-config.yaml without PyYAML.
    Returns {active: bool|None, end: str|None, deadline: dt|None}. active None = UNKNOWN
    (parse failure) — callers must treat unknown as un-routable, never as open or closed."""
    win = {"active": None, "end": None, "deadline": None, "permanent": False}
    try:
        text = open(cfg["model_config_ssot"]).read()
    except OSError:
        return win
    m = re.search(r"^frontier_access:\n((?:[ \t]+.*\n|\n)*?)(?=^\S|\Z)", text, re.M)
    if not m:
        return win
    block = m.group(1)
    ma = re.search(r"^\s*active:\s*(true|false)\b", block, re.M)
    me = re.search(r"^\s*end:\s*\"?(\d{4}-\d{2}-\d{2})\"?", block, re.M)
    mp = re.search(r"^\s*permanent:\s*(true|false)\b", block, re.M)
    if ma:
        win["active"] = ma.group(1) == "true"
    # The SSOT states this outright: "This flag is the truth; `end` is a sentinel only."
    # Fable became a standing plan inclusion on 2026-07-20 and `end` was pinned to a
    # far-future date purely so date-based consumers never raise a false "expired". Parsing
    # only `end` made the footer advertise "26826.6d left" — a 73-year countdown on a
    # window that no longer exists. deadline=None is score-neutral: score_fable's
    # window-ended check and JB_BONUS branch are both already guarded on deadline is None.
    if mp and mp.group(1) == "true":
        win["permanent"] = True
    if me:
        win["end"] = me.group(1)
        end = datetime.strptime(me.group(1), "%Y-%m-%d").replace(tzinfo=timezone.utc)
        if cfg["frontier"].get("end_date_inclusive", True):
            end += timedelta(days=1)             # available THROUGH the end date
        # A permanent entitlement has no deadline to press against — leave it None so no
        # surface derives urgency from the sentinel.
        win["deadline"] = None if win["permanent"] else end
    return win


# ---- live concurrency (all claude sessions, not just --resume) --------------------------------

ENV_TOK = re.compile(r"^[A-Z_][A-Z0-9_]*=")


def concurrency(cfg):
    """Live interactive-session count per account. Counts processes whose argv[0] is the claude
    binary (excludes expect wrappers and node/MCP children that inherit the env), attributed via
    the CLAUDE_CONFIG_DIR env var that every launcher sets (ps -E appends env). Bare `claude`
    (env CLAUDE_CONFIG_DIR absent or ~/.claude) counts toward 'next' — .claude mirrors
    .claude-next. Headless one-shots (-p/--print) are skipped."""
    counts = {a["name"]: 0 for a in cfg["accounts"]}
    by_dir = {a["config_dir"]: a["name"] for a in cfg["accounts"]}
    mirror_next = next((a["name"] for a in cfg["accounts"] if a["config_dir"].endswith(".claude-next")), None)
    by_dir[os.path.join(HOME, ".claude")] = mirror_next
    try:
        out = subprocess.run(["ps", "-wwEo", "command="], capture_output=True, text=True,
                             timeout=10).stdout
    except (subprocess.TimeoutExpired, OSError):
        return counts
    for line in out.splitlines():
        toks = line.split()
        if not toks:
            continue
        t0 = toks[0]
        if not (t0 == "claude" or t0.endswith("/claude") or "cli.js" in t0):
            continue
        # Headless one-shot flags sit in the first few argv slots (`claude -p "…"`); scanning
        # the whole line would false-match a '-p' or '--print' inside a PROMPT argument.
        head = [t for t in toks[1:7] if t.startswith("-")]
        if "-p" in head or "--print" in head or "--version" in head:
            continue
        # ps -E appends env AFTER argv, so the LAST CLAUDE_CONFIG_DIR= match is the real env
        # var — a first-match search could hit prompt text that merely mentions it.
        cfgs = re.findall(r"CLAUDE_CONFIG_DIR=(\S+)", line)
        d = os.path.expanduser(cfgs[-1]) if cfgs else os.path.join(HOME, ".claude")
        name = by_dir.get(d.rstrip("/"))
        if name:
            counts[name] += 1
    return counts


# ---- usage endpoint (urllib in-process: no tokens in argv/ps) ---------------------------------

def _ssl_ctx():
    # python.org framework builds ship no CA bundle (CERTIFICATE_VERIFY_FAILED) — prefer
    # certifi, then the macOS system bundle, then whatever the default context finds.
    import ssl
    try:
        import certifi
        return ssl.create_default_context(cafile=certifi.where())
    except ImportError:
        pass
    if os.path.exists("/etc/ssl/cert.pem"):
        return ssl.create_default_context(cafile="/etc/ssl/cert.pem")
    return ssl.create_default_context()


SSL_CTX = None


def fetch_usage(cfg, token, retries=2):
    global SSL_CTX
    if SSL_CTX is None:
        SSL_CTX = _ssl_ctx()
    req = urllib.request.Request(
        cfg["usage_endpoint"],
        headers={"Authorization": f"Bearer {token}",
                 "anthropic-beta": "oauth-2025-04-20",
                 "User-Agent": cfg.get("user_agent", "claude-cli")})
    for attempt in range(retries + 1):
        try:
            with urllib.request.urlopen(req, timeout=12, context=SSL_CTX) as r:
                return r.status, json.loads(r.read().decode())
        except urllib.error.HTTPError as e:
            body = {}
            try:
                body = json.loads(e.read().decode())
            except Exception:
                pass
            if e.code == 429 and attempt < retries:
                time.sleep(1.5 * (attempt + 1))
                continue
            return e.code, body
        except (urllib.error.URLError, TimeoutError, json.JSONDecodeError, OSError):
            if attempt < retries:
                time.sleep(1.0)
                continue
            return None, None
    return None, None


# ---- heal (delegated to the official binary; rotation-safe) -----------------------------------

def heal(cfg, acct, refresh_token, k_live):
    """Headless re-auth via `claude auth login` with the refresh token in env. The binary does
    the refresh grant AND persists the (possibly rotated) tokens to the same keychain item.
    Gated: only when the account has ZERO live sessions (no rotation race with a running CC) and
    under a per-account lock. Returns (ok, detail)."""
    if k_live > 0:
        return False, f"skipped: {k_live} live session(s) — CC owns the token lifecycle"
    if not refresh_token:
        return False, "skipped: no refresh token in keychain"
    cbin = cfg["claude_bin"]
    if not os.path.exists(cbin):
        return False, f"skipped: claude binary missing at {cbin}"
    lock_path = f"/tmp/claude-accounts-heal-{acct['name']}.lock"
    with open(lock_path, "w") as lock:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return False, "skipped: another heal in flight"
        # Re-check liveness UNDER the lock. k_live came from a single ps snapshot taken at
        # the start of the sweep, which can be minutes old by the time this account's turn
        # arrives (each earlier account may burn a 90s heal plus two retry ladders). This
        # gate is the rotation-safety invariant — a refresh racing a running CC can rotate
        # the token out from under it, and a discarded rotation means logged out — so it
        # must be evaluated against current state, not a stale reading.
        if concurrency(cfg).get(acct["name"], 0) > 0:
            return False, "skipped: a session started during the sweep — CC owns the token"
        env = os.environ.copy()
        env["CLAUDE_CONFIG_DIR"] = acct["config_dir"]
        env["CLAUDE_CODE_OAUTH_REFRESH_TOKEN"] = refresh_token
        env["CLAUDE_CODE_OAUTH_SCOPES"] = cfg["oauth_scopes"]
        try:
            p = subprocess.run([cbin, "auth", "login"], env=env, capture_output=True,
                               text=True, timeout=90)
        except subprocess.TimeoutExpired:
            log_event(f"heal {acct['name']}: TIMEOUT")
            return False, "heal timed out"
        out = (p.stdout + p.stderr).strip()
        ok = p.returncode == 0 and "Login successful" in out
        detail = out.splitlines()[-1] if out else f"rc={p.returncode}"
        log_event(f"heal {acct['name']}: {'OK' if ok else 'FAIL'} — {detail}")
        return ok, detail


# ---- collection ------------------------------------------------------------------------------

def hrs_until(iso):
    if not iso:
        return None
    try:
        dt = datetime.fromisoformat(str(iso).replace("Z", "+00:00"))
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return (dt - datetime.now(timezone.utc)).total_seconds() / 3600.0
    except (ValueError, TypeError):
        return None


def pick(u, kind, scope_name=None):
    for lm in (u.get("limits") or []):
        if lm.get("kind") != kind:
            continue
        if scope_name and ((lm.get("scope") or {}).get("model") or {}).get("display_name") != scope_name:
            continue
        return lm.get("percent"), lm.get("resets_at")
    return None, None


# ---- last-good quota ledger (durable stale-quota visibility; NEVER influences routing) --------
# The oauth/usage endpoint yields quota ONLY on a 200. Every other outcome — logged-out /
# token-invalid / keychain-error / expired-stale-401 / no-data / 429 poll-throttle — leaves the
# row quota-blank and _excluded() drops it from routing. That exclusion is CORRECT and stays; the
# gap is that the STRANDED quota (how much weekly an unreachable account still holds) vanishes from
# --json / the table / a handoff successor. This ledger records the last good numbers per account
# so those surfaces can show "next3 logged-out — last-known weekly 31% @ 09:40" while the router
# still excludes the row (its error field is untouched). Generalizes the 429 poll-throttle's
# in-memory `prev` inheritance (≤ cache TTL) to a durable, TTL-free store.


def load_lastgood():
    """-> {acct: {quota fields + quota_as_of}}. Never raises (missing/corrupt ⇒ {})."""
    try:
        with open(LASTGOOD_PATH) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (OSError, json.JSONDecodeError):
        return {}


def save_lastgood(ledger):
    """Atomic replace; best-effort (a failed persist must never break a sweep)."""
    try:
        os.makedirs(os.path.dirname(LASTGOOD_PATH), exist_ok=True)
        tmp = f"{LASTGOOD_PATH}.{os.getpid()}.tmp"
        with open(tmp, "w") as f:
            json.dump(ledger, f, indent=2, sort_keys=True)
        os.replace(tmp, LASTGOOD_PATH)
    except OSError:
        pass


def inherit_lastgood(row, ledger, prev):
    """Merge an account's last-good quota into a quota-absent row for VISIBILITY ONLY.
    NEVER touches row['error'] → _excluded() still bails on it, so the router excludes the row
    exactly as before (no policy change). Absolute reset stamps are re-derived to *_reset_h at
    read time, so a day-old ledger shows a correct (possibly already-elapsed) countdown, not a
    frozen one. Prefers the durable ledger; falls back to the ≤TTL in-memory `prev` snapshot
    (percent-only) for the window before the first good sweep populates the ledger. Returns True
    if any quota was inherited."""
    e = ledger.get(row["acct"])
    if e and e.get("weekly_pct") is not None:
        # Per-bucket validation against that bucket's OWN reset stamp. A percent whose reset
        # has already passed is provably obsolete — that window rolled over to ~0 — so it must
        # not be presented as "last-known". The rollover is itself the useful fact: a stranded
        # account whose weekly has since reset is likely FRESH, which is exactly what decides
        # whether to bother relogging in. So record it; never blank the row (that would clear
        # stale_quota and leave the table with nothing to render at all).
        rolled = []
        for pfx in ("session", "weekly", "fable"):
            stamp = e.get(f"{pfx}_reset_at")
            h = hrs_until(stamp)
            if stamp and h is not None and h <= 0:
                row[f"{pfx}_pct"] = None
                row[f"{pfx}_reset_at"] = None
                row[f"{pfx}_reset_h"] = None
                rolled.append(pfx)
            else:
                row[f"{pfx}_pct"] = e.get(f"{pfx}_pct")
                row[f"{pfx}_reset_at"] = stamp
                row[f"{pfx}_reset_h"] = h
        if rolled:
            row["rolled_since"] = rolled
        row["credits_on"] = bool(e.get("credits_on"))
        row["credits_used"] = e.get("credits_used") or 0.0
        row["stale_quota"] = True
        row["quota_as_of"] = e.get("quota_as_of")
        return True
    pr = (prev or {}).get("rows", {}).get(row["acct"])
    if pr and pr.get("weekly_pct") is not None:
        for f in ("session_pct", "weekly_pct", "fable_pct"):
            if pr.get(f) is not None:
                row[f] = pr[f]
        ts = (prev or {}).get("ts")
        row["stale_quota"] = True
        # Provenance must survive re-inheritance. get_data writes the inherited row back into
        # the cache and _prev_snapshot reads rows back out of it, so an account with no ledger
        # entry re-inherits its OWN previously-inherited percents every sweep. Stamping
        # prev["ts"] unconditionally re-dated that data to "just now" on each pass, so numbers
        # of any age reported as fresh, forever. Carry the original stamp forward; only a row
        # that was genuinely LIVE in that snapshot may be dated by the snapshot's own time.
        row["quota_as_of"] = (
            pr.get("quota_as_of") if pr.get("stale_quota")
            else (datetime.fromtimestamp(ts, timezone.utc).isoformat() if ts else None))
        return True
    return False


def probe_account(cfg, acct, kc, k_live, ledger, prev, no_heal):
    """Probe ONE account -> (row, lastgood_entry | None).

    Split out of collect() so that an UNEXPECTED exception can be contained per-account:
    before the split, one malformed keychain item raised out of the loop and blanked the
    dashboard for ALL FOUR accounts (and every consumer of --json/--route/--rank) instead
    of degrading the single bad row."""
    name = acct["name"]
    row = {"acct": name, "email": acct["email"], "dia_profile": acct["dia_profile"],
           "launcher": acct["launcher"], "k": k_live, "auth": None}
    creds, kstate = read_creds(acct["config_dir"], kc)
    if kstate != "present":
        row["auth"] = "logged-out" if kstate == "no-keychain-item" else "keychain-error"
        row["error"] = row["auth"]
        inherit_lastgood(row, ledger, prev)
        return row, None
    if not creds:
        # The item exists but carries no usable claudeAiOauth blob (API-key auth, or a
        # half-written/cleared payload). read_creds returns (None, "present") for this by
        # design; the old code then called creds.get("refreshToken") -> AttributeError.
        # Short-circuit before the pointless heal + guaranteed-failing fetch, and give the
        # operator a label that names the real cause instead of "no data (http None)".
        row["auth"] = "no-oauth-blob"
        row["error"] = "keychain item present but carries no OAuth credentials"
        inherit_lastgood(row, ledger, prev)
        return row, None
    token = creds.get("accessToken")
    expires_ms = creds.get("expiresAt") or 0
    stale = expires_ms / 1000.0 <= time.time() + 60
    row["auth"] = "stale" if stale else "ok"
    if stale and not no_heal:
        ok, detail = heal(cfg, acct, creds.get("refreshToken"), k_live)
        if ok:
            creds, kstate = read_creds(acct["config_dir"], kc)
            token = (creds or {}).get("accessToken")
            row["auth"] = "healed"
        elif "invalid" in detail.lower() or "revoked" in detail.lower():
            row["auth"] = "logged-out"
            row["error"] = "logged-out"
            inherit_lastgood(row, ledger, prev)
            return row, None
        else:
            row["heal_note"] = detail
    status, u = fetch_usage(cfg, token) if token else (None, None)
    if status == 401:
        # CC may have rotated the token between our read and the call — one fresh re-read.
        creds, kstate = read_creds(acct["config_dir"], kc)
        token = (creds or {}).get("accessToken")
        status, u = fetch_usage(cfg, token) if token else (None, None)
        if status == 401:
            if row["auth"] == "stale":
                row["error"] = ("stale (expired token; --no-heal)" if no_heal
                                else "stale (expired token; heal skipped/failed — see heal_note)")
            else:
                row["auth"] = "token-invalid"
                row["error"] = "token-invalid (revoked? run /accounts relogin check)"
            inherit_lastgood(row, ledger, prev)
            return row, None
    if status == 429:
        # A 429 from the oauth/usage endpoint is ALWAYS a transient POLL-THROTTLE
        # (concurrent callers racing the 90s single-flight cache) — NEVER a usage cap.
        # A real weekly/5h/Fable cap returns HTTP 200 with percent≈100; status+endpoint
        # alone is the discriminator. Labeling this "rate-limited" made a downstream
        # session-classifier read a transient poll failure as a hard cap (false-limit
        # misdiagnosis 2026-07-16). Flag it distinctly + fall back to last-good percents.
        row["poll_throttled"] = True
        row["error"] = ("poll throttled ↻ (cached usage)"
                        if inherit_lastgood(row, ledger, prev) else "poll throttled ↻")
        return row, None
    if not u or "limits" not in u:
        row["error"] = f"no data (http {status})"
        inherit_lastgood(row, ledger, prev)
        return row, None
    sp, sr = pick(u, "session")
    wp, wr = pick(u, "weekly_all")
    fp, fr = pick(u, "weekly_scoped", cfg["frontier"]["scoped_display_name"])
    eu = u.get("extra_usage") or {}
    row.update({
        # session_reset_at is emitted alongside the *_reset_h countdown for the SAME reason
        # weekly/fable are: a countdown decays the moment it is serialized, so any consumer
        # rendering an absolute wall-clock time (the /accounts chat readout does) had to do
        # now + session_reset_h arithmetic itself. The absolute stamp is the durable form.
        "session_pct": sp, "session_reset_h": hrs_until(sr), "session_reset_at": sr,
        "weekly_pct": wp, "weekly_reset_h": hrs_until(wr), "weekly_reset_at": wr,
        "fable_pct": fp, "fable_reset_h": hrs_until(fr), "fable_reset_at": fr,
        "credits_on": bool(eu.get("is_enabled")), "credits_used": eu.get("used_credits") or 0.0,
    })
    # capture last-good (weekly is the durable stranded-quota signal; skip data-less rows).
    # Absolute reset stamps are stored (NOT the decaying *_reset_h) — inherit re-derives them.
    entry = None
    if wp is not None:
        entry = {
            "session_pct": sp, "session_reset_at": sr,
            "weekly_pct": wp, "weekly_reset_at": wr,
            "fable_pct": fp, "fable_reset_at": fr,
            "credits_on": bool(eu.get("is_enabled")), "credits_used": eu.get("used_credits") or 0.0,
            "quota_as_of": datetime.now(timezone.utc).isoformat(),
        }
    return row, entry


def collect(cfg, no_heal=False, prev=None):
    kc = cfg["keychain_account"]
    counts = concurrency(cfg)
    ledger = load_lastgood()
    lastgood_dirty = False
    rows = []
    for acct in cfg["accounts"]:
        name = acct["name"]
        try:
            row, entry = probe_account(cfg, acct, kc, counts.get(name, 0), ledger, prev,
                                       no_heal)
        except Exception as e:                    # never bare: KeyboardInterrupt/SystemExit pass
            # Containment, not concealment — the traceback goes to the log so a real
            # regression is still discoverable rather than silently degrading forever.
            log_event(f"probe {name}: UNEXPECTED {type(e).__name__}: {e}\n{traceback.format_exc()}")
            row = {"acct": name, "email": acct.get("email"), "dia_profile": acct.get("dia_profile"),
                   "launcher": acct.get("launcher"), "k": counts.get(name, 0),
                   "auth": "probe-error",
                   "error": f"probe failed: {type(e).__name__} (see claude-accounts.log)"}
            inherit_lastgood(row, ledger, prev)
            entry = None
        if entry:
            ledger[name] = entry
            lastgood_dirty = True
        rows.append(row)
    if lastgood_dirty:
        save_lastgood(ledger)
    return rows


# ---- router (verified scoring math, 2026-07-04; audit fixes 2026-07-10) -----------------------

def clamp(x, lo, hi):
    return max(lo, min(hi, x))


def horizon(reset_h, R):
    """Hours of runway a bucket has left -> the urgency DENOMINATOR (score = headroom / time).

    `(reset_h or EPS_H)` was wrong in three ways at once: None (the endpoint omits resets_at
    on a freshly-rolled bucket), 0.0, and any NEGATIVE value (a reset stamp inherited from the
    last-good ledger that has since elapsed) all collapsed T to the EPS_H floor — 0.25h. That
    is MAXIMUM urgency, so the account with the least trustworthy timing data scored ~400x
    higher than a healthy one and won the route.

    A missing horizon must read as "far away", never "imminent": substitute the full bucket
    period (NO_RESET_H) so the row stays rankable by its real headroom (w_rem / f_eff still
    discriminate) without the urgency inflation. Excluding the row instead would fail CLOSED —
    all four accounts sit at 0% with a null resets_at right after a weekly reset, i.e. exactly
    when the fleet is maximally available, and the router would answer "none".

    The EPS_H clamp is retained: it is a correct divide-by-zero guard for a genuinely imminent
    MEASURED reset — it must simply never be the fallback for an absent one."""
    h = reset_h if (reset_h is not None and reset_h > 0) else R.get("NO_RESET_H", 168.0)
    return max(h - R["MARGIN_H"], R["EPS_H"])


def _soft(r, R):
    su = (r.get("session_pct") or 0) / 100.0
    wu = (r.get("weekly_pct") or 0) / 100.0
    SF = clamp((R["S_CUT"] - su) / (R["S_CUT"] - R["S_SOFT"]), R["SF_FLOOR"], 1.0)
    KF = clamp(1 - r.get("k", 0) / R["KMAX"], R["KFLOOR"], 1.0)
    CF = (1.0 if wu < 0.90 else 0.5) if r.get("credits_on") else 1.0
    return SF * KF * CF


def _excluded(r, R):
    if "error" in r:
        return r["error"]
    if r.get("session_pct") is None:
        return "no-session-data"
    su = r["session_pct"] / 100.0
    sr = r.get("session_reset_h")
    if su >= R["S_CUT"] and (sr is None or sr >= R["EPS_H"]):
        return "5h-cutoff"
    if r.get("k", 0) >= R["KMAX"]:
        return "kmax-concurrency"
    return None


def score_general(r, cfg):
    R = cfg["router"]
    reason = _excluded(r, R)
    if reason:
        return None, reason
    if r.get("weekly_pct") is None:
        return None, "no-weekly-data"          # missing data is NOT headroom
    wtgt = 0.98 if r.get("credits_on") else 1.00
    w_rem = max(0.0, wtgt - r["weekly_pct"] / 100.0)
    if w_rem <= R["WEEKLY_FLOOR"]:
        return None, "weekly-exhausted"
    T = horizon(r.get("weekly_reset_h"), R)
    return (w_rem / T) * _soft(r, R), None


def score_fable(r, cfg, win):
    R, F = cfg["router"], cfg["frontier"]
    reason = _excluded(r, R)
    if reason:
        return None, reason
    if win["active"] is None:
        return None, "window-unknown"           # SSOT unreadable: fail loud, not open/closed
    if not win["active"]:
        return None, "window-inactive"
    if r.get("fable_pct") is None:
        return None, "no-fable-limit"           # missing scoped limit = no entitlement, not 100% headroom
    if r.get("weekly_pct") is None:
        return None, "no-weekly-data"
    h_deadline = None
    if win["deadline"] is not None:
        h_deadline = (win["deadline"] - datetime.now(timezone.utc)).total_seconds() / 3600.0 \
            - F["deadline_margin_h"]
        if h_deadline <= 0 and not F.get("credits_authorized"):
            return None, "window-ended"
        if h_deadline <= 0:
            h_deadline = None                   # credits mode: no window pressure, CF deprioritizes
    w_rem = max(0.0, (0.98 if r.get("credits_on") else 1.00) - r["weekly_pct"] / 100.0)
    f_eff = min(F["coupling"] * max(0.0, 1 - r["fable_pct"] / 100.0), w_rem)
    if f_eff <= R["FABLE_FLOOR"]:
        return None, "fable-exhausted"
    T_fable = horizon(r.get("fable_reset_h"), R)
    H = max(min(T_fable, h_deadline), R["EPS_H"]) if h_deadline is not None else max(T_fable, R["EPS_H"])
    JB = R["JB_BONUS"] if (h_deadline is not None and T_fable > h_deadline) else 1.00
    return (f_eff / H) * JB * _soft(r, R), None


def ranked(rows, cfg, win, kind):
    out = []
    reasons = {}
    for r in rows:
        s, why = score_fable(r, cfg, win) if kind == "fable" else score_general(r, cfg)
        if s is not None and s > 0:
            out.append((s, r))
        else:
            reasons[r["acct"]] = why or "zero-score"
    out.sort(key=lambda x: x[0], reverse=True)
    return out, reasons


# Exclusion reasons meaning "we could not SEE the data", as opposed to "policy says no".
# This drives the --route/--rank exit code, which callers branch on: 3 = data unavailable
# (degrade to a proxy), 2 = data was fine and policy refused (do NOT fire blind). The old
# test — `all("error" in r for r in rows)` — keyed on a row field these reasons never set,
# so a fleet excluded purely for missing data reported as a policy QUOTA CLIFF.
# Deliberately EXCLUDES "no-fable-limit": a missing scoped limit is an entitlement fact, not
# a gap in our knowledge. Classifying it as data-unavailable would make cc-route hard-refuse
# (RT-d) instead of taking its designed Opus down-tier when no account carries Fable.
DATA_UNAVAILABLE = {"no-session-data", "no-weekly-data", "window-unknown"}


def reason_class(row, why):
    """-> 'data' | 'policy' for one row's exclusion (see DATA_UNAVAILABLE)."""
    return "data" if ("error" in row or why in DATA_UNAVAILABLE) else "policy"


# ---- shared cache (single-flight) -------------------------------------------------------------

def _cfg_key(cfg):
    # Cache entries are keyed to the config identity so a scratch/test CLAUDE_ACCOUNTS_JSON
    # sharing the default cache_file can neither poison real routing nor read real rows.
    ident = os.path.realpath(CFG_PATH) + "|" + ",".join(sorted(a["name"] for a in cfg["accounts"]))
    return sha256(ident.encode()).hexdigest()[:12]


BAD_AUTH = ("stale", "logged-out", "token-invalid", "keychain-error", "no-oauth-blob",
            "probe-error")


def cache_read(cfg, want_heal=False, grace_s=None):
    """grace_s overrides the TTL — used ONLY by the lock-degrade path, which prefers a
    slightly-expired sweep over blocking behind another caller's multi-minute one."""
    try:
        with open(cfg["cache_file"]) as f:
            c = json.load(f)
        # Valid JSON that is not an object (a stray `null`, `[]`, or a bare string written by
        # something else sharing /tmp) reached .get() and raised AttributeError, which the
        # handler below does not catch — every invocation then died until the file was
        # removed by hand. A malformed cache must degrade to "no cache", never wedge the tool.
        if not isinstance(c, dict):
            return None
        if c.get("cfg_key") != _cfg_key(cfg):
            return None
        ttl = grace_s if grace_s is not None else cfg.get("cache_ttl_s", 90)
        if time.time() - c.get("ts", 0) > ttl:
            return None
        # A no-heal sweep that saw auth trouble must not satisfy a heal-enabled caller —
        # that would defer the heal for the whole TTL and mislabel the state.
        if want_heal and c.get("no_heal") and any(
                (r.get("auth") in BAD_AUTH or "error" in r) for r in c.get("rows", [])):
            return None
        return c
    except (OSError, json.JSONDecodeError):
        pass
    return None


def cache_write(cfg, payload):
    tmp = cfg["cache_file"] + f".{os.getpid()}.tmp"
    try:
        with open(tmp, "w") as f:
            json.dump(payload, f)
        os.replace(tmp, cfg["cache_file"])
    except OSError:
        pass


def _prev_snapshot(cfg):
    """Last sweep's percents (TTL-ignored, cfg-key-checked) — feeds the burn-delta display."""
    try:
        with open(cfg["cache_file"]) as f:
            old = json.load(f)
        if old.get("cfg_key") != _cfg_key(cfg):
            return None
        # quota_as_of/stale_quota ride along so inherit_lastgood can carry provenance forward
        # instead of re-dating inherited numbers to "now" on every sweep. The burn-delta loop
        # (the only other consumer) reads a fixed field tuple and ignores the extra keys.
        return {"ts": old.get("ts"),
                "rows": {r["acct"]: {k: r.get(k) for k in
                                     ("session_pct", "weekly_pct", "fable_pct",
                                      "quota_as_of", "stale_quota")}
                         for r in old.get("rows", [])}}
    except (OSError, json.JSONDecodeError, KeyError):
        return None


def _acquire_lock(lock, cfg, allow_degrade):
    """Take the single-flight lock. -> True when held; False only when allow_degrade is set
    and the wait budget expired (caller should then serve a grace-TTL cache).

    allow_degrade is FALSE for --fresh, which must never be satisfied by cached data:
    handoff-fire runs `--fresh --json` specifically to force a live sweep WITH in-process
    auto-heal before firing a wave, and then reads the resulting rows to decide the fleet is
    healthy. Handing it a 91-second-old cache would report "all accounts healthy (or
    auto-healed)" when no heal had run at all, and the wave would fire at a stranded account."""
    if not allow_degrade:
        fcntl.flock(lock, fcntl.LOCK_EX)
        return True
    deadline = time.time() + cfg.get("lock_wait_s", 5)
    while True:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return True
        except BlockingIOError:
            if time.time() >= deadline:
                return False
            time.sleep(0.15)


def get_data(cfg, fresh=False, no_heal=False):
    if not fresh:
        c = cache_read(cfg, want_heal=not no_heal)
        if c:
            return c["rows"], c["window"], True, c.get("prev")
    lock_path = cfg["cache_file"] + ".lock"
    with open(lock_path, "w") as lock:
        # single-flight: first caller sweeps, rest reuse. The holder can own this for MINUTES
        # in the worst case — 4 accounts x (keychain read + a 90s heal subprocess + two
        # fetch_usage retry ladders) — and a bare blocking flock made every other caller
        # (statuslines, cc-board, a handoff wave) wait it out with no way to fall back to the
        # cache it had just declined by a few seconds.
        if not _acquire_lock(lock, cfg, allow_degrade=not fresh):
            c = cache_read(cfg, want_heal=not no_heal,
                           grace_s=cfg.get("cache_grace_s", 600))
            if c:
                return c["rows"], c["window"], True, c.get("prev")
            # Nothing servable — the wait is the only correct option.
            fcntl.flock(lock, fcntl.LOCK_EX)
        if not fresh:
            c = cache_read(cfg, want_heal=not no_heal)
            if c:
                return c["rows"], c["window"], True, c.get("prev")
        prev = _prev_snapshot(cfg)
        win = frontier_window(cfg)
        rows = collect(cfg, no_heal=no_heal, prev=prev)
        wj = {"active": win["active"], "end": win["end"], "permanent": win.get("permanent", False),
              # permanent is carried explicitly: without it a null deadline cannot be told
              # apart from "the SSOT deadline was unparseable" by any --json consumer.
              "deadline": win["deadline"].isoformat() if win["deadline"] else None}
        cache_write(cfg, {"ts": time.time(), "cfg_key": _cfg_key(cfg), "no_heal": no_heal,
                          "rows": rows, "window": wj, "prev": prev})
        return rows, wj, False, prev


def mark_self(rows, cfg):
    """Stamp is_self on each row — ALWAYS after get_data(), never inside collect().

    The sweep result is written to ONE shared cache file whose key hashes only the SSOT path
    plus the account names, and that path is $HOME/.claude/accounts.json for every session
    regardless of CLAUDE_CONFIG_DIR. All four accounts therefore share a single cache entry,
    so an is_self computed during the sweep would be served to a DIFFERENT account's session
    for the rest of the TTL — marking the wrong row as "you", which is the exact error this
    field exists to prevent. Computing it per-invocation from the reader's own env is the
    only correct placement.

    A bare ~/.claude (CLAUDE_CONFIG_DIR unset) attributes to the 'next' account, the same
    mirror rule concurrency() uses."""
    self_dir = os.path.expanduser(
        os.environ.get("CLAUDE_CONFIG_DIR") or os.path.join(HOME, ".claude")).rstrip("/")
    by_name = {a["name"]: a["config_dir"].rstrip("/") for a in cfg["accounts"]}
    mirror = next((a["name"] for a in cfg["accounts"]
                   if a["config_dir"].rstrip("/").endswith(".claude-next")), None)
    for r in rows:
        d = by_name.get(r["acct"])
        r["is_self"] = bool(d and d == self_dir) or (
            r["acct"] == mirror and self_dir == os.path.join(HOME, ".claude"))
    return rows


def win_from_json(wj):
    d = None
    if wj.get("deadline"):
        d = datetime.fromisoformat(wj["deadline"])
    return {"active": wj.get("active"), "end": wj.get("end"), "deadline": d,
            "permanent": bool(wj.get("permanent"))}


# ---- output ----------------------------------------------------------------------------------
# Human table only: ANSI truecolor with graceful degradation (pipe / NO_COLOR / TERM=dumb /
# --no-color → plain). Machine surfaces (--json/--route/--rank/--relogin-info) stay plain, always.

CLAY = (215, 119, 87)         # Anthropic clay — accents, matches CC's own TUI palette
PERI = (177, 185, 249)        # periwinkle — informational (healed, cache note)
GREEN = (140, 190, 120)
AMBER = (255, 193, 7)
RED = (224, 90, 90)
GRAY = (150, 150, 150)

COLOR = False


def _color_on(args):
    if "--no-color" in args or os.environ.get("NO_COLOR"):
        return False
    if os.environ.get("FORCE_COLOR"):
        return True
    return sys.stdout.isatty() and os.environ.get("TERM", "") != "dumb"


def c(txt, rgb=None, bold=False, dim=False):
    # NEVER emit SGR-2 (dim): its rendering is profile-dependent and collapses to invisible
    # on dark iTerm themes (observed 2026-07-10). "dim" = an explicit darker truecolor gray —
    # the same technique CC's own /context uses (38;2;153;153;153-style, no dim attribute).
    if not COLOR or (rgb is None and not bold and not dim):
        return txt
    if dim:
        rgb = tuple(int(v * 0.62) for v in (rgb or (170, 170, 175)))
    seq = ["1"] if bold else []
    if rgb:
        seq.append(f"38;2;{rgb[0]};{rgb[1]};{rgb[2]}")
    return f"\x1b[{';'.join(seq)}m{txt}\x1b[0m"


def usage_rgb(p):
    return GREEN if p < 50 else AMBER if p < 80 else RED


EIGHTHS = "▏▎▍▌▋▊▉█"


def cut_marker(p, cut, width=10):
    """'▲' once usage is at/over the router's hard cutoff, else ' '.

    The ┆ tick inside bar() can only sit on a CELL boundary, so on a 10-cell track it marks
    80%, not S_CUT=85% — and it is overwritten by the fill as soon as usage reaches it, i.e.
    it disappears from the 81-100% band, exactly where it decides routing. Widening the bar
    blows the 82-column budget; recoloring the fill is invisible under --no-color (which is
    how the agent path invokes this); substituting a glyph destroys the 1/8-cell magnitude
    the fill carries.

    So the crossing is signalled OUTSIDE the bar, in the separator that already sits between
    the bar and the percentage — width-neutral, a real character rather than a color, and an
    EXACT `p >= cut` comparison instead of cell arithmetic. Net effect: below the cutoff the
    ┆ tick shows how much room is left; at/over it the ▲ shows the line is crossed. Between
    the two — where the fill has swallowed the tick cell but usage has not yet reached the
    cutoff (82-84% on a 10-cell track) — the ┆ simply relocates here, so the decision line is
    visible at EVERY usage level rather than blinking out for the last few points before it
    matters most."""
    if p is None or cut is None:
        return " "
    if p >= cut * 100:
        return "▲"
    q = max(0.0, min(100.0, p)) / 100.0 * width
    full = int(q)
    fill_len = full + (1 if int((q - full) * 8) else 0)
    return "┆" if fill_len > int(width * cut) else " "


def bar(p, width=10, cut=None):
    """0-100 used% → `████▌···┆·` at 1/8-cell resolution, colored by severity.
    cut (0..1) draws a boundary tick in the TRACK where the router's hard cutoff sits, so the
    bar shows the DECISION LINE and not just magnitude (5h column: S_CUT). The tick is
    cell-granular (±5% on a 10-cell track) and is covered once the fill reaches it —
    cut_marker() carries the exact crossing signal from there on."""
    if p is None:
        return c("·" * width, GRAY, dim=True)
    q = max(0.0, min(100.0, p)) / 100.0 * width
    full, sub = int(q), int((q - int(q)) * 8)
    fill = "█" * full + (EIGHTHS[sub - 1] if sub else "")
    track = ["·"] * (width - len(fill))
    out = c(fill, usage_rgb(p))
    ci = int(width * cut) - len(fill) if cut is not None else -1
    if 0 <= ci < len(track):
        return (out + c("".join(track[:ci]), GRAY, dim=True) + c("┆", RED, dim=True)
                + c("".join(track[ci + 1:]), GRAY, dim=True))
    return out + c("".join(track), GRAY, dim=True)


def pct(p):
    # The number IS the signal (user feedback 2026-07-10: dimmed/textured data reads worse
    # than crisp numerals) — full-brightness severity color, bold once it's decision-relevant.
    if p is None:
        return c("   ?", GRAY, dim=True)
    return c(f"{p:>3.0f}%", usage_rgb(p), bold=p >= 80)


def fmt_h(h):
    if h is None:
        return "?"
    if h < 0:
        # An elapsed stamp means the bucket ALREADY rolled — fresh capacity, not an
        # expiry. Rendering it through the h<1 branch produced raw negative minutes
        # ("↻-2499m" observed live), which also overflowed the :>5 / :>6 reset cells and
        # skewed every column to the right of it. Kept to 3 chars so both fields hold.
        return "now"
    if h < 1:
        return f"{int(h * 60)}m"
    if h < 48:
        return f"{h:.1f}h"
    # Both reset cells are fixed-width (:>5 / :>6) and an overflow skews every column to
    # the right of it, so the width guarantee must hold for ANY input — including a corrupt
    # or far-future stamp — not merely for realistic ones.
    if h >= 2400:                                # ≥100d
        return "99d+"
    return f"{h / 24:.1f}d"


def _fmt_asof(iso):
    """A last-good quota_as_of stamp → 'HH:MM' when captured today, else 'Mon DD', in LOCAL time
    (matches the table's header clock). None / unparseable ⇒ '' (caller omits the '@ …')."""
    if not iso:
        return ""
    try:
        dt = datetime.fromisoformat(str(iso).replace("Z", "+00:00"))
    except (ValueError, TypeError):
        return ""
    if dt.tzinfo is not None:
        dt = dt.astimezone()                     # aware → local, to match 'live · Mon HH:MM'
    now = datetime.now()
    return dt.strftime("%H:%M") if dt.date() == now.date() else dt.strftime("%a %d")


AUTH_GLYPH = {
    "ok": ("●", GREEN), "healed": ("●", PERI), "stale": ("◐", AMBER),
    "logged-out": ("○", RED), "token-invalid": ("✕", RED), "keychain-error": ("△", AMBER),
    "no-oauth-blob": ("△", AMBER), "probe-error": ("✕", RED),
}
# auth states that need an operator ACTION, surfaced as a bullet under the table
ACTIONABLE_AUTH = ("logged-out", "token-invalid", "keychain-error", "no-oauth-blob",
                   "probe-error")


def render_table(rows, cfg, win, cached, prev=None):
    W = 82                                     # visible width budget (right-aligned header meta)
    src = "cached" if cached else "live"
    stamp = f"{src} · {datetime.now().strftime('%a %H:%M')}"
    title = "Claude Max accounts"
    print()
    print("  " + c(title, bold=True)
          + " " * max(2, W - 2 - len(title) - len(stamp)) + c(stamp, GRAY))
    print()
    cell = 15                                   # bar(10) + space + pct(4)
    # the 5h header self-documents the ┆ tick: "5h session ┆85%" (router cutoff);
    # ↻5h heads the per-row 5-hour-window reset countdown — it was invisible until a
    # window silently rolled 81%→0% between sweeps (2026-07-11 feedback).
    cutlbl = f"{int(cfg['router']['S_CUT'] * 100)}%"
    h5 = c("5h session ", GRAY) + c("┆", RED, dim=True) + c(cutlbl, GRAY, dim=True)
    h5 += " " * (cell - 12 - len(cutlbl))                 # pad "5h session ┆85%" to the cell
    h5 += " " + c(f"{'↻5h':>5}", GRAY)                    # 5h-reset sub-column (matches the row width)
    print("  " + c(f"{'account':<8}   {'live':>4}  ", GRAY) + h5 + "  "
          + c(f"{'weekly all':<{cell}}  {'weekly Fable':<{cell}}  {'↻week':>6}", GRAY))
    alerts = []
    for r in rows:
        a = r.get("auth")
        glyph, grgb = AUTH_GLYPH.get(a, ("·", GRAY))
        # Quota-staleness OVERRIDES the auth glyph. A poll-throttled row keeps auth="ok",
        # so it rendered with the green ● and full-brightness bars — visually identical to
        # live data, while actually showing ledger numbers that can be days old AND being
        # silently dropped from routing. The bars stay bright on purpose (pct()'s comment
        # records that dimmed data reads worse than crisp numerals); the GLYPH carries the
        # warning. A row that was both healed and throttled loses the healed glyph here —
        # acceptable only because the "healed headlessly" alert fires independently below.
        if r.get("stale_quota"):
            glyph, grgb = "↻", AMBER
        # the invoking session's own account, resolved in probe_account from config_dir
        label = r["acct"] + (" ←" if r.get("is_self") else "")
        name = c(f"{label:<8}", bold=True) if a in ("ok", "healed") else f"{label:<8}"
        k = c(f"{r.get('k', 0):>4}", GRAY, dim=(r.get("k", 0) == 0))
        if "error" in r and not r.get("poll_throttled"):
            # auth-broken (logged-out / token-invalid / keychain-error / expired-stale / no-data):
            # error text prominent, plus the STRANDED last-known weekly when the ledger has it
            # (inheritance populated session_pct, which the old `is None` guard would have hidden).
            msg = r["error"]
            lastknown = ""
            if r.get("stale_quota") and r.get("weekly_pct") is not None:
                asof = _fmt_asof(r.get("quota_as_of"))
                lastknown = c(f"  · last-known wk {r['weekly_pct']:.0f}%"
                              + (f" @ {asof}" if asof else ""), AMBER, dim=True)
            print(f"  {name} {c(glyph, grgb)} {k}  "
                  + c(msg, RED if a in ("logged-out", "token-invalid") else AMBER)
                  + lastknown
                  + c(f"  ({r['email']})", GRAY, dim=True))
        else:
            srh = r.get("session_reset_h")
            # the 5h reset sits WITH the 5h usage: a high 5h% + soon reset = capacity relief
            # incoming. Amber when <1h (a rollover is imminent), else a quiet gray.
            s5r_rgb = AMBER if (srh is not None and srh < 1) else GRAY
            s5reset = c(f"{('↻' + fmt_h(srh)):>5}", s5r_rgb, dim=(srh is None or srh >= 1))
            cells = "  ".join([
                bar(r.get("session_pct"), cut=cfg["router"]["S_CUT"])
                + c(cut_marker(r.get("session_pct"), cfg["router"]["S_CUT"]), RED, bold=True)
                + pct(r.get("session_pct")) + " " + s5reset,
                bar(r.get("weekly_pct")) + " " + pct(r.get("weekly_pct")),
                bar(r.get("fable_pct")) + " " + pct(r.get("fable_pct"))])
            wrh = r.get("weekly_reset_h")
            reset_rgb = AMBER if (wrh is not None and wrh < 6) else GRAY   # imminent = act on it
            print(f"  {name} {c(glyph, grgb)} {k}  {cells}  "
                  + c(f"{fmt_h(wrh):>6}", reset_rgb))
        # conditional detail — only states that need action surface below the table
        if a in ACTIONABLE_AUTH:
            alerts.append(c("○ ", RED) + c(f"{r['acct']} {a}", RED, bold=True)
                          + c(f" → {r['email']} · Dia “{r['dia_profile']}”", GRAY)
                          + c(f" · fix: claude-accounts --relogin-info {r['acct']} → account-relogin skill",
                              GRAY, dim=True))
        elif a == "healed":
            alerts.append(c("↻ ", PERI) + c(f"{r['acct']} token was stale — healed headlessly", PERI)
                          + c(" · ~/.claude/logs/claude-accounts.log", GRAY, dim=True))
        elif a == "stale":
            alerts.append(c("◐ ", AMBER) + c(f"{r['acct']} token stale — heal skipped", AMBER)
                          + c(f" · {r.get('heal_note', r.get('error', ''))}", GRAY, dim=True))
        if r.get("stale_quota"):
            # The numbers on this row are historical AND the row is router-excluded (every
            # inheritance path leaves row["error"] set, which _excluded() bails on). Say both
            # — a number with no provenance reads as current.
            asof = _fmt_asof(r.get("quota_as_of"))
            alerts.append(c("↻ ", AMBER)
                          + c(f"{r['acct']} showing LAST-KNOWN quota, not polled this sweep", AMBER)
                          + c(f" · as of {asof or 'unknown'} · excluded from routing"
                              " · --fresh to retry", GRAY, dim=True))
            if r.get("rolled_since"):
                # The most actionable derived fact available for a stranded account: those
                # windows have reset since the reading, so it is probably fresh again.
                alerts.append(c("  ⤷ ", GREEN)
                              + c(f"{'/'.join(r['rolled_since'])} window(s) have RESET since"
                                  " that reading — this account is likely fresh", GREEN))
        sp = r.get("session_pct")
        # these two alerts imply a LIVE, routable account — never fire them on a stale/last-known
        # row (its number is historical; the account is currently unreachable/excluded).
        if sp is not None and sp >= 85 and not r.get("stale_quota"):
            alerts.append(c("▲ ", RED) + c(f"{r['acct']} 5h window at {sp:.0f}% — routing cutoff", RED)
                          + c(f" · resets in {fmt_h(r.get('session_reset_h'))}", GRAY, dim=True))
        if r.get("credits_on") and not r.get("stale_quota"):
            alerts.append(c("¢ ", AMBER) + c(f"{r['acct']} extra-usage credits ON", AMBER)
                          + c(f" · used {r.get('credits_used', 0):.0f}", GRAY, dim=True))
    if alerts:
        print()
        for a in alerts:
            print("  " + a)
    # burn since last sweep — the snapshot becomes an instrument (Δ<0.5% stays silent;
    # a NEGATIVE delta means that limit reset in between)
    if prev and prev.get("ts") and prev.get("rows"):
        chips = []
        for r in rows:
            p = prev["rows"].get(r["acct"]) or {}
            for f, tag in (("session_pct", "5h"), ("weekly_pct", "weekly"), ("fable_pct", "Fable")):
                a, b = p.get(f), r.get(f)
                if a is not None and b is not None and abs(b - a) >= 0.5:
                    # 5h moves fast — only surface it when the window ROLLED OVER (negative
                    # delta = reset). Its growth is noise; weekly/Fable show both directions.
                    if f == "session_pct" and b >= a:
                        continue
                    chips.append(c(f"{r['acct']} {b - a:+.0f}% {tag}", GRAY))
        if chips:
            # _prev_snapshot deliberately ignores the TTL, so this stamp can be days old.
            # Reuse the same today/not-today switch _fmt_asof uses — a bare "since 02:45"
            # reads as this morning even when it is from last week.
            since = _fmt_asof(datetime.fromtimestamp(prev["ts"], timezone.utc).isoformat())
            print()
            print("  " + c("Δ ", PERI) + c(f"since {since}  ", GRAY, dim=True)
                  + c(" · ", GRAY, dim=True).join(chips))
    print()
    if win["active"] is None:
        wline = c("◌ ", RED) + c("Fable window UNKNOWN", RED, bold=True) \
            + c(" — model-config.yaml frontier_access unreadable", GRAY, dim=True)
    elif not win["active"]:
        wline = c("○ ", GRAY, dim=True) + c("Fable window inactive", GRAY, dim=True)
    elif win.get("permanent"):
        # No countdown: there is no deadline to press against. The old code derived one from
        # the far-future sentinel `end` and advertised "26826.6d left".
        wline = c("◉ ", GREEN) + c("Fable permanent", GREEN) \
            + c(" — standard Max/Team-Premium inclusion at ≤50% of weekly limits", GRAY)
    else:
        left_h = None
        if win["deadline"]:
            left_h = (win["deadline"] - datetime.now(timezone.utc)).total_seconds() / 3600.0
        # left_h stays truthful to the printed `end` date — subtracting the router's safety
        # margin here would contradict the date on the same line. The divergence that
        # mattered is the LABEL: score_fable stops routing Fable once left_h drops below
        # deadline_margin_h, so the footer must not still read "open" at that point.
        margin = cfg["frontier"].get("deadline_margin_h", 0.0)
        ended = (left_h is not None and left_h - margin <= 0
                 and not cfg["frontier"].get("credits_authorized"))
        urgent = left_h is not None and left_h < 24
        if ended:
            wline = c("○ ", RED) + c(f"Fable window ended {win['end']}", RED, bold=True) \
                + c(" — router excluding Fable", GRAY)
        else:
            wline = c("◉ ", AMBER if urgent else GREEN) \
                + c(f"Fable window open through {win['end']}", AMBER if urgent else GREEN) \
                + (c(f" · {fmt_h(left_h)} left", GRAY) if left_h is not None else "")
    print("  " + wline)
    g, gre = ranked(rows, cfg, win, "general")
    f, fre = ranked(rows, cfg, win, "fable")

    def route_line(label, lst, reasons, why_fields):
        head = c("➤ ", CLAY) + f"{label:<7} → "
        if not lst:
            return head + c("none", RED, bold=True) \
                + c("  " + " · ".join(f"{a} {w}" for a, w in reasons.items()), GRAY, dim=True)
        row = lst[0][1]
        why = " · ".join(w for w in (why_fields(row),) if w)
        # A COUNT, not the reason map: the footer lives in the same 82-col budget as the
        # table, and three "acct reason" pairs overflow it. The count is what changes the
        # read — "best of 4" and "best of the 1 we could see" are different claims — and the
        # per-account detail is already in the alert block above and --json route_reasons.
        excl = c(f"  · {len(reasons)} excluded", GRAY, dim=True) if reasons else ""
        return head + c(f"{row['acct']:<6}", CLAY, bold=True) + c(f" {why}", GRAY) + excl

    def fable_why(r):
        # Lead with the REASON. An imminent reset is a use-it-or-lose-it pick — naming it
        # first stops the "but that account is at 74%?!" first-read contradiction.
        frh = r.get("fable_reset_h")
        if frh is not None and frh < 24:
            return f"resets in {fmt_h(frh)} — use it or lose it · Fable {r['fable_pct']:.0f}%"
        return f"Fable {r['fable_pct']:.0f}% ↻ {fmt_h(frh)} · weekly {r['weekly_pct']:.0f}%"

    print("  " + route_line("general", g, gre, lambda r:
          f"5h {r['session_pct']:.0f}% · weekly {r['weekly_pct']:.0f}% ↻ {fmt_h(r.get('weekly_reset_h'))}"))
    print("  " + route_line("fable", f, fre, fable_why))
    if cached:
        print("  " + c(f"cache ≤{cfg.get('cache_ttl_s', 90)}s old · --fresh for a live sweep",
                       GRAY, dim=True))
    print()


def main():
    args = sys.argv[1:]
    if "-h" in args or "--help" in args:
        print(__doc__)
        return
    cfg = load_cfg()
    fresh = "--fresh" in args
    no_heal = "--no-heal" in args

    if "--relogin-info" in args:
        if args.index("--relogin-info") + 1 >= len(args):
            sys.exit("claude-accounts: --relogin-info requires an account name")
        name = args[args.index("--relogin-info") + 1]
        acct = next((a for a in cfg["accounts"] if a["name"] == name), None)
        if not acct:
            sys.exit(f"unknown account: {name} ({'|'.join(a['name'] for a in cfg['accounts'])})")
        dia_dir = None
        try:
            ls = json.load(open(cfg["dia_local_state"]))
            dia_dir = {v.get("name"): k for k, v in ls["profile"]["info_cache"].items()}.get(acct["dia_profile"])
        except (OSError, KeyError, json.JSONDecodeError):
            pass
        creds, kstate = read_creds(acct["config_dir"], cfg["keychain_account"])
        print(json.dumps({**{k: v for k, v in acct.items()}, "dia_profile_dir": dia_dir,
                          "keychain_service": keychain_service(acct["config_dir"]),
                          "keychain_state": kstate, "claude_bin": cfg["claude_bin"],
                          "oauth_scopes": cfg["oauth_scopes"],
                          "has_refresh_token": bool(creds and creds.get("refreshToken"))}, indent=2))
        return

    rows, wj, cached, prev = get_data(cfg, fresh=fresh, no_heal=no_heal)
    mark_self(rows, cfg)                          # per-invocation: MUST be after the cache read
    win = win_from_json(wj)

    if "--json" in args:
        for r in rows:
            g, gr = score_general(r, cfg)
            f, fr_ = score_fable(r, cfg, win)
            r["score_general"], r["score_fable"] = g, f
            r["route_reasons"] = {"general": gr, "fable": fr_}
            # Parallel map, not a reshape of route_reasons: the reason strings are prose
            # (one carries an emoji), so a consumer classifying them had to string-match.
            # None where the account routed — there is nothing to classify.
            r["route_reason_class"] = {
                "general": reason_class(r, gr) if gr else None,
                "fable": reason_class(r, fr_) if fr_ else None}
        # s_cut is config, not per-account state, so it rides at top level once. Emitted so
        # consumers read the routing cutoff as DATA instead of hardcoding 85 in prose that
        # silently diverges the day the SSOT constant changes.
        print(json.dumps({"window": wj, "cached": cached,
                          "s_cut": cfg["router"]["S_CUT"], "rows": rows}, indent=2))
        return

    if "--route" in args or "--rank" in args:
        if "--route" in args and "--rank" in args:
            sys.exit("claude-accounts: --route and --rank are mutually exclusive")
        flag = "--route" if "--route" in args else "--rank"
        # Read the flag's VALUE positionally. The old `"fable" if "fable" in args` was a
        # membership test over all of argv, so `--route fabel`, `--route FABLE` and a bare
        # `--route` all fell through to general and exited 0 with a confident account name —
        # a caller asking for a frontier account silently got a general one.
        i = args.index(flag)
        kind = args[i + 1] if i + 1 < len(args) else None
        if kind not in ("general", "fable"):
            sys.exit(f"claude-accounts: {flag} requires general|fable (got {kind!r})")
        cand, reasons = ranked(rows, cfg, win, kind)
        if not cand:
            print("none")
            print(f"claude-accounts: no routable account for {kind}: "
                  + "; ".join(f"{a}={w}" for a, w in reasons.items()), file=sys.stderr)
            # exit 3 = data unavailable (callers may degrade to a proxy); exit 2 = data was
            # fine, no account routable by POLICY (exhausted / window / cutoff — callers must
            # NOT fire blind). Classified by REASON, not by the presence of a row error.
            sys.exit(3 if all(reason_class(r, reasons.get(r["acct"])) == "data" for r in rows)
                     else 2)
        # Excluded accounts are named even when a route WAS found. Without this the caller
        # sees a confident winner and no hint that a roomier account was dropped for a
        # TRANSIENT reason (a 90s poll throttle scores null and vanishes) — which reads as
        # "this is the best account" rather than "this is the best account we could see".
        # stderr, so the stdout contract for both flags is untouched.
        if reasons:
            print(f"claude-accounts: {kind} excluded — "
                  + "; ".join(f"{a}={w}" for a, w in reasons.items()), file=sys.stderr)
        if flag == "--route":
            print(cand[0][1]["acct"])
        else:
            for s, r in cand:
                print(f"{r['acct']} {s:.6f}")
        return

    # human table
    global COLOR
    COLOR = _color_on(args)
    render_table(rows, cfg, win, cached, prev)


if __name__ == "__main__":
    main()
