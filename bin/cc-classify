#!/bin/bash
# cc-classify — idle-CAUSE classifier for a Claude Code session. The BRAIN of the autonomous
# lifecycle reaper: it decides WHY a session is idle so the reaper (bin/cc-reaper) can reap ONLY
# the provably-terminal, work-safe causes and NEVER an active/waiting/limited one.
#
#   cc-classify <target> [--json]     target = sessionId | paneUUID | friendly-name
#   cc-classify --all [--json]        classify every live session across the 4 accounts
#   cc-classify selftest              RED-proof each cause against fixtures (no real session)
#
# CAUSES (exactly one per session):
#   active            recent *assistant* turn (< idle threshold), pid alive        → NEVER reap
#   rate-limited      a structured usage-cap API error in the transcript tail       → NEVER reap
#   owned-wait        pid alive, idle, a legitimate wait (live teammates / user)    → NEVER reap
#   coordination-hang pid alive, idle, had REAL teammates but none alive / no prog  → NEVER reap (surface)
#   handed-off-lead   idle, fired a /handoff, a live successor exists elsewhere      → reap IFF work landed
#   finished-teammate a teammate/worktree session, idle, done                        → reap IFF work landed
#   finished          idle past threshold, NO live teammates, work LANDED (committed + on trunk) → reap
#   crashed           owning process is DEAD                                         → NEVER auto-reap (surface)
#
# SAFETY: the three REAPABLE causes (handed-off-lead, finished-teammate, finished) demand POSITIVE
# evidence (a fired handoff + a live successor; a teammate context + idleness; work durably landed +
# idle). Every ambiguous/idle case falls to a NEVER-reap cause. The implicit-team model (CC 2.1.178+)
# writes a team config for EVERY session — a config alone is NOT a coordination context; only a member
# beyond the in-process `team-lead` placeholder is (else every idle solo session read as coordination-hang
# and nothing could ever be `finished`). Work-landed and the final teardown gate are re-checked by the reaper
# and cc-teardown — this classifier is the FIRST of a defence-in-depth chain, never the only one.
# Inputs are read from durable signals (last-ASSISTANT-ts, registry pid, git, structured API error,
# process liveness), NEVER file mtime alone (mtime bumps on any append; memory cc-notify-session-pane).

set -uo pipefail

SESSIONS_BIN="${CC_CLASSIFY_SESSIONS_BIN:-cc-sessions}"
PS_BIN="${CC_CLASSIFY_PS_BIN:-/bin/ps}"
IDLE_S="${CC_CLASSIFY_IDLE_S:-300}"                 # < this since last assistant turn ⇒ active
COORD_HANG_DEAD_REAP_S="${CC_CLASSIFY_COORD_HANG_DEAD_REAP_S:-7200}"  # a coordination-hang idle past this WITH a live co-cwd owner ⇒ abandoned zombie (reapable)
NOW="${CC_CLASSIFY_NOW:-$(date +%s)}"
PROJECT_ROOTS="${CC_CLASSIFY_PROJECT_ROOTS:-$HOME/.claude/projects $HOME/.claude-secondary/projects $HOME/.claude-tertiary/projects $HOME/.claude-quaternary/projects}"
GIT_BIN="${CC_CLASSIFY_GIT_BIN:-git}"
TRUNK="${CC_CLASSIFY_TRUNK:-origin/main}"
TEAMS_GLOB="${CC_CLASSIFY_TEAMS_GLOB:-$HOME/.claude*/teams}"
WAIT_CONTRACTS_DIR="${CC_CLASSIFY_WAIT_CONTRACTS_DIR:-$HOME/.claude/wait-contracts}"   # L2 wait system (a17 S-3)
DESK_ROLE_FILE="${CC_CLASSIFY_DESK_ROLE_FILE:-$HOME/.claude/cc-roles/desk}"            # desk-role never-reap (a17 S-3)

die(){ printf 'cc-classify: %s\n' "$*" >&2; exit 2; }
command -v jq >/dev/null || die "jq required"

# ── input helpers (all read-only) ─────────────────────────────────────────────────────────────
iso_to_epoch() { # <iso8601 e.g. 2026-07-16T22:46:27.449Z> → epoch seconds (empty on parse fail)
  local s="${1%%.*}"; s="${s%Z}"                    # drop fractional seconds + trailing Z
  [ -z "$s" ] && return 0
  TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%S" "$s" +%s 2>/dev/null || true
}
alive() { [ -n "${1:-}" ] && kill -0 "$1" 2>/dev/null; }
pid_lstart() { # <pid> → normalized ps lstart string (identity pin, a17 S-4). Matches cc-teardown's format.
  [ -n "${1:-}" ] || return 0
  "$PS_BIN" -o lstart= -p "$1" 2>/dev/null | tr -s ' ' | sed 's/^ *//;s/ *$//'
}

find_transcript() { # <sid> → path to its .jsonl (first match across the account roots)
  local sid="$1" r f
  for r in $PROJECT_ROOTS; do
    [ -d "$r" ] || continue
    f="$(find "$r" -maxdepth 2 -name "$sid.jsonl" 2>/dev/null | head -1)"
    [ -n "$f" ] && { printf '%s' "$f"; return 0; }
  done
  return 1
}

last_assistant_ts() { # <jsonl> → epoch of last real assistant turn (excludes sidechain + api-error)
  local f="$1" iso
  [ -f "$f" ] || return 1
  iso="$(jq -rc 'select(.type=="assistant" and (.isSidechain|not) and ((.isApiErrorMessage//false)|not)) | .timestamp' "$f" 2>/dev/null | tail -1)"
  [ -n "$iso" ] && iso_to_epoch "$iso"
}

recent_api_limit() { # <jsonl> → 0 if a structured USAGE-CAP api error is among the last records
  local f="$1"
  [ -f "$f" ] || return 1
  # isApiErrorMessage is the SIGNAL (never text-grep 429 — mostly false positives, aa49); the text
  # is only to confirm it is a real cap ("session limit"/"weekly limit"), not a transient blip.
  tail -n 60 "$f" 2>/dev/null \
    | jq -rc 'select((.isApiErrorMessage//false)==true) | (.message.content // [] | map(.text // "") | join(" "))' 2>/dev/null \
    | grep -qiE 'session limit|weekly limit|usage limit|limit ·|resets'
}

handoff_fired() { # <jsonl> → 0 if the session actually FIRED a SELF-/handoff near the end
  local f="$1"
  [ -f "$f" ] || return 1
  # SELF-scoped tell (a18 L-3): a Bash tool_use that INVOKES the handoff mechanism AND is a self-op
  # (--recycle / self-close), or a bare /handoff — and does NOT target ELSEWHERE (--cwd / --worktree,
  # i.e. a third-party fire spawning some OTHER session). It is NEVER a mere Read of a *-resume.md
  # payload (reading a resume doc is not "I handed MYSELF off"), and NEVER the CC-native
  # `bridge-session` record (aa49). Reads carry .input.file_path, not .input.command — restricting to
  # .input.command drops them; the per-command awk keeps the --cwd/--worktree exclusion SCOPED to the
  # same command (a session may BOTH self-recycle AND third-party-fire in one tail window).
  tail -n 80 "$f" 2>/dev/null | jq -rc '
      if .type=="assistant"
      then (.message.content // [] | map(select(.type=="tool_use") | (.input.command // empty)) | .[])
      else empty end' 2>/dev/null \
    | awk '
        /(^|[ =])--cwd([ =]|$)/ || /(^|[ =])--worktree([ =]|$)/ { next }   # third-party fire → skip
        {
          mech   = ($0 ~ /handoff-fire\.sh/) || ($0 ~ /scripts\/handoff\.sh/)
          selfop = ($0 ~ /(^|[ ])--recycle([ ]|$)/) || ($0 ~ /(^|[ ])self-close([ ]|$)/)
          bare   = ($0 ~ /(^| )\/handoff( |$)/)
          if ((mech && selfop) || bare) { found = 1; exit }
        }
        END { exit(found ? 0 : 1) }'
}

tool_in_flight() { # <jsonl> → 0 if a tool is RUNNING: the transcript's LAST record is an assistant
  # tool_use whose id has no matching tool_result anywhere (a18 L-13). "idle" must mean no-new-assistant
  # AND no-tool-in-flight; a single long Bash/build/test call otherwise leaves the last record an
  # assistant tool_use timestamped at call START, so IDLE crosses 300s mid-call and reads `finished`.
  # In a real transcript a finished turn's last record is an assistant TEXT turn or a `user` tool_result
  # (never a bare trailing tool_use) — so this fires ONLY for a genuine mid-call state.
  local f="$1" last_rec tu_id
  [ -f "$f" ] || return 1
  last_rec="$(tail -n 1 "$f" 2>/dev/null)"
  [ -n "$last_rec" ] || return 1
  # last record must be an assistant message carrying at least one tool_use block
  printf '%s' "$last_rec" | jq -e '.type=="assistant" and ((.message.content // []) | map(select(.type=="tool_use")) | length > 0)' >/dev/null 2>&1 || return 1
  tu_id="$(printf '%s' "$last_rec" | jq -r '(.message.content // []) | map(select(.type=="tool_use")) | last | .id // empty' 2>/dev/null)"
  if [ -n "$tu_id" ]; then
    # a matching tool_result (a `user` record block) anywhere ⇒ the tool returned ⇒ not in-flight
    jq -rc 'select(.type=="user") | (.message.content // []) | if type=="array" then .[] else empty end | select(.type=="tool_result") | .tool_use_id // empty' "$f" 2>/dev/null \
      | grep -qxF "$tu_id" && return 1
  fi
  return 0   # trailing tool_use with no (matching) result → a tool is running
}

find_successor() { # <this-sid> <this-cwd> <since-epoch-SECONDS> <all-json> → candidate {paneUUID,pid} objects, one/line
  local sid="$1" cwd="$2" since="${3:-0}" all="$4"
  # A handoff continues the SAME work in the SAME cwd. A successor is a DISTINCT session (different
  # session_id) in that cwd, started at/after this session's last turn. Liveness (kill -0) is checked
  # by the caller — a dead 'successor' is no successor. Exclude self by session_id, never by pane
  # (a --recycle successor reuses the pane; a self-close successor gets a new one).
  # UNIT FIX (a18 L-3): registry startedAt is epoch-MILLISECONDS (session-register.sh:69 `date +%s*1000`)
  # while $since is epoch-SECONDS (a last-assistant ts). The old `startedAt >= since` was ms>=s — VACUOUS
  # (always true), so even a sibling started long BEFORE the "handoff" counted. Compare startedAt/1000.
  printf '%s' "$all" | jq -rc --arg cwd "$cwd" --arg sid "$sid" --argjson since "${since:-0}" '
      .[] | select(.cwd==$cwd)
          | select((.session_id // .sessionId // "") != $sid)
          | select($since==0 or ((.startedAt // 0) / 1000) >= $since)
          | {paneUUID, pid: ((.pid // "")|tostring)}' 2>/dev/null | head -20
}

cocwd_live() { # <sid> <cwd> <all-json> → 0 if a DISTINCT LIVE session shares this cwd. That live
  # session OWNS the shared working tree (its uncommitted work, not the target's), so reaping the
  # idle target strands nothing — its committed work persists in git, its WIP is checkpointed by
  # cc-teardown (git-plumbing snapshot, zero working-tree impact), and the live owner keeps the tree.
  local sid="$1" cwd="$2" all="$3" cand spid
  while IFS= read -r cand; do
    [ -z "$cand" ] && continue
    spid="$(printf '%s' "$cand" | jq -r '.pid // ""' 2>/dev/null)"
    alive "$spid" && return 0
  done < <(find_successor "$sid" "$cwd" 0 "$all")
  return 1
}

ahead_zero() { # <cwd> → 0 if HEAD is NOT ahead of trunk (this session's commits are landed on trunk)
  local cwd="$1" ahead
  [ -d "$cwd" ] || return 1
  "$GIT_BIN" -C "$cwd" rev-parse --git-dir >/dev/null 2>&1 || return 1
  ahead="$("$GIT_BIN" -C "$cwd" rev-list --count "$TRUNK"..HEAD 2>/dev/null)" || return 1
  [ "${ahead:-1}" = 0 ]
}

is_worktree_session() { # <cwd> → 0 if the cwd is a teammate/worktree path
  case "$1" in /tmp/wt-*|/private/tmp/wt-*|*/.worktrees/*|/tmp/worktree-*) return 0 ;; esac
  return 1
}

live_agent_procs() { # → count of live `--agent-name` (teammate) processes machine-wide
  "$PS_BIN" -eo pid=,command= 2>/dev/null | grep -c -- '--agent-name' || true
}

team_config() { # <sid> → path of a team config.json naming this sid as lead (empty if none)
  local sid="$1" c
  # shellcheck disable=SC2231  # $TEAMS_GLOB is INTENTIONALLY unquoted: it word-splits across the 4
  # account roots AND expands the `.claude*` glob — quoting would defeat both. (Cf. reaper-horizon-lint SC2086.)
  for c in $TEAMS_GLOB/*/config.json; do
    [ -f "$c" ] || continue
    jq -e --arg s "$sid" '((.leadSessionId // .lead_session_id // "")==$s)' "$c" >/dev/null 2>&1 && { printf '%s' "$c"; return 0; }
  done
  return 1
}

team_live_member() { # <team-config> → 0 if any member of this team is a live `--agent-name` process
  local c="$1" names procs m
  names="$(jq -r '(.members // [])[] | (.name // .member // empty)' "$c" 2>/dev/null)"
  [ -n "$names" ] || return 1
  procs="$("$PS_BIN" -eo pid=,command= 2>/dev/null | grep -- '--agent-name' || true)"
  while IFS= read -r m; do
    [ -z "$m" ] && continue
    printf '%s' "$procs" | grep -qF -- "--agent-name $m" && return 0
    printf '%s' "$procs" | grep -qF -- "--agent-name=$m" && return 0
  done <<< "$names"
  return 1
}

team_has_real_members() { # <team-config> → 0 if the team ACTUALLY spawned a teammate (≥1 member that is
  # NOT the in-process `team-lead` placeholder). The implicit-team model (CC 2.1.178+) writes a
  # teams/session-<sid8>/config.json for EVERY session — solo ones too — carrying a single phantom
  # member {name:team-lead, agentType:team-lead, backendType:in-process}: the lead itself, not a
  # teammate. Without this gate every idle solo session matched team_config and fell to coordination-hang.
  local c="$1" n
  n="$(jq -r '[(.members // [])[] | select(((.agentType // "") != "team-lead") and ((.name // "") != "team-lead"))] | length' "$c" 2>/dev/null)"
  [ -n "$n" ] && [ "$n" -gt 0 ]
}

open_wait_contract() { # <sid> <pane> → 0 if an OPEN wait-contract names this session as waiter (a17 S-3)
  # The L2 wait system (bin/cc-wait) writes a durable {waiter,waitee,...,status:"OPEN"} contract on disk
  # BEFORE a block. The classifier never read it, so a conscientious desk that went clean+landed and
  # waited on fired peers read `finished` and was executed. An OPEN contract naming this sid/pane as
  # waiter is POSITIVE wait evidence → never-reap. A CLOSED contract confers nothing (never weakens).
  local sid="$1" pane="$2" c w st
  [ -d "$WAIT_CONTRACTS_DIR" ] || return 1
  for c in "$WAIT_CONTRACTS_DIR"/*.json; do
    [ -f "$c" ] || continue
    st="$(jq -r '.status // ""' "$c" 2>/dev/null)"
    [ "$st" = OPEN ] || continue
    w="$(jq -r '.waiter // ""' "$c" 2>/dev/null)"
    [ -n "$w" ] || continue
    { [ "$w" = "$sid" ] || [ "$w" = "$pane" ]; } && return 0
  done
  return 1
}

is_desk_role() { # <sid> <pane> <name> → 0 if the desk-role file resolves to this session (a17 S-3)
  # cc-roles/<role> holds a single target (uuid|name). If the desk role points at this pane/sid/name,
  # this IS the orchestrator desk — never-reap, unconditionally (a dead desk has no respawner).
  local sid="$1" pane="$2" name="$3" t
  [ -f "$DESK_ROLE_FILE" ] || return 1
  t="$(head -1 "$DESK_ROLE_FILE" 2>/dev/null | tr -d '[:space:]')"
  [ -n "$t" ] || return 1
  [ "$t" = "$pane" ] || [ "$t" = "$sid" ] || [ "$t" = "$name" ]
}

work_landed() { # <cwd> → 0 if clean AND nothing ahead of trunk (pre-filter; cc-teardown re-verifies)
  local cwd="$1"
  [ -d "$cwd" ] || return 1
  "$GIT_BIN" -C "$cwd" rev-parse --git-dir >/dev/null 2>&1 || return 1
  [ -z "$("$GIT_BIN" -C "$cwd" status --porcelain 2>/dev/null)" ] || return 1
  local ahead; ahead="$("$GIT_BIN" -C "$cwd" rev-list --count "$TRUNK"..HEAD 2>/dev/null)" || return 1
  [ "${ahead:-1}" = 0 ]
}

# ── the decision tree ─────────────────────────────────────────────────────────────────────────
# sets: CAUSE, IDLE (seconds or -1), LANDED (yes/no/na), SUCCESSOR (uuid|""), DETAIL
classify_entry() { # <entry-json> <all-sessions-json>
  local e="$1" all="$2"
  local sid pid cwd pane name
  sid="$(printf '%s' "$e"  | jq -r '.session_id // .sessionId // ""')"
  pid="$(printf '%s' "$e"  | jq -r '.pid // ""')"
  cwd="$(printf '%s' "$e"  | jq -r '.cwd // ""')"
  pane="$(printf '%s' "$e" | jq -r '.paneUUID // ""')"
  name="$(printf '%s' "$e" | jq -r '.name // ""')"
  CAUSE=""; IDLE=-1; LANDED=na; SUCCESSOR=""; DETAIL=""

  # 1. owning process dead → crashed (idle-linger targets are ALIVE; a dead pid is a separate cleanup)
  if ! alive "$pid"; then CAUSE=crashed; DETAIL="pid ${pid:-?} not alive"; return 0; fi

  local tj lat
  tj="$(find_transcript "$sid" 2>/dev/null || true)"
  lat="$(last_assistant_ts "$tj" 2>/dev/null || true)"
  [ -n "$lat" ] && IDLE=$(( NOW - lat ))

  # 2. structured usage-cap in the transcript tail → rate-limited (resumes on reset; never reap)
  if [ -n "$tj" ] && recent_api_limit "$tj"; then CAUSE=rate-limited; DETAIL="structured usage-cap api error"; return 0; fi

  # 3. recent assistant turn → active
  if [ "$IDLE" -ge 0 ] 2>/dev/null && [ "$IDLE" -lt "$IDLE_S" ]; then
    CAUSE=active; DETAIL="last assistant turn ${IDLE}s ago (< ${IDLE_S}s)"; return 0
  fi
  # If we could not read a transcript ts AT ALL, we cannot prove idleness → treat as active (never-reap).
  if [ "$IDLE" -lt 0 ]; then CAUSE=active; DETAIL="no readable assistant timestamp — cannot prove idle (fail-safe)"; return 0; fi

  # --- pid alive, provably idle (>= IDLE_S), not rate-limited ---
  LANDED=no; work_landed "$cwd" && LANDED=yes

  # 4. handed-off-lead: fired a /handoff AND a LIVE successor session exists in the same cwd
  if [ -n "$tj" ] && handoff_fired "$tj"; then
    local cand spid found=""
    while IFS= read -r cand; do
      [ -z "$cand" ] && continue
      spid="$(printf '%s' "$cand" | jq -r '.pid // ""' 2>/dev/null)"
      if alive "$spid"; then found="$(printf '%s' "$cand" | jq -r '.paneUUID // ""' 2>/dev/null)"; break; fi
    done < <(find_successor "$sid" "$cwd" "${lat:-0}" "$all")
    if [ -n "$found" ]; then
      SUCCESSOR="$found"
      CAUSE=handed-off-lead; DETAIL="fired /handoff; LIVE successor $found in cwd; work-landed=$LANDED"; return 0
    fi
    DETAIL="fired /handoff but NO live successor found — not safe to reap"
  fi

  # 4.5 in-flight tool → active (a18 L-13). A single long tool call (12-min build/test) leaves the
  #     transcript's LAST record an assistant tool_use timestamped at call START; IDLE crosses 300s
  #     mid-call and the session otherwise reads `finished`/`finished-teammate`. A running tool ⇒ NOT
  #     idle ⇒ never-reap. Checked BEFORE the finished/finished-teammate branches (after handed-off-lead,
  #     whose own last record is the handoff tool_use with its tool_result already landed).
  if [ -n "$tj" ] && tool_in_flight "$tj"; then
    CAUSE=active; DETAIL="in-flight tool call (unmatched trailing tool_use) — running, not idle (never-reap)"; return 0
  fi

  # 4.6 wait-contract / desk-role → owned-wait (never-reap). a17 S-3: the classifier's only wait evidence
  #     was team-config members; it never read the L2 wait system, so a desk that went clean+landed and
  #     waited >10 min on fired peers read `finished` and the launchd reaper EXECUTED it. Read BOTH now,
  #     BEFORE any reapable idle cause: an OPEN wait-contract naming this session as waiter, or the desk
  #     role resolving to it, is positive wait evidence — never-reap (a dead desk has no respawner).
  if open_wait_contract "$sid" "$pane"; then
    CAUSE=owned-wait; DETAIL="idle ${IDLE}s, an OPEN wait-contract names this session as waiter — owned wait (never-reap)"; return 0
  fi
  if is_desk_role "$sid" "$pane" "$name"; then
    CAUSE=owned-wait; DETAIL="idle ${IDLE}s, the desk-role file resolves to this session — desk-role (never-reap)"; return 0
  fi

  # 5. finished-teammate: a worktree/teammate session, idle, no live successor needed
  if is_worktree_session "$cwd"; then
    CAUSE=finished-teammate; DETAIL="worktree/teammate session, idle ${IDLE}s; work-landed=$LANDED"; return 0
  fi

  # 6. REAL team coordination — ONLY when the team actually spawned a teammate (a member beyond the
  #    in-process `team-lead` placeholder; see team_has_real_members). A live member ⇒ owned-wait
  #    (healthy wave); had real members but none alive now ⇒ coordination-hang (stuck, surface).
  #    Both NEVER-reap; the split only decides whether the reaper SURFACES for re-engagement. Without
  #    the real-members gate the implicit-team config (every session has one) collapsed ALL idle solo
  #    sessions to coordination-hang — the "defaulting, not discriminating" bug this fix closes.
  local tc; tc="$(team_config "$sid" 2>/dev/null || true)"
  if [ -n "$tc" ] && team_has_real_members "$tc"; then
    if team_live_member "$tc"; then
      CAUSE=owned-wait; DETAIL="idle ${IDLE}s, lead of a team with ≥1 live member — healthy wait"; return 0
    fi
    # Gap A (2026-07-17): a coordination-hang whose partner is DEAD, idle past the dead-reap horizon,
    # WHILE a live co-cwd session owns the shared tree, is an abandoned zombie — reapable. Committed
    # work persists in git; WIP is checkpointed by cc-teardown; the live owner keeps the working tree.
    # The 13h doc_classifier wave-2 lead was exactly this (dead fix-w6 partner + live endgame lead in
    # the same cwd). LIVE coordination (team_live_member above) never reaches here.
    if [ "$IDLE" -ge "$COORD_HANG_DEAD_REAP_S" ] && cocwd_live "$sid" "$cwd" "$all"; then
      CAUSE=coordination-abandoned; DETAIL="idle ${IDLE}s (> ${COORD_HANG_DEAD_REAP_S}s horizon), team partner dead, a LIVE co-cwd session owns the tree — abandoned zombie, reapable"; return 0
    fi
    CAUSE=coordination-hang; DETAIL="idle ${IDLE}s, lead of a team but NO live member — stuck (surface, never reap)"; return 0
  fi

  # 7. finished: idle past threshold, no live teammates, and work is LANDED (clean tree AND nothing
  #    ahead of trunk). POSITIVE, durable done-evidence (committed + on trunk), never inferred from
  #    silence. Reapable — the reaper re-verifies landed + settle window and checkpoints WIP first.
  if [ "$LANDED" = yes ]; then
    CAUSE=finished; DETAIL="idle ${IDLE}s, no live teammates, work landed (clean & 0 ahead of $TRUNK) — done, reapable"; return 0
  fi

  # Gap B (2026-07-17): a solo idle session whose OWN commits are landed (0 ahead of trunk) but whose
  # cwd tree is dirty, WITH a live co-cwd session that owns that dirt, is very likely finished — the
  # dirt is the sibling's, not ours (session-4 the reaper-session: landed to main, yet the shared
  # checkout carried an unrelated `M validate-bash.sh`). SURFACE it (a dirty tree could still hold our
  # OWN WIP, so NOT auto-reaped — the desk/operator confirm-closes) so it never lingers silently.
  if [ "$LANDED" = no ] && ahead_zero "$cwd" && cocwd_live "$sid" "$cwd" "$all"; then
    CAUSE=finished-shared-review; DETAIL="idle ${IDLE}s, own commits landed (0 ahead of $TRUNK), tree dirty but a LIVE co-cwd sibling owns it — likely finished, surface for confirm-close (not auto-reaped)"
    return 0
  fi

  # 8. default: idle + alive but work NOT landed (or a solo/implicit team). NEVER reap — the operator
  #    may return, and an unlanded tree must never be stranded. owned-wait is the never-reap bucket.
  CAUSE=owned-wait; DETAIL="idle ${IDLE}s, pid alive, work not landed / no real team — waiting (never-reap default)"
  return 0
}

emit_one() { # <entry-json> <all-json> <json?>
  classify_entry "$1" "$2"
  if [ "${3:-}" = "--json" ]; then
    # emit pid + classify-time lstart so cc-reaper can pin session identity across classify→act (a17 S-4).
    local _pid _lstart
    _pid="$(printf '%s' "$1" | jq -r '.pid // ""')"
    _lstart="$(pid_lstart "$_pid")"
    jq -nc --argjson e "$1" --arg cause "$CAUSE" --arg idle "$IDLE" --arg landed "$LANDED" \
       --arg succ "$SUCCESSOR" --arg detail "$DETAIL" --arg lstart "$_lstart" \
       '{name:$e.name, paneUUID:$e.paneUUID, account:$e.account, cwd:$e.cwd,
         pid:($e.pid // null),
         cause:$cause, idle_s:($idle|tonumber? // -1), work_landed:$landed,
         lstart:(if $lstart=="" then null else $lstart end),
         successor:(if $succ=="" then null else $succ end), detail:$detail}'
  else
    printf '%-18s %-17s %-8s idle=%-7s landed=%-3s %s\n' \
      "$(printf '%s' "$1" | jq -r '.name // .paneUUID')" "$CAUSE" \
      "$(printf '%s' "$1" | jq -r '.account // "?"')" "$IDLE" "$LANDED" "$DETAIL"
  fi
}

cmd_classify() { # <target> [--json]
  local target="$1" json="${2:-}"
  local all; all="$("$SESSIONS_BIN" --json 2>/dev/null || echo '[]')"
  local e
  e="$(printf '%s' "$all" | jq -c --arg t "$target" '.[] | select(.paneUUID==$t or .session_id==$t or .sessionId==$t or .name==$t)' 2>/dev/null | head -1)"
  [ -n "$e" ] || die "no live session matches '$target'"
  emit_one "$e" "$all" "$json"
}

cmd_all() { # [--json]
  local json="${1:-}"
  local all; all="$("$SESSIONS_BIN" --json 2>/dev/null || echo '[]')"
  local n; n="$(printf '%s' "$all" | jq 'length' 2>/dev/null || echo 0)"
  [ "$json" = "--json" ] && printf '['
  local first=1 i
  for ((i=0; i<n; i++)); do
    local e; e="$(printf '%s' "$all" | jq -c ".[$i]")"
    if [ "$json" = "--json" ]; then
      [ $first = 1 ] || printf ','; first=0
      emit_one "$e" "$all" --json
    else
      emit_one "$e" "$all"
    fi
  done
  [ "$json" = "--json" ] && printf ']\n'
  return 0
}

case "${1:-}" in
  --all)        cmd_all "${2:-}" ;;
  selftest)     exec bats "$(cd "$(dirname "$0")" && pwd)/../tests/cc-classify.bats" ;;
  -h|--help|"") sed -n '2,20p' "$0"; exit 0 ;;
  *)            cmd_classify "$1" "${2:-}" ;;
esac
