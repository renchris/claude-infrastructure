#!/bin/bash
# cc-reaper — the autonomous SAFE session reaper (the standing loop's one sweep). It classifies
# every live session across the 4 accounts and reaps ONLY the two provably-terminal, work-safe
# causes, checkpoint-first, through the effect-verified cc-teardown actuator. The end of the
# north star: an idle handed-off lead never lingers holding a pane, and NOTHING else is ever killed.
#
#   cc-reaper sweep            DRY-RUN — classify + show what WOULD be reaped (default; writes nothing)
#   cc-reaper sweep --reap     ACT — checkpoint → re-verify → cc-teardown the safe candidates
#   cc-reaper selftest         RED-proof the disposition + the never-reap guarantees (no real session)
#
# SAFETY (defence-in-depth — a reap requires ALL of these, independently):
#   1. cc-classify labels the session handed-off-lead (successor live) OR finished-teammate.
#   2. work is LANDED (clean tree AND nothing ahead of origin/trunk) — re-verified here, post-classify.
#   3. it has been idle >= the SETTLE window (the primary --recycle / TeammateIdle self-close had its
#      chance first; the reaper is the BACKSTOP, never the first mover).
#   4. checkpoint-first: any WIP is snapshotted to refs/wip/<name>/LAST BEFORE any close (losing
#      uncommitted work is a P0 failure — so we snapshot even though a landed session should be clean).
#   5. cc-teardown re-runs its OWN gate (work-safe G-a + positive-done G-b + self-guard + tty-exclusive
#      + re-observed effect-verify). The done-evidence is DERIVED from positive signals (successor
#      alive, commits on trunk), NEVER inferred from silence — "idle ≠ done".
# active / owned-wait / coordination-hang / rate-limited / crashed are NEVER reaped — surfaced only.
#
# C10 note: cc-teardown's header bars raw hook/settings wiring; cc-reaper is the sanctioned PRE-GATED
# autonomous caller. cc-reaper's OWN standing-loop deployment (launchd) is the C10 operator step —
# see docs/AUTONOMOUS-REAPER-ACTIVATION.md. The tool itself never self-installs a daemon.

set -uo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
CLASSIFY_BIN="${CC_REAPER_CLASSIFY_BIN:-$HERE/cc-classify}"
TEARDOWN_BIN="${CC_REAPER_TEARDOWN_BIN:-$HERE/cc-teardown}"
CHECKPOINT_BIN="${CC_REAPER_CHECKPOINT_BIN:-$HERE/../hooks/teammate-checkpoint.sh}"
GIT_BIN="${CC_REAPER_GIT_BIN:-git}"
TRUNK="${CC_REAPER_TRUNK:-origin/main}"
SETTLE_S="${CC_REAPER_SETTLE_S:-600}"                 # backstop delay: give self-close 10 min first
LOG_FILE="${CC_REAPER_LOG:-$HOME/.claude/logs/cc-reaper.log}"
REAPABLE_RE='^(handed-off-lead|finished-teammate)$'

command -v jq >/dev/null || { echo "cc-reaper: jq required" >&2; exit 2; }
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
log(){ printf '[%s] %s\n' "$(date '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)" "$*" >> "$LOG_FILE" 2>/dev/null || true; }
say(){ printf '%s\n' "$*"; }

# clean AND nothing ahead of trunk — the load-bearing work-landed re-check (post-classify race guard).
work_landed() {
  local cwd="$1"
  [ -d "$cwd" ] || return 1
  "$GIT_BIN" -C "$cwd" rev-parse --git-dir >/dev/null 2>&1 || return 1
  [ -z "$("$GIT_BIN" -C "$cwd" status --porcelain 2>/dev/null)" ] || return 1
  local ahead; ahead="$("$GIT_BIN" -C "$cwd" rev-list --count "$TRUNK"..HEAD 2>/dev/null)" || return 1
  [ "${ahead:-1}" = 0 ]
}

checkpoint_first() { # <cwd> <name> <sid> — snapshot WIP to refs/wip/<name>/LAST (proven plumbing)
  local cwd="$1" name="$2" sid="$3"
  [ -x "$CHECKPOINT_BIN" ] || { log "checkpoint: $CHECKPOINT_BIN not executable — SKIP (no snapshot)"; return 1; }
  printf '{"session_id":"%s","hook_event_name":"TeammateIdle","cwd":"%s","team_name":"cc-reaper","teammate_name":"%s"}' \
    "$sid" "$cwd" "$name" | "$CHECKPOINT_BIN" >/dev/null 2>&1 || true
  return 0
}

worktree_cleanup() { # <cwd> — remove a LINKED worktree after a confirmed teardown (never the main tree)
  local cwd="$1"
  case "$cwd" in /tmp/wt-*|/private/tmp/wt-*|/tmp/worktree-*|*/.worktrees/*) ;; *) return 0 ;; esac
  # Only a LINKED worktree (git-dir != <cwd>/.git). Removing must run from the MAIN worktree.
  local gitdir main
  gitdir="$("$GIT_BIN" -C "$cwd" rev-parse --git-dir 2>/dev/null)" || return 0
  case "$gitdir" in */worktrees/*) ;; *) return 0 ;; esac      # not a linked worktree → leave it
  main="$("$GIT_BIN" -C "$cwd" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')"
  [ -n "$main" ] && [ "$main" != "$cwd" ] || return 0
  if "$GIT_BIN" -C "$main" worktree remove --force "$cwd" 2>/dev/null; then
    say "    worktree removed: $cwd"; log "worktree removed: $cwd"
  else
    say "    worktree remove FAILED (left intact): $cwd"; log "worktree remove failed: $cwd"
  fi
}

sweep() {
  local reap=0; [ "${1:-}" = "--reap" ] && reap=1
  local mode; mode=$([ $reap = 1 ] && echo REAP || echo DRY-RUN)
  say "cc-reaper sweep ($mode) — settle=${SETTLE_S}s trunk=$TRUNK"
  log "sweep start mode=$mode settle=$SETTLE_S"
  local cj; cj="$("$CLASSIFY_BIN" --all --json 2>/dev/null || echo '[]')"
  local n; n="$(printf '%s' "$cj" | jq 'length' 2>/dev/null || echo 0)"
  local reaped=0 candidates=0 i
  for ((i=0; i<n; i++)); do
    local o cause name pane cwd idle landed
    o="$(printf '%s' "$cj" | jq -c ".[$i]")"
    cause="$(printf '%s' "$o" | jq -r '.cause // "?"')"
    name="$(printf '%s'  "$o" | jq -r '.name // .paneUUID // "?"')"
    pane="$(printf '%s'  "$o" | jq -r '.paneUUID // ""')"
    cwd="$(printf '%s'   "$o" | jq -r '.cwd // ""')"
    idle="$(printf '%s'  "$o" | jq -r '.idle_s // -1')"
    landed="$(printf '%s' "$o" | jq -r '.work_landed // "no"')"

    # ── disposition (never-reap is the default; a reap needs every gate) ──
    if ! [[ "$cause" =~ $REAPABLE_RE ]]; then
      say "  keep   $name [$cause] — never-reap cause"; continue
    fi
    if [ "$landed" != yes ]; then
      say "  keep   $name [$cause] — work NOT landed (would strand work) → DEFER"; log "defer $name: not landed"; continue
    fi
    if ! [ "$idle" -ge "$SETTLE_S" ] 2>/dev/null; then
      say "  keep   $name [$cause] — idle ${idle}s < settle ${SETTLE_S}s (self-close still has its chance)"; continue
    fi
    candidates=$((candidates+1))
    if [ $reap = 0 ]; then
      say "  WOULD-REAP $name [$cause] pane=$pane idle=${idle}s landed=yes"; log "would-reap $name [$cause]"; continue
    fi

    # ── ACT: checkpoint-first → re-verify landed → cc-teardown (double-gate) → worktree cleanup ──
    say "  REAP   $name [$cause] pane=$pane"
    checkpoint_first "$cwd" "$name" "$(printf '%s' "$o" | jq -r '.paneUUID')"
    if ! work_landed "$cwd"; then
      say "    ABORT — became dirty/ahead post-classify; WIP checkpointed, NOT reaping"; log "abort $name: dirty post-classify (WIP checkpointed)"; continue
    fi
    local succ ev trc
    succ="$(printf '%s' "$o" | jq -r '.successor // "none"')"
    ev="cc-reaper: cause=$cause successor=$succ work-landed(clean & 0 ahead of $TRUNK) idle=${idle}s — positive done-evidence, not inferred from silence"
    "$TEARDOWN_BIN" "$pane" --done-evidence "$ev"; trc=$?
    if [ "$trc" = 0 ]; then
      reaped=$((reaped+1)); say "    torn down + effect-verified (cc-teardown exit 0)"; log "reaped $name [$cause] pane=$pane"
      worktree_cleanup "$cwd"
    else
      say "    cc-teardown returned $trc (10=DEFER 2=REFUSE 5=FAIL) — its gate refused; NOT reaped (trusted)"; log "teardown-refused $name rc=$trc"
    fi
  done
  say "cc-reaper: $n classified · $candidates safe candidate(s) · $reaped reaped"
  log "sweep end: $n classified $candidates candidates $reaped reaped"
  return 0
}

case "${1:-}" in
  sweep)        sweep "${2:-}" ;;
  selftest)     exec bats "$HERE/../tests/cc-reaper.bats" ;;
  -h|--help|"") sed -n '2,20p' "$0"; exit 0 ;;
  *)            echo "cc-reaper: unknown command '$1' (sweep | selftest)" >&2; exit 2 ;;
esac
