#!/bin/bash
# cc-reaper — the autonomous SAFE session reaper (the standing loop's one sweep). It classifies
# every live session across the 4 accounts and reaps ONLY the three provably-terminal, work-safe
# causes, checkpoint-first, through the effect-verified cc-teardown actuator. The end of the
# north star: an idle handed-off lead never lingers holding a pane, and NOTHING else is ever killed.
#
#   cc-reaper sweep            DRY-RUN — classify + show what WOULD be reaped/paged (default; writes nothing)
#   cc-reaper sweep --reap     ACT — checkpoint → re-verify → cc-teardown safe candidates; PAGE the desk on
#                              never-reap-but-surface causes; run the enumerated≈live-panes self-check
#   cc-reaper selftest         RED-proof the disposition + the never-reap guarantees (no real session)
#
# SURFACE PAGING (T-P3-3 — surfaced ≠ acted, the FM2 gap G-P3-3): a never-reap cause that needs a HUMAN
# (coordination-hang / crashed / finished-shared-review) was only `say`'d to stdout+log and NOTHING
# consumed it — the desk was never told. Now `--reap` emits a best-effort cc-notify PAGE to the desk
# (CC_PAGE_TO → the live cc-roles/desk file), composer-DAMPED (one page per pane per cause; a cause
# CHANGE re-pages; a pane leaving the surface set clears its marker → re-armed), plus a desk-board IDL
# row. cc-reaper NEVER acts on a surfaced cause — the operator/desk re-engages / closes / confirm-closes.
#
# ENUMERATED≈LIVE-PANES SELF-CHECK (P0-12b — the blind-spot detector, G-P3-1): the reaper can only reap
# what cc-classify enumerates. A spawn mode that never registers (cc-registry) is INVISIBLE — a live pane
# holding quota the reaper reports as "healthy" (it can't see it at all). Each `--reap` sweep counts live
# INTERACTIVE claude panes INDEPENDENTLY (a `ps` argv0 scan, NOT the registry) and compares to the
# enumerated count; a positive delta past tolerance, PERSISTED across sweeps (kills a start/exit race),
# PAGES the desk with the blind-session count. Surfaces the delta — never reaps on it.
# SAFETY (defence-in-depth — a reap requires ALL of these, independently):
#   1. cc-classify labels the session handed-off-lead (successor live) OR finished-teammate OR
#      finished (idle past settle + no live teammates + work landed) OR coordination-abandoned
#      (a dead-partner coordination-hang idle past COORD_HANG_DEAD_REAP_S WITH a live co-cwd owner
#      that owns the shared tree — still landed-gated at step 2, so ahead/dirty ones DEFER not reap).
#   2. work is LANDED (clean tree AND nothing ahead of origin/trunk) — re-verified here, post-classify.
#   3. it has been idle >= the SETTLE window (the primary --recycle / TeammateIdle self-close had its
#      chance first; the reaper is the BACKSTOP, never the first mover).
#   4. checkpoint-first: any WIP is snapshotted to refs/wip/<name>/LAST BEFORE any close (losing
#      uncommitted work is a P0 failure — so we snapshot even though a landed session should be clean).
#   5. cc-teardown re-runs its OWN gate (work-safe G-a + positive-done G-b + self-guard + tty-exclusive
#      + re-observed effect-verify). The done-evidence is DERIVED from positive signals (successor
#      alive, commits on trunk), NEVER inferred from silence — "idle ≠ done".
# active / owned-wait / coordination-hang / rate-limited / crashed / finished-shared-review are NEVER
# reaped — surfaced only (finished-shared-review = a done solo session whose dirty shared cwd is owned
# by a live sibling; surfaced for desk confirm-close since a dirty tree could still hold its own WIP).
#
# C10 note: cc-teardown's header bars raw hook/settings wiring; cc-reaper is the sanctioned PRE-GATED
# autonomous caller. cc-reaper's OWN standing-loop deployment (launchd) is the C10 operator step —
# see docs/AUTONOMOUS-REAPER-ACTIVATION.md. The tool itself never self-installs a daemon.

set -uo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
CLASSIFY_BIN="${CC_REAPER_CLASSIFY_BIN:-$HERE/cc-classify}"
TEARDOWN_BIN="${CC_REAPER_TEARDOWN_BIN:-$HERE/cc-teardown}"
CHECKPOINT_BIN="${CC_REAPER_CHECKPOINT_BIN:-$HERE/../hooks/teammate-checkpoint.sh}"
GIT_BIN="${CC_REAPER_GIT_BIN:-git}"
TRUNK="${CC_REAPER_TRUNK:-origin/main}"
SETTLE_S="${CC_REAPER_SETTLE_S:-600}"                 # backstop delay: give self-close 10 min first
LOG_FILE="${CC_REAPER_LOG:-$HOME/.claude/logs/cc-reaper.log}"
REAPABLE_RE='^(handed-off-lead|finished-teammate|finished|coordination-abandoned)$'

command -v jq >/dev/null || { echo "cc-reaper: jq required" >&2; exit 2; }
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
log(){ printf '[%s] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null)" "$*" >> "$LOG_FILE" 2>/dev/null || true; }  # -u: true UTC — a bare `date` stamps LOCAL time under the Z suffix, reading TZ-offset hours stale to any freshness check (false 'reaper DORMANT'); matches utc() + cc-reconcile/cc-teardown
say(){ printf '%s\n' "$*"; }

# ── surface-cause desk paging (T-P3-3) + enumerated≈live-panes self-check (P0-12b) config ──
PAGEDIR="${CC_REAPER_PAGEDIR:-$HOME/.claude/autonomy/pages/reaper}"     # damping/state (autonomy/pages namespace)
IDL_FILE="${CC_REAPER_IDL:-$HOME/.claude/autonomy/idl.jsonl}"           # shared desk board (supervisor-shaped rows)
PAGE_TO="${CC_PAGE_TO:-}"                                               # desk pane for cc-notify (best-effort)
PAGE_TO_FILE="${CC_PAGE_TO_FILE:-$HOME/.claude/cc-roles/desk}"          # fallback: live desk role file (empty PAGE_TO)
# never-reap causes that WARRANT a desk page (a human must re-engage / close / confirm-close). active,
# owned-wait, rate-limited are DELIBERATELY excluded: healthy or self-healing, a page would be noise.
SURFACE_PAGE_RE='^(coordination-hang|crashed|finished-shared-review)$'
PANE_DELTA_TOL="${CC_REAPER_PANE_DELTA_TOL:-0}"                         # live−enumerated > tol ⇒ blind-spot surface
SELFCHECK_MIN_PERSIST="${CC_REAPER_SELFCHECK_MIN_PERSIST:-2}"          # delta must persist N sweeps (kills a race)
PS_BIN="${CC_REAPER_PS_BIN:-/bin/ps}"
# cc-notify must resolve under launchd's bare default PATH — env override → beside-script bin → ~/.claude/bin
# → PATH (mirrors lead-supervisor's resolve order; the reaper's own NOTIFY_BIN seam is added for tests).
NOTIFY_BIN="${CC_REAPER_NOTIFY_BIN:-}"
if [ -z "$NOTIFY_BIN" ]; then
  for _c in "$HERE/cc-notify" "$HOME/.claude/bin/cc-notify" "$(command -v cc-notify 2>/dev/null || true)"; do
    [ -n "$_c" ] && [ -x "$_c" ] && { NOTIFY_BIN="$_c"; break; }
  done
fi
# cc-reconcile — the P0-12b companion that CLOSES the blind-spot delta instead of only surfacing it:
# it backfills a cc-registry row for any live pane that missed SessionStart (pre-wiring cohort / hook
# outage / a spawn mode that didn't fire the hook), so those panes are ENUMERATED this sweep. Same
# resolve order as NOTIFY_BIN; a missing binary just means the self-check keeps surfacing (no regression).
RECONCILE_BIN="${CC_REAPER_RECONCILE_BIN:-}"
if [ -z "$RECONCILE_BIN" ]; then
  for _c in "$HERE/cc-reconcile" "$HOME/.claude/bin/cc-reconcile" "$(command -v cc-reconcile 2>/dev/null || true)"; do
    [ -n "$_c" ] && [ -x "$_c" ] && { RECONCILE_BIN="$_c"; break; }
  done
fi
# cc-backlog — the CLAIM-ledger companion to cc-reconcile: where cc-reconcile heals the SESSION
# registry, `cc-backlog reap` heals the CLAIM ledger (dead-worker stale claim → reopen · persistent
# spawn-fail/land-conflict thrash → block), the FM2 gap neither the reaper nor cc-reconcile closed.
# Same resolve order; a missing binary just skips the claim sweep (no regression). Tunable via
# CC_BACKLOG_* (see cc-backlog `reap`); the reaper calls it with defaults.
BACKLOG_BIN="${CC_REAPER_BACKLOG_BIN:-}"
if [ -z "$BACKLOG_BIN" ]; then
  for _c in "$HERE/cc-backlog" "$HOME/.claude/bin/cc-backlog" "$(command -v cc-backlog 2>/dev/null || true)"; do
    [ -n "$_c" ] && [ -x "$_c" ] && { BACKLOG_BIN="$_c"; break; }
  done
fi
# cc-inbox-guard — the v2-comms fail-loud backstop: escalate mail enqueued to a session but never CONSUMED
# (unacked past a deadline). Rides the reaper cadence (same --reap gating as reconcile/backlog); a missing
# binary just skips the guard (no regression). Tunable via CC_INBOX_GUARD_* (see cc-inbox-guard).
GUARD_BIN="${CC_REAPER_GUARD_BIN:-}"
if [ -z "$GUARD_BIN" ]; then
  for _c in "$HERE/cc-inbox-guard" "$HOME/.claude/bin/cc-inbox-guard" "$(command -v cc-inbox-guard 2>/dev/null || true)"; do
    [ -n "$_c" ] && [ -x "$_c" ] && { GUARD_BIN="$_c"; break; }
  done
fi

utc(){ date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null; }
# desk-board IDL rows — supervisor-shaped {ts,actor,kind,…}. Values pass as jq --arg/--argjson (NEVER
# string-interpolated into the filter) so a name/pane carrying quotes can't corrupt or inject the row.
# The abstain-monitor filters for .hook+.disposition, so these actor-tagged rows are safely ignored there.
idl_surface(){ # <cause> <name> <pane>
  mkdir -p "$(dirname "$IDL_FILE")" 2>/dev/null || true
  jq -nc --arg ts "$(utc)" --arg cause "$1" --arg name "$2" --arg pane "$3" \
    '{ts:$ts, actor:"cc-reaper", kind:"surface-page", cause:$cause, name:$name, pane:$pane}' \
    2>/dev/null >> "$IDL_FILE" || true
}
idl_selfcheck(){ # <live> <enumerated> <delta>
  mkdir -p "$(dirname "$IDL_FILE")" 2>/dev/null || true
  jq -nc --arg ts "$(utc)" --argjson live "$1" --argjson enum "$2" --argjson delta "$3" \
    '{ts:$ts, actor:"cc-reaper", kind:"selfcheck-page", live:$live, enumerated:$enum, delta:$delta}' \
    2>/dev/null >> "$IDL_FILE" || true
}
page_target(){ local t="$PAGE_TO"; [ -n "$t" ] || t="$(cat "$PAGE_TO_FILE" 2>/dev/null || true)"; printf '%s' "$t"; }
notify_desk(){ # <message> — best-effort desk cc-notify; an unresolved target or missing cc-notify is silent, never fatal
  local target; target="$(page_target)"
  [ -n "$target" ] && [ -n "$NOTIFY_BIN" ] || return 0
  "$NOTIFY_BIN" "$target" "$1" >/dev/null 2>&1 || true
}
sanitize_key(){ printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'; }   # marker-filename-safe damping key

# live_pane_count — INDEPENDENT count of live INTERACTIVE claude panes (the P0-12b truth signal). Mirrors
# claude-accounts.concurrency(): argv0 is the claude binary (or its cli.js), excluding headless one-shots
# (-p/--print/--version) and env-inherited node/MCP children. Deliberately NOT read from the cc-registry —
# the whole point is to catch panes the registry (hence cc-classify) never enumerated.
live_pane_count(){
  "$PS_BIN" -wwEo command= 2>/dev/null | awk '
    { t0=$1
      if (t0!="claude" && t0 !~ /\/claude$/ && t0 !~ /cli\.js/) next
      for (i=2; i<=7 && i<=NF; i++) if ($i=="-p" || $i=="--print" || $i=="--version") next
      c++ }
    END { print c+0 }'
}

# clean AND the branch's content is on trunk — the load-bearing work-landed re-check (post-classify race
# guard). P0-17 landed-by-CONTENT (a18 L-10): a squash/cherry-pick land (different sha, same content)
# leaves HEAD "N ahead" by COUNT though the work is durably on trunk; a count check DEFERred it forever.
work_landed() {
  local cwd="$1"
  [ -d "$cwd" ] || return 1
  "$GIT_BIN" -C "$cwd" rev-parse --git-dir >/dev/null 2>&1 || return 1
  # --untracked-files=no (2026-07-20): a finished session's own work-safety is about ITS OWN
  # uncommitted TRACKED changes — never a sibling's untracked litter in a SHARED cwd. Counting
  # untracked files left every co-cwd session permanently "dirty" (one stray scratch file in the
  # shared checkout ⇒ landed never re-verified ⇒ nothing could self-close), which is how 13+
  # finished workers piled up on the operator's confirm-close queue. Untracked files are also
  # never LOST by a pane close (they stay on disk; worktree_cleanup separately refuses to
  # --force-remove a tree carrying any).
  [ -z "$("$GIT_BIN" -C "$cwd" status --porcelain --untracked-files=no 2>/dev/null)" ] || return 1
  local ahead; ahead="$("$GIT_BIN" -C "$cwd" rev-list --count "$TRUNK"..HEAD 2>/dev/null)" || return 1
  [ "${ahead:-1}" = 0 ] && return 0                              # fast path: 0 ahead by COUNT → landed
  # content path: `git cherry` patch-id equivalence ('+' = genuinely unlanded); tree-diff-0 = squash backstop.
  local cherry_out
  if cherry_out="$("$GIT_BIN" -C "$cwd" cherry "$TRUNK" HEAD 2>/dev/null)"; then
    printf '%s\n' "$cherry_out" | grep -q '^+' || return 0
  fi
  "$GIT_BIN" -C "$cwd" diff --quiet "$TRUNK" HEAD 2>/dev/null && return 0
  return 1
}

checkpoint_first() { # <cwd> <name> <sid> — snapshot WIP to refs/wip/<name>/LAST (proven plumbing)
  local cwd="$1" name="$2" sid="$3"
  [ -x "$CHECKPOINT_BIN" ] || { log "checkpoint: $CHECKPOINT_BIN not executable — SKIP (no snapshot)"; return 1; }
  printf '{"session_id":"%s","hook_event_name":"TeammateIdle","cwd":"%s","team_name":"cc-reaper","teammate_name":"%s"}' \
    "$sid" "$cwd" "$name" | "$CHECKPOINT_BIN" >/dev/null 2>&1 || true
  return 0
}

worktree_cleanup() { # <cwd> — remove a LINKED worktree after a confirmed teardown (never the main tree)
  local cwd="$1"
  case "$cwd" in /tmp/wt-*|/private/tmp/wt-*|/tmp/worktree-*|*/.worktrees/*) ;; *) return 0 ;; esac
  # Only a LINKED worktree (git-dir != <cwd>/.git). Removing must run from the MAIN worktree.
  local gitdir main
  gitdir="$("$GIT_BIN" -C "$cwd" rev-parse --git-dir 2>/dev/null)" || return 0
  case "$gitdir" in */worktrees/*) ;; *) return 0 ;; esac      # not a linked worktree → leave it
  main="$("$GIT_BIN" -C "$cwd" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')"
  [ -n "$main" ] && [ "$main" != "$cwd" ] || return 0
  # UNTRACKED GUARD (2026-07-20, paired with the --untracked-files=no relaxation in work_landed):
  # `worktree remove --force` DELETES untracked files. work_landed now (correctly) ignores them, so
  # without this check a reap could reach here and destroy an uncommitted research report / scratch
  # output nothing ever committed. HERE — and only here, where deletion is real — untracked counts
  # as dirty: leave the tree on disk and say so. The PANE is still reaped either way.
  if [ -n "$("$GIT_BIN" -C "$cwd" status --porcelain 2>/dev/null)" ]; then
    say "    worktree LEFT INTACT (untracked files present — --force would delete them): $cwd"
    log "worktree left intact (untracked present): $cwd"; return 0
  fi
  if "$GIT_BIN" -C "$main" worktree remove --force "$cwd" 2>/dev/null; then
    say "    worktree removed: $cwd"; log "worktree removed: $cwd"
  else
    say "    worktree remove FAILED (left intact): $cwd"; log "worktree remove failed: $cwd"
  fi
}

# ── T-P3-3: page the desk on a never-reap-but-surface cause (damped). Prints the reaper's per-session line. ──
handle_surface() { # <reap> <key> <name> <cause> <pane> <detail>
  local reap="$1" key="$2" name="$3" cause="$4" pane="$5" detail="$6"
  if [ "$reap" = 0 ]; then
    say "  WOULD-PAGE $name [$cause] — surface-worthy (desk paged in --reap)"; return 0
  fi
  mkdir -p "$PAGEDIR" 2>/dev/null || true
  local mk="$PAGEDIR/$key.cause" last
  last="$(cat "$mk" 2>/dev/null || true)"
  if [ "$last" = "$cause" ]; then
    say "  keep   $name [$cause] — surfaced (already paged this cause; damped)"; return 0
  fi
  notify_desk "⚠️ REAPER SURFACE — session ${name} is ${cause}: ${detail} (never-reap; desk/operator resolves — re-engage a hang · close a crashed pane · confirm-close a shared-review). cc-reaper never auto-acts on this."
  printf '%s\n' "$cause" > "$mk" 2>/dev/null || true
  idl_surface "$cause" "$name" "$pane"
  say "  PAGE   $name [$cause] → desk (surfaced, never-reap)"
  log "surface-page $name [$cause] pane=$pane"
}

# ── P0-12b: enumerated≈live-panes self-check. `enum` = what cc-classify saw this sweep; `live` = the
#    independent interactive-pane count. A positive delta past tolerance, PERSISTED, pages the desk once. ──
self_check() { # <reap> <enumerated>
  local reap="$1" enum="$2" live delta sf
  live="$(live_pane_count)"; delta=$(( live - enum ))
  sf="$PAGEDIR/selfcheck.state"
  if [ "$delta" -le "$PANE_DELTA_TOL" ]; then
    say "cc-reaper self-check: $live live pane(s) ≈ $enum enumerated (Δ$delta ≤ tol $PANE_DELTA_TOL) — reaper sees all live panes"
    [ "$reap" = 1 ] && { mkdir -p "$PAGEDIR" 2>/dev/null || true; printf '0 0\n' > "$sf" 2>/dev/null || true; }   # re-arm
    return 0
  fi
  if [ "$reap" = 0 ]; then
    say "cc-reaper self-check: WOULD-PAGE — $live live panes vs $enum enumerated (Δ$delta unseen; a spawn mode isn't registering)"; return 0
  fi
  mkdir -p "$PAGEDIR" 2>/dev/null || true
  local consec paged
  read -r consec paged < <(cat "$sf" 2>/dev/null || echo "0 0"); consec="${consec:-0}"; paged="${paged:-0}"
  consec=$(( consec + 1 ))
  if [ "$consec" -ge "$SELFCHECK_MIN_PERSIST" ] && { [ "$paged" = 0 ] || [ "$delta" -gt "$paged" ]; }; then
    notify_desk "⚠️ REAPER SELF-CHECK — ${live} live Claude panes but only ${enum} enumerated (Δ${delta} unseen). The reaper is BLIND to ${delta} live session(s): a spawn mode isn't registering in cc-registry, so they can't be classified or reaped. Investigate: compare \`cc-sessions --json\` against the live interactive-claude procs."
    idl_selfcheck "$live" "$enum" "$delta"
    say "cc-reaper self-check: PAGE — Δ$delta blind spot ($live live vs $enum enumerated) → desk"
    log "self-check page: live=$live enum=$enum delta=$delta (persisted ${consec} sweep(s))"
    paged="$delta"
  else
    say "cc-reaper self-check: Δ$delta blind spot ($live live vs $enum enumerated) — persist ${consec}/${SELFCHECK_MIN_PERSIST}$([ "$paged" != 0 ] && printf ' (already paged; damped)')"
  fi
  printf '%s %s\n' "$consec" "$paged" > "$sf" 2>/dev/null || true
}

sweep() {
  local reap=0; [ "${1:-}" = "--reap" ] && reap=1
  local mode; mode=$([ $reap = 1 ] && echo REAP || echo DRY-RUN)
  say "cc-reaper sweep ($mode) — settle=${SETTLE_S}s trunk=$TRUNK"
  log "sweep start mode=$mode settle=$SETTLE_S"
  # Self-heal the registry BEFORE enumerating, so a pane that missed SessionStart is backfilled and
  # ENUMERATED this same sweep (delta closes) rather than only surfaced. Additive + idempotent; gated on
  # --reap so a DRY-RUN sweep still writes nothing (its self-check then reports the true pre-heal delta).
  if [ "$reap" = 1 ] && [ -n "$RECONCILE_BIN" ]; then
    local rout; rout="$("$RECONCILE_BIN" 2>/dev/null || true)"
    [ -n "$rout" ] && { say "$rout"; log "reconcile: $rout"; }
  fi
  # Claim-ledger reap (dead-worker stale claim → reopen · thrash → block). Same --reap gating as
  # reconcile (a DRY-RUN sweep writes nothing); append-only + idempotent, so it is safe every sweep.
  if [ "$reap" = 1 ] && [ -n "$BACKLOG_BIN" ]; then
    local bout; bout="$("$BACKLOG_BIN" reap 2>/dev/null || true)"
    [ -n "$bout" ] && { say "$bout"; log "backlog-reap: $bout"; }
  fi
  # v2-comms fail-loud backstop: escalate inbox mail enqueued but never consumed. Same --reap gating; the
  # guard is self-damping (one escalation per undelivered state), so it is safe every sweep.
  if [ "$reap" = 1 ] && [ -n "$GUARD_BIN" ]; then
    local gout; gout="$("$GUARD_BIN" sweep 2>/dev/null || true)"
    [ -n "$gout" ] && log "inbox-guard: $gout"
  fi
  local cj; cj="$("$CLASSIFY_BIN" --all --json 2>/dev/null || echo '[]')"
  local n; n="$(printf '%s' "$cj" | jq 'length' 2>/dev/null || echo 0)"
  local reaped=0 candidates=0 surfaced=0 surfaced_keys=" " i
  for ((i=0; i<n; i++)); do
    local o cause name pane cwd idle landed xpid xlstart
    o="$(printf '%s' "$cj" | jq -c ".[$i]")"
    cause="$(printf '%s' "$o" | jq -r '.cause // "?"')"
    name="$(printf '%s'  "$o" | jq -r '.name // .paneUUID // "?"')"
    pane="$(printf '%s'  "$o" | jq -r '.paneUUID // ""')"
    cwd="$(printf '%s'   "$o" | jq -r '.cwd // ""')"
    idle="$(printf '%s'  "$o" | jq -r '.idle_s // -1')"
    landed="$(printf '%s' "$o" | jq -r '.work_landed // "no"')"
    xpid="$(printf '%s'  "$o" | jq -r '.pid // ""')"        # classify-time identity pin (a17 S-4)
    xlstart="$(printf '%s' "$o" | jq -r '.lstart // ""')"

    # ── disposition (never-reap is the default; a reap needs every gate) ──
    if ! [[ "$cause" =~ $REAPABLE_RE ]]; then
      # T-P3-3: a never-reap cause that needs a HUMAN → page the desk (damped); the rest just stay quiet.
      if [[ "$cause" =~ $SURFACE_PAGE_RE ]]; then
        surfaced=$((surfaced+1))
        local key; key="$(sanitize_key "${pane:-$name}")"
        surfaced_keys="$surfaced_keys$key "
        handle_surface "$reap" "$key" "$name" "$cause" "$pane" "$(printf '%s' "$o" | jq -r '.detail // ""')"
      else
        say "  keep   $name [$cause] — never-reap cause"
      fi
      continue
    fi
    if [ "$landed" != yes ]; then
      say "  keep   $name [$cause] — work NOT landed (would strand work) → DEFER"; log "defer $name: not landed"; continue
    fi
    if ! [ "$idle" -ge "$SETTLE_S" ] 2>/dev/null; then
      say "  keep   $name [$cause] — idle ${idle}s < settle ${SETTLE_S}s (self-close still has its chance)"; continue
    fi
    candidates=$((candidates+1))
    if [ $reap = 0 ]; then
      say "  WOULD-REAP $name [$cause] pane=$pane idle=${idle}s landed=yes"; log "would-reap $name [$cause]"; continue
    fi

    # ── ACT: checkpoint-first → re-verify landed → cc-teardown (double-gate) → worktree cleanup ──
    say "  REAP   $name [$cause] pane=$pane"
    checkpoint_first "$cwd" "$name" "$(printf '%s' "$o" | jq -r '.paneUUID')"
    if ! work_landed "$cwd"; then
      say "    ABORT — became dirty/ahead post-classify; WIP checkpointed, NOT reaping"; log "abort $name: dirty post-classify (WIP checkpointed)"; continue
    fi
    local succ ev trc
    succ="$(printf '%s' "$o" | jq -r '.successor // "none"')"
    ev="cc-reaper: cause=$cause successor=$succ work-landed(clean & 0 ahead of $TRUNK) idle=${idle}s — positive done-evidence, not inferred from silence"
    # identity pin (a17 S-4): pass classify-time {pid,lstart} so cc-teardown REFUSES if the pane recycled
    # in the classify→act window (successor booted in the same pane). Only pin when classify supplied it.
    local expect_args=()
    { [ -n "$xpid" ] && [ "$xpid" != null ]; } && expect_args+=(--expect-pid "$xpid")
    { [ -n "$xlstart" ] && [ "$xlstart" != null ]; } && expect_args+=(--expect-lstart "$xlstart")
    "$TEARDOWN_BIN" "$pane" --done-evidence "$ev" "${expect_args[@]+"${expect_args[@]}"}"; trc=$?
    if [ "$trc" = 0 ]; then
      reaped=$((reaped+1)); say "    torn down + effect-verified (cc-teardown exit 0)"; log "reaped $name [$cause] pane=$pane"
      worktree_cleanup "$cwd"
    else
      say "    cc-teardown returned $trc (10=DEFER 2=REFUSE 5=FAIL) — its gate refused; NOT reaped (trusted)"; log "teardown-refused $name rc=$trc"
    fi
  done

  # ── T-P3-3 re-arm: a pane no longer in the surface set (recovered / cause cleared) drops its damping
  #    marker, so a future re-hang re-pages. A persistent hang stays surfaced every sweep → never cleared.
  #    (Page-marker LIFECYCLE, the clear_page analog — NOT an evidence-horizon reaper; see reaper-horizon-lint.)
  if [ "$reap" = 1 ] && [ -d "$PAGEDIR" ]; then
    local mk bn
    for mk in "$PAGEDIR"/*.cause; do
      [ -e "$mk" ] || continue
      bn="$(basename "$mk" .cause)"
      case "$surfaced_keys" in *" $bn "*) ;; *) rm -f "$mk" 2>/dev/null || true ;; esac
    done
  fi

  say "cc-reaper: $n classified · $candidates safe candidate(s) · $reaped reaped · $surfaced surfaced"
  log "sweep end: $n classified $candidates candidates $reaped reaped $surfaced surfaced"

  # ── P0-12b: the blind-spot self-check runs once per sweep, AFTER classification (enum = what we saw). ──
  self_check "$reap" "$n"
  return 0
}

case "${1:-}" in
  sweep)        sweep "${2:-}" ;;
  selftest)     exec bats "$HERE/../tests/cc-reaper.bats" ;;
  -h|--help|"") sed -n '2,20p' "$0"; exit 0 ;;
  *)            echo "cc-reaper: unknown command '$1' (sweep | selftest)" >&2; exit 2 ;;
esac
